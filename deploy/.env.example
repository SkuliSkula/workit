# Copy this file to .env and fill in your values before running docker compose.
# Never commit .env to git.

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=workit
POSTGRES_USER=workit
POSTGRES_PASSWORD=change-me-strong-db-password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Use a long random string — at least 32 characters.
# Generate one with: openssl rand -base64 48
JWT_SIGNING_KEY=change-me-very-long-random-signing-key-here

# ── Initial admin account ────────────────────────────────────────────────────
# Used once on first boot to create the super-admin user.
ADMIN_EMAIL=admin@workit.is
ADMIN_PASSWORD=change-me-strong-admin-password

# ── Payday integration (optional) ────────────────────────────────────────────
PAYDAY_CLIENT_ID=
PAYDAY_CLIENT_SECRET=
