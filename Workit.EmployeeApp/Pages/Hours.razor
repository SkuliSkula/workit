@page "/"
@page "/hours"
@inject AuthSessionService AuthSession
@inject NavigationManager Navigation
@inject ICompanyApi CompanyApi
@inject IEmployeesApi EmployeesApi
@inject IJobsApi JobsApi
@inject ITimeEntriesApi TimeEntriesApi
@inject IDrivingApi DrivingApi

<PageTitle>Hours</PageTitle>

@* ── Mode toggle ── *@
<div class="hours-mode-toggle employee-shell">
    <button class="hours-mode-btn @(mode == PageMode.Hours ? "hours-mode-btn--active" : "")"
            @onclick="@(() => SetMode(PageMode.Hours))">Hours</button>
    <button class="hours-mode-btn @(mode == PageMode.Driving ? "hours-mode-btn--active" : "")"
            @onclick="@(() => SetMode(PageMode.Driving))">Driving</button>
</div>

@* ── Summary header ── *@
@if (mode == PageMode.Hours)
{
    <div class="hours-header employee-shell hours-card">
        <div>
            <span class="employee-eyebrow">Last 30 days</span>
            <div class="hours-header-total">
                @totalRecentHours.ToString("0.#")<span class="hours-header-unit"> hrs</span>
            </div>
            <div class="hours-header-company">@(company?.Name ?? string.Empty)</div>
        </div>
        <div class="hours-header-stats">
            <div class="hours-header-stat">
                <span class="hours-header-stat-val">@entries.Count</span>
                <span class="hours-header-stat-lbl">entries</span>
            </div>
            <div class="hours-header-stat">
                <span class="hours-header-stat-val">@uniqueJobCount</span>
                <span class="hours-header-stat-lbl">jobs</span>
            </div>
        </div>
    </div>
}
else
{
    <div class="hours-header employee-shell hours-card">
        <div>
            <span class="employee-eyebrow">Last 30 days</span>
            <div class="hours-header-total">
                @totalRecentDrivingUnits<span class="hours-header-unit"> km</span>
            </div>
            <div class="hours-header-company">@(company?.Name ?? string.Empty)</div>
        </div>
        <div class="hours-header-stats">
            <div class="hours-header-stat">
                <span class="hours-header-stat-val">@drivingEntries.Count</span>
                <span class="hours-header-stat-lbl">entries</span>
            </div>
            <div class="hours-header-stat">
                <span class="hours-header-stat-val">@uniqueDrivingJobCount</span>
                <span class="hours-header-stat-lbl">jobs</span>
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrWhiteSpace(loadError))
{
    <div class="hours-error-banner">@loadError</div>
}

@* ── Hours entry list ── *@
@if (mode == PageMode.Hours)
{
    @if (entries.Count == 0 && string.IsNullOrWhiteSpace(loadError))
    {
        <div class="hours-empty">
            <FluentIcon Value="new Size48.Clock()" />
            <strong>No entries yet</strong>
            <span>Tap the + button to log your first hours.</span>
        </div>
    }
    else
    {
        <div class="hours-entry-list">
            @foreach (var entry in entries.OrderByDescending(e => e.WorkDate).ThenByDescending(e => e.Hours))
            {
                <div class="hours-entry-item">
                    <div class="hours-entry-top">
                        <span class="hours-entry-date">@entry.WorkDate.ToString("MMM d, yyyy")</span>
                        <div class="hours-entry-badges">
                            <span class="hours-entry-badge">@entry.Hours h</span>
                            @if (entry.OvertimeHours > 0)
                            {
                                <span class="hours-entry-badge hours-entry-badge-ot">+@entry.OvertimeHours h OT</span>
                            }
                        </div>
                    </div>
                    <div class="hours-entry-job">@jobLookup.GetValueOrDefault(entry.JobId, "Unknown job")</div>
                    @if (!string.IsNullOrWhiteSpace(entry.Notes))
                    {
                        <div class="hours-entry-notes">@entry.Notes</div>
                    }
                </div>
            }
        </div>
    }
}

@* ── Driving entry list ── *@
@if (mode == PageMode.Driving)
{
    @if (drivingEntries.Count == 0 && string.IsNullOrWhiteSpace(loadError))
    {
        <div class="hours-empty">
            <FluentIcon Value="new Size48.VehicleCar()" />
            <strong>No driving logged yet</strong>
            <span>Tap the + button to log driving.</span>
        </div>
    }
    else
    {
        <div class="hours-entry-list">
            @foreach (var de in drivingEntries.OrderByDescending(d => d.WorkDate))
            {
                <div class="hours-entry-item">
                    <div class="hours-entry-top">
                        <span class="hours-entry-date">@de.WorkDate.ToString("MMM d, yyyy")</span>
                        <span class="hours-entry-badge">@de.Units km</span>
                    </div>
                    <div class="hours-entry-job">@jobLookup.GetValueOrDefault(de.JobId, "Unknown job")</div>
                    @if (!string.IsNullOrWhiteSpace(de.Notes))
                    {
                        <div class="hours-entry-notes">@de.Notes</div>
                    }
                </div>
            }
        </div>
    }
}

@* ── Floating action button ── *@
<button class="hours-fab"
        @onclick="OpenSheet"
        disabled="@(!CanCreateEntries)"
        aria-label="@(mode == PageMode.Hours ? "Log new hours" : "Log driving")">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="28" height="28"
         fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <line x1="12" y1="4" x2="12" y2="20" />
        <line x1="4" y1="12" x2="20" y2="12" />
    </svg>
</button>

@* ── Bottom sheet backdrop ── *@
<div class="sheet-backdrop @(isSheetOpen ? "show" : string.Empty)" @onclick="CloseSheet"></div>

@* ── Bottom sheet drawer ── *@
<section class="sheet @(isSheetOpen ? "show" : string.Empty)">
    <div class="sheet-handle"></div>

    <div class="sheet-header">
        <div class="sheet-header-left">
            <div class="sheet-header-icon">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20"
                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10" />
                    <polyline points="12 6 12 12 16 14" />
                </svg>
            </div>
            <h2>@(mode == PageMode.Hours ? "Log hours" : "Log driving")</h2>
        </div>
        <button class="sheet-close-btn" @onclick="CloseSheet" aria-label="Close">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20"
                 fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                <line x1="18" y1="6" x2="6" y2="18" />
                <line x1="6" y1="6" x2="18" y2="18" />
            </svg>
        </button>
    </div>

    <div class="sheet-form">
        @* Job — full width *@
        <div class="sheet-field sheet-field-full">
            <label class="sheet-label">Job</label>
            @if (jobs.Count > 0)
            {
                <FluentSelect TValue="string" TOption="string" @bind-Value="selectedJobId" style="width:100%">
                    @foreach (var job in jobs)
                    {
                        <FluentOption TOption="string" Value="@job.Id.ToString()">
                            @job.Code – @job.Name
                        </FluentOption>
                    }
                </FluentSelect>
            }
            else
            {
                <span class="sheet-no-jobs">No jobs available.</span>
            }
        </div>

        @* Date + Hours/Driving fields *@
        @if (mode == PageMode.Hours)
        {
            <div class="sheet-row sheet-row-3">
                <div class="sheet-field">
                    <label class="sheet-label">Date</label>
                    <FluentDatePicker @bind-Value="workDate" style="width:100%" />
                </div>
                <div class="sheet-field">
                    <label class="sheet-label">Hours</label>
                    <FluentNumberField TValue="decimal" @bind-Value="hours" Step="0.5" Min="0" style="width:100%" />
                </div>
                <div class="sheet-field">
                    <label class="sheet-label">
                        Overtime
                        <span class="sheet-label-hint">optional</span>
                    </label>
                    <FluentNumberField TValue="decimal" @bind-Value="overtimeHours" Step="0.5" Min="0" style="width:100%" />
                </div>
            </div>
        }
        else
        {
            <div class="sheet-row sheet-row-2">
                <div class="sheet-field">
                    <label class="sheet-label">Date</label>
                    <FluentDatePicker @bind-Value="workDate" style="width:100%" />
                </div>
                <div class="sheet-field">
                    <label class="sheet-label">km driven</label>
                    <FluentNumberField TValue="int" @bind-Value="drivingUnits" Min="1" style="width:100%" />
                </div>
            </div>
        }

        @* Notes — full width *@
        <div class="sheet-field sheet-field-full">
            <label class="sheet-label">Notes <span class="sheet-label-hint">optional</span></label>
            <FluentTextField @bind-Value="notes" Placeholder="e.g. Installed windows on 2nd floor" style="width:100%" />
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(saveError))
    {
        <div class="hours-error-banner">@saveError</div>
    }

    <button class="sheet-save-btn"
            @onclick="SaveEntryAsync"
            disabled="@(!CanCreateEntries || isSaving)">
        @if (isSaving)
        {
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20"
                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                 class="sheet-save-spinner">
                <path d="M12 2a10 10 0 1 0 10 10" />
            </svg>
            <span>Saving…</span>
        }
        else
        {
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20"
                 fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z" />
                <polyline points="17 21 17 13 7 13 7 21" />
                <polyline points="7 3 7 8 15 8" />
            </svg>
            <span>@(mode == PageMode.Hours ? "Save hours" : "Save driving")</span>
        }
    </button>
</section>

@code {
    private enum PageMode { Hours, Driving }

    private readonly List<Job>          jobs           = [];
    private readonly List<TimeEntry>    entries        = [];
    private readonly List<DrivingEntry> drivingEntries = [];
    private readonly Dictionary<Guid, string> jobLookup = new();

    private Company?  company;
    private PageMode  mode          = PageMode.Hours;
    private string?   selectedJobId;
    private string?   loadError;
    private string?   saveError;
    private DateTime? workDate      = DateTime.Today;
    private decimal   hours         = 8m;
    private decimal   overtimeHours = 0m;
    private int       drivingUnits  = 1;
    private string    notes         = string.Empty;
    private bool      isSheetOpen;
    private bool      isSaving;

    private decimal totalRecentHours        => entries.Sum(e => e.Hours);
    private int     uniqueJobCount          => entries.Select(e => e.JobId).Distinct().Count();
    private int     totalRecentDrivingUnits => drivingEntries.Sum(d => d.Units);
    private int     uniqueDrivingJobCount   => drivingEntries.Select(d => d.JobId).Distinct().Count();

    private bool CanCreateEntries =>
        company is not null &&
        Guid.TryParse(selectedJobId, out _);

    private void SetMode(PageMode m) { mode = m; isSheetOpen = false; }

    protected override async Task OnInitializedAsync()
    {
        var session = await AuthSession.GetSessionAsync();
        if (session is null || !string.Equals(session.Role, WorkitRoles.Employee, StringComparison.Ordinal))
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadCompanyAsync();
        await LoadDataAsync();
    }

    private async Task LoadCompanyAsync()
    {
        var result = await CompanyApi.GetCompanyAsync();
        company = result.Value;
        loadError = result.IsSuccess ? null : result.ErrorMessage;
    }

    private async Task LoadDataAsync()
    {
        jobs.Clear();
        entries.Clear();
        drivingEntries.Clear();
        jobLookup.Clear();
        selectedJobId = null;

        if (company is null) return;

        var jobsResult = await JobsApi.GetJobsAsync();
        if (!jobsResult.IsSuccess) { loadError ??= jobsResult.ErrorMessage; return; }

        jobs.AddRange(jobsResult.Value ?? []);
        foreach (var job in jobs) jobLookup[job.Id] = $"{job.Code} – {job.Name}";
        selectedJobId = jobs.FirstOrDefault()?.Id.ToString();

        var from = DateOnly.FromDateTime(DateTime.Today.AddDays(-30));
        var entriesTask  = TimeEntriesApi.GetTimeEntriesAsync(from);
        var drivingTask  = DrivingApi.GetDrivingEntriesAsync();
        await Task.WhenAll(entriesTask, drivingTask);

        var entriesResult = await entriesTask;
        if (!entriesResult.IsSuccess) { loadError ??= entriesResult.ErrorMessage; return; }
        entries.AddRange(entriesResult.Value ?? []);

        var drivingResult = await drivingTask;
        if (drivingResult.IsSuccess) drivingEntries.AddRange(drivingResult.Value ?? []);
    }

    private async Task SaveEntryAsync()
    {
        if (company is null || !Guid.TryParse(selectedJobId, out var jobId) || workDate is null)
            return;

        saveError = null;
        isSaving  = true;

        try
        {
            ApiResult result;

            if (mode == PageMode.Hours)
            {
                result = await TimeEntriesApi.CreateTimeEntryAsync(new TimeEntry
                {
                    CompanyId     = company.Id,
                    JobId         = jobId,
                    WorkDate      = DateOnly.FromDateTime(workDate.Value.Date),
                    Hours         = hours,
                    OvertimeHours = overtimeHours,
                    Notes         = notes
                });
            }
            else
            {
                result = await DrivingApi.CreateDrivingEntryAsync(new DrivingEntry
                {
                    CompanyId = company.Id,
                    JobId     = jobId,
                    WorkDate  = DateOnly.FromDateTime(workDate.Value.Date),
                    Units     = drivingUnits,
                    Notes     = notes
                });
            }

            if (result.IsSuccess)
            {
                notes         = string.Empty;
                hours         = 8m;
                overtimeHours = 0m;
                drivingUnits  = 1;
                isSheetOpen   = false;
                await LoadDataAsync();
            }
            else
            {
                saveError = result.ErrorMessage ?? "Could not save entry.";
            }
        }
        finally
        {
            isSaving = false;
        }
    }

    private void OpenSheet()  => isSheetOpen = true;
    private void CloseSheet() => isSheetOpen = false;
}
