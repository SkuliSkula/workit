@inject AuthSessionService AuthSession
@inject NavigationManager Navigation
@implements IDisposable

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Workit Owner</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        @if (!isAuthenticated)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="login">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Login
                </NavLink>
            </div>
        }

        @if (isAdmin)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="register">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Register
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="admin">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Admin
                </NavLink>
            </div>
        }

        @if (isOwner || isAdmin)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="customers">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Customers
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="employees">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Employees
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="jobs">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Jobs
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="timeentries">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Time Entries
                </NavLink>
            </div>

            @* ── Payday expandable group ── *@
            <div class="nav-item px-3">
                <button type="button" class="nav-link nav-link-button nav-group-toggle"
                        @onclick="TogglePayday">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span>
                    Payday
                    <span class="nav-chevron @(paydayExpanded ? "expanded" : "")">&#8250;</span>
                </button>
            </div>

            @if (paydayExpanded)
            {
                <div class="nav-submenu">
                    <div class="nav-item">
                        <NavLink class="nav-link nav-sublink" href="payday" Match="NavLinkMatch.All">
                            <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Sync
                        </NavLink>
                    </div>
                    <div class="nav-item">
                        <NavLink class="nav-link nav-sublink" href="payday/dashboard">
                            <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Dashboard
                        </NavLink>
                    </div>
                    <div class="nav-item">
                        <NavLink class="nav-link nav-sublink" href="payday/invoices">
                            <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Invoices
                        </NavLink>
                    </div>
                </div>
            }
        }

        @if (isAuthenticated)
        {
            <div class="nav-item px-3">
                <button type="button" class="nav-link nav-link-button" @onclick="LogoutAsync">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Logout
                </button>
            </div>
        }
    </nav>
</div>

<style>
    .nav-group-toggle {
        display: flex;
        align-items: center;
        width: 100%;
        gap: 0;
    }

    .nav-chevron {
        margin-left: auto;
        font-size: 1.1rem;
        line-height: 1;
        transition: transform 0.2s ease;
        transform: rotate(0deg);
        display: inline-block;
    }

    .nav-chevron.expanded {
        transform: rotate(90deg);
    }

    .nav-submenu {
        padding-left: 2rem;
        border-left: 2px solid rgba(255,255,255,0.15);
        margin-left: 1.25rem;
        margin-bottom: 0.25rem;
    }

    .nav-sublink {
        font-size: 0.9rem;
        padding-top: 0.3rem;
        padding-bottom: 0.3rem;
    }
</style>

@code {
    private bool isAdmin;
    private bool isOwner;
    private bool isAuthenticated;
    private bool paydayExpanded;

    protected override void OnInitialized()
    {
        paydayExpanded = IsOnPaydayRoute();
        Navigation.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var session = await AuthSession.GetSessionAsync();
        var nextIsAuthenticated = session is not null;
        var nextIsAdmin  = session?.Role == WorkitRoles.Admin;
        var nextIsOwner  = session?.Role == WorkitRoles.Owner;

        if (nextIsAuthenticated == isAuthenticated &&
            nextIsAdmin  == isAdmin &&
            nextIsOwner  == isOwner)
        {
            return;
        }

        isAuthenticated = nextIsAuthenticated;
        isAdmin  = nextIsAdmin;
        isOwner  = nextIsOwner;
        StateHasChanged();
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        if (IsOnPaydayRoute())
            paydayExpanded = true;
        InvokeAsync(StateHasChanged);
    }

    private void TogglePayday() => paydayExpanded = !paydayExpanded;

    private bool IsOnPaydayRoute()
    {
        var path = Navigation.ToBaseRelativePath(Navigation.Uri).TrimStart('/');
        return path.StartsWith("payday", StringComparison.OrdinalIgnoreCase);
    }

    private async Task LogoutAsync()
    {
        await AuthSession.LogoutAsync();
        Navigation.NavigateTo("/", forceLoad: true);
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
