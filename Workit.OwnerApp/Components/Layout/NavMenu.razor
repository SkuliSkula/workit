@inject AuthSessionService AuthSession
@inject NavigationManager Navigation
@implements IDisposable

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Workit Owner</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        @if (!isAuthenticated)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="login" Match="NavLinkMatch.All">
                    <FluentIcon Value="new Size24.PersonKey()" /> Login
                </NavLink>
            </div>
        }

        @if (isAuthenticated)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                    <FluentIcon Value="new Size24.Home()" /> Home
                </NavLink>
            </div>
        }

        @if (isAdmin)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="admin">
                    <FluentIcon Value="new Size24.Shield()" /> Admin
                </NavLink>
            </div>
        }

        @* Owner without a company — show only the onboarding link *@
        @if (isOwner && !ownerHasCompany)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="onboarding" Match="NavLinkMatch.All">
                    <FluentIcon Value="new Size24.BuildingFactory()" /> Set Up Company
                </NavLink>
            </div>
        }

        @if ((isOwner && ownerHasCompany) || isAdmin)
        {
            @* ── Owner expandable group ── *@
            <div class="nav-item px-3">
                <button type="button" class="nav-link nav-link-button nav-group-toggle"
                        @onclick="ToggleOwner">
                    <FluentIcon Value="new Size24.Person()" />
                    Owner
                    <span class="nav-chevron @(ownerExpanded ? "expanded" : "")">&#8250;</span>
                </button>
            </div>

            @if (ownerExpanded)
            {
                <div class="nav-submenu">
                    @if (isOwner && ownerHasCompany)
                    {
                        <div class="nav-item">
                            <NavLink class="nav-link nav-sublink" href="companies">
                                <FluentIcon Value="new Size24.Building()" /> Companies
                            </NavLink>
                        </div>
                    }
                    <div class="nav-item">
                        <NavLink class="nav-link nav-sublink" href="customers">
                            <FluentIcon Value="new Size24.PeopleTeam()" /> Customers
                        </NavLink>
                    </div>
                    <div class="nav-item">
                        <NavLink class="nav-link nav-sublink" href="jobs">
                            <FluentIcon Value="new Size24.Briefcase()" /> Jobs
                        </NavLink>
                    </div>
                    <div class="nav-item">
                        <NavLink class="nav-link nav-sublink" href="employees">
                            <FluentIcon Value="new Size24.Person()" /> Employees
                        </NavLink>
                    </div>
                    <div class="nav-item">
                        <NavLink class="nav-link nav-sublink" href="timeentries">
                            <FluentIcon Value="new Size24.Clock()" /> Time Entries
                        </NavLink>
                    </div>
                </div>
            }

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="kanban">
                    <FluentIcon Value="new Size24.TaskListSquareLtr()" /> Kanban
                </NavLink>
            </div>

            @* ── Resources expandable group ── *@
            <div class="nav-item px-3">
                <button type="button" class="nav-link nav-link-button nav-group-toggle"
                        @onclick="ToggleResources">
                    <FluentIcon Value="new Size24.Toolbox()" />
                    Resources
                    <span class="nav-chevron @(resourcesExpanded ? "expanded" : "")">&#8250;</span>
                </button>
            </div>

            @if (resourcesExpanded)
            {
                <div class="nav-submenu">
                    <div class="nav-item">
                        <NavLink class="nav-link nav-sublink" href="calendar">
                            <FluentIcon Value="new Size24.CalendarLtr()" /> Calendar
                        </NavLink>
                    </div>
                    <div class="nav-item">
                        <NavLink class="nav-link nav-sublink" href="absence">
                            <FluentIcon Value="new Size24.CalendarCancel()" /> Absence
                        </NavLink>
                    </div>
                    <div class="nav-item">
                        <NavLink class="nav-link nav-sublink" href="tools">
                            <FluentIcon Value="new Size24.Wrench()" /> Tools
                        </NavLink>
                    </div>
                    <div class="nav-item">
                        <NavLink class="nav-link nav-sublink" href="materials">
                            <FluentIcon Value="new Size24.Box()" /> Materials
                        </NavLink>
                    </div>
                </div>
            }

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="invoices">
                    <FluentIcon Value="new Size24.DocumentText()" /> Invoices
                </NavLink>
            </div>

            @* ── Payday expandable group ── *@
            <div class="nav-item px-3">
                <button type="button" class="nav-link nav-link-button nav-group-toggle"
                        @onclick="TogglePayday">
                    <FluentIcon Value="new Size24.Money()" />
                    Payday
                    <span class="nav-chevron @(paydayExpanded ? "expanded" : "")">&#8250;</span>
                </button>
            </div>

            @if (paydayExpanded)
            {
                <div class="nav-submenu">
                    <div class="nav-item">
                        <NavLink class="nav-link nav-sublink" href="payday" Match="NavLinkMatch.All">
                            <FluentIcon Value="new Size24.ArrowSync()" /> Sync
                        </NavLink>
                    </div>
                    <div class="nav-item">
                        <NavLink class="nav-link nav-sublink" href="payday/dashboard">
                            <FluentIcon Value="new Size24.ChartMultiple()" /> Dashboard
                        </NavLink>
                    </div>
                    <div class="nav-item">
                        <NavLink class="nav-link nav-sublink" href="payday/invoices">
                            <FluentIcon Value="new Size24.DocumentText()" /> Invoices
                        </NavLink>
                    </div>
                    <div class="nav-item">
                        <NavLink class="nav-link nav-sublink" href="payday/invoice-builder">
                            <FluentIcon Value="new Size24.DocumentBulletList()" /> Invoice Builder
                        </NavLink>
                    </div>
                    <div class="nav-item">
                        <NavLink class="nav-link nav-sublink" href="payday/expenses">
                            <FluentIcon Value="new Size24.Receipt()" /> Expenses
                        </NavLink>
                    </div>
                    <div class="nav-item">
                        <NavLink class="nav-link nav-sublink" href="payday/settings">
                            <FluentIcon Value="new Size24.Settings()" /> Connection
                        </NavLink>
                    </div>
                </div>
            }
        }

        @if (isAuthenticated)
        {
            <div class="nav-item px-3">
                <button type="button" class="nav-link nav-link-button" @onclick="ShowLogoutConfirm">
                    <FluentIcon Value="new Size24.SignOut()" /> Logout
                </button>
            </div>
        }
    </nav>
</div>

<style>
    .nav-group-toggle {
        display: flex;
        align-items: center;
        width: 100%;
        gap: 0;
    }

    .nav-chevron {
        margin-left: auto;
        font-size: 1.1rem;
        line-height: 1;
        transition: transform 0.2s ease;
        transform: rotate(0deg);
        display: inline-block;
    }

    .nav-chevron.expanded {
        transform: rotate(90deg);
    }

    .nav-submenu {
        padding-left: 2rem;
        border-left: 2px solid rgba(255,255,255,0.15);
        margin-left: 1.25rem;
        margin-bottom: 0.25rem;
    }

    .nav-sublink {
        font-size: 0.9rem;
        padding-top: 0.3rem;
        padding-bottom: 0.3rem;
    }
</style>

@code {
    [CascadingParameter]
    public MainLayout? Layout { get; set; }

    private bool isAdmin;
    private bool isOwner;
    private bool ownerHasCompany;
    private bool isAuthenticated;
    private bool paydayExpanded;
    private bool ownerExpanded;
    private bool resourcesExpanded;

    protected override void OnInitialized()
    {
        paydayExpanded = IsOnPaydayRoute();
        ownerExpanded = IsOnOwnerRoute();
        resourcesExpanded = IsOnResourcesRoute();
        Navigation.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var session = await AuthSession.GetSessionAsync();
        var nextIsAuthenticated  = session is not null;
        var nextIsAdmin          = session?.Role == WorkitRoles.Admin;
        var nextIsOwner          = session?.Role == WorkitRoles.Owner;
        var nextOwnerHasCompany  = nextIsOwner && session?.CompanyId != Guid.Empty;

        if (nextIsAuthenticated == isAuthenticated &&
            nextIsAdmin         == isAdmin         &&
            nextIsOwner         == isOwner         &&
            nextOwnerHasCompany == ownerHasCompany)
        {
            return;
        }

        isAuthenticated = nextIsAuthenticated;
        isAdmin         = nextIsAdmin;
        isOwner         = nextIsOwner;
        ownerHasCompany = nextOwnerHasCompany;
        StateHasChanged();
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        if (IsOnPaydayRoute())
            paydayExpanded = true;
        if (IsOnOwnerRoute())
            ownerExpanded = true;
        if (IsOnResourcesRoute())
            resourcesExpanded = true;
        InvokeAsync(StateHasChanged);
    }

    private void TogglePayday() => paydayExpanded = !paydayExpanded;
    private void ToggleOwner() => ownerExpanded = !ownerExpanded;
    private void ToggleResources() => resourcesExpanded = !resourcesExpanded;

    private bool IsOnPaydayRoute()
    {
        var path = Navigation.ToBaseRelativePath(Navigation.Uri).TrimStart('/');
        return path.StartsWith("payday", StringComparison.OrdinalIgnoreCase);
    }

    private bool IsOnOwnerRoute()
    {
        var path = Navigation.ToBaseRelativePath(Navigation.Uri).TrimStart('/');
        return path.StartsWith("companies", StringComparison.OrdinalIgnoreCase)
            || path.StartsWith("customers", StringComparison.OrdinalIgnoreCase)
            || path.StartsWith("jobs", StringComparison.OrdinalIgnoreCase)
            || path.StartsWith("employees", StringComparison.OrdinalIgnoreCase)
            || path.StartsWith("timeentries", StringComparison.OrdinalIgnoreCase);
    }

    private bool IsOnResourcesRoute()
    {
        var path = Navigation.ToBaseRelativePath(Navigation.Uri).TrimStart('/');
        return path.StartsWith("calendar", StringComparison.OrdinalIgnoreCase)
            || path.StartsWith("absence", StringComparison.OrdinalIgnoreCase)
            || path.StartsWith("tools", StringComparison.OrdinalIgnoreCase)
            || path.StartsWith("materials", StringComparison.OrdinalIgnoreCase);
    }

    private void ShowLogoutConfirm() => Layout?.ShowLogoutConfirm();

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
