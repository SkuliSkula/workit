@inject AuthSessionService AuthSession
@inject NavigationManager Navigation

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Workit Owner</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        @if (!isAuthenticated)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="login">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Login
                </NavLink>
            </div>
        }

        @if (isAdmin)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="register">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Register
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="admin">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Admin
                </NavLink>
            </div>
        }

        @if (isOwner || isAdmin)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="customers">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Customers
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="employees">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Employees
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="jobs">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Jobs
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="timeentries">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Time Entries
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="payday">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Payday
                </NavLink>
            </div>

            <div class="nav-item px-3" style="padding-left:1.5rem;">
                <NavLink class="nav-link" href="payday/invoices">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Invoices
                </NavLink>
            </div>
        }

        @if (isAuthenticated)
        {
            <div class="nav-item px-3">
                <button type="button" class="nav-link nav-link-button" @onclick="LogoutAsync">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Logout
                </button>
            </div>
        }
    </nav>
</div>

@code {
    private bool isAdmin;
    private bool isOwner;
    private bool isAuthenticated;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var session = await AuthSession.GetSessionAsync();
        var nextIsAuthenticated = session is not null;
        var nextIsAdmin = session?.Role == WorkitRoles.Admin;
        var nextIsOwner = session?.Role == WorkitRoles.Owner;

        if (nextIsAuthenticated == isAuthenticated &&
            nextIsAdmin == isAdmin &&
            nextIsOwner == isOwner)
        {
            return;
        }

        isAuthenticated = nextIsAuthenticated;
        isAdmin = nextIsAdmin;
        isOwner = nextIsOwner;
        StateHasChanged();
    }

    private async Task LogoutAsync()
    {
        await AuthSession.LogoutAsync();
        Navigation.NavigateTo("/", forceLoad: true);
    }
}
