@page "/jobs"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject ICompanyApi CompanyApi
@inject ICustomersApi CustomersApi
@inject IJobsApi JobsApi

<PageTitle>Jobs</PageTitle>

<FluentCard Class="admin-card" AreaRestricted="false">
    <FluentLabel Typo="Typography.PaneHeader">Jobs</FluentLabel>

    @if (company is null)
    {
        <FluentLabel>Set up the company first in Admin before adding jobs.</FluentLabel>
    }
    else
    {
        <div class="admin-grid">
            <div>
                <FluentLabel>Customer</FluentLabel>
                @if (customers.Count > 0)
                {
                    <FluentSelect TValue="string" TOption="string"
                                  @bind-Value="selectedCustomerId"
                                  style="width:100%">
                        @foreach (var customer in customers)
                        {
                            <FluentOption TOption="string" Value="@customer.Id.ToString()">@customer.Name</FluentOption>
                        }
                    </FluentSelect>
                }
                else
                {
                    <FluentLabel>No customers available yet.</FluentLabel>
                }
            </div>

            <div>
                <FluentLabel>Job code</FluentLabel>
                <FluentTextField @bind-Value="newJobCode"
                                 Placeholder="e.g. HA-1"
                                 style="width:100%" />
            </div>

            <div>
                <FluentLabel>Job name</FluentLabel>
                <FluentTextField @bind-Value="newJobName"
                                 Placeholder="e.g. Electrical installation"
                                 style="width:100%" />
            </div>

            <div>
                <FluentLabel>Billing type</FluentLabel>
                <FluentSelect TValue="string" TOption="string"
                              Value="@newBillingType.ToString()"
                              ValueChanged="@(v => newBillingType = Enum.TryParse<BillingType>(v, out var b) ? b : BillingType.Hourly)"
                              style="width:100%">
                    <FluentOption TOption="string" Value="Hourly">Hourly</FluentOption>
                    <FluentOption TOption="string" Value="FixedPrice">Fixed price</FluentOption>
                </FluentSelect>
            </div>

            <FluentButton Appearance="Appearance.Accent" @onclick="CreateJobAsync"
                          Disabled="@(!HasSelectedCustomer)"
                          style="align-self:end;">Add Job</FluentButton>
        </div>
    }

    @if (editingJob is not null)
    {
        <FluentCard Class="admin-card" AreaRestricted="false">
            <FluentLabel Typo="Typography.PaneHeader">Edit Job</FluentLabel>
            <div class="admin-grid">
                <div>
                    <FluentLabel>Customer</FluentLabel>
                    <FluentSelect TValue="string" TOption="string"
                                  @bind-Value="editingCustomerId"
                                  style="width:100%">
                        @foreach (var customer in customers)
                        {
                            <FluentOption TOption="string" Value="@customer.Id.ToString()">@customer.Name</FluentOption>
                        }
                    </FluentSelect>
                </div>

                <div>
                    <FluentLabel>Job code</FluentLabel>
                    <FluentTextField @bind-Value="editingJob.Code"
                                     Placeholder="e.g. HA-1"
                                     style="width:100%" />
                </div>

                <div>
                    <FluentLabel>Job name</FluentLabel>
                    <FluentTextField @bind-Value="editingJob.Name"
                                     Placeholder="e.g. Electrical installation"
                                     style="width:100%" />
                </div>

                <div>
                    <FluentLabel>Billing type</FluentLabel>
                    <FluentSelect TValue="string" TOption="string"
                                  Value="@editingJob.BillingType.ToString()"
                                  ValueChanged="@(v => editingJob.BillingType = Enum.TryParse<BillingType>(v, out var b) ? b : BillingType.Hourly)"
                                  style="width:100%">
                        <FluentOption TOption="string" Value="Hourly">Hourly</FluentOption>
                        <FluentOption TOption="string" Value="FixedPrice">Fixed price</FluentOption>
                    </FluentSelect>
                </div>

                <div style="display:flex; align-items:flex-end; gap:0.5rem;">
                    <FluentButton Appearance="Appearance.Accent" @onclick="SaveJobAsync" Disabled="@(!HasEditingCustomer)">Save Changes</FluentButton>
                    <FluentButton Appearance="Appearance.Outline" @onclick="CancelJobEdit">Cancel</FluentButton>
                </div>
            </div>
        </FluentCard>
    }

    @if (!string.IsNullOrWhiteSpace(loadError))
    {
        <FluentLabel>@loadError</FluentLabel>
    }

    @if (jobs.Count > 0)
    {
        <FluentDataGrid TGridItem="Job" Items="@jobs.AsQueryable()" AutoFit="true" DisplayMode="DataGridDisplayMode.Table">
            <PropertyColumn Property="@(x => x.Code)" Title="Code" />
            <PropertyColumn Property="@(x => x.Name)" Title="Name" />
            <TemplateColumn Title="Customer">
                <FluentLabel>@customerLookup.GetValueOrDefault(context.CustomerId, context.CustomerId.ToString())</FluentLabel>
            </TemplateColumn>
            <TemplateColumn Title="Billing">
                <span style="@BillingBadgeStyle(context.BillingType) padding:2px 10px; border-radius:4px; font-size:0.8rem; font-weight:600;">
                    @(context.BillingType == BillingType.Hourly ? "Hourly" : "Fixed price")
                </span>
            </TemplateColumn>
            <TemplateColumn Title="Actions">
                <FluentButton Appearance="Appearance.Stealth" @onclick="@(() => BeginEditJob(context))">Edit</FluentButton>
            </TemplateColumn>
        </FluentDataGrid>
    }
    else
    {
        <FluentLabel>No jobs yet.</FluentLabel>
    }
</FluentCard>

@code {
    private readonly List<Customer> customers = [];
    private readonly List<Job> jobs = [];
    private readonly Dictionary<Guid, string> customerLookup = new();
    private Company? company;
    private Job? editingJob;
    private string? selectedCustomerId;
    private string? editingCustomerId;
    private string newJobCode = string.Empty;
    private string newJobName = string.Empty;
    private BillingType newBillingType = BillingType.Hourly;
    private string? loadError;

    private static string BillingBadgeStyle(BillingType type) => type == BillingType.Hourly
        ? "background:#e8f4fd; color:#0078d4;"
        : "background:#f0f9f0; color:#107c10;";

    private bool HasSelectedCustomer => Guid.TryParse(selectedCustomerId, out _);
    private bool HasEditingCustomer => Guid.TryParse(editingCustomerId, out _);

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        loadError = null;
        customers.Clear();
        jobs.Clear();
        customerLookup.Clear();
        selectedCustomerId = null;
        var companyResult = await CompanyApi.GetCompanyAsync();
        company = companyResult.Value;

        if (!companyResult.IsSuccess)
        {
            loadError = companyResult.ErrorMessage;
            return;
        }

        if (company is null)
        {
            return;
        }

        var customersResult = await CustomersApi.GetCustomersAsync();
        if (!customersResult.IsSuccess)
        {
            loadError = customersResult.ErrorMessage;
            return;
        }

        customers.AddRange(customersResult.Value ?? []);
        selectedCustomerId = customers.FirstOrDefault()?.Id.ToString();

        foreach (var customer in customers)
        {
            customerLookup[customer.Id] = customer.Name;
        }

        var jobsResult = await JobsApi.GetJobsAsync();
        if (!jobsResult.IsSuccess)
        {
            loadError = jobsResult.ErrorMessage;
            return;
        }

        jobs.AddRange(jobsResult.Value ?? []);
    }

    private async Task CreateJobAsync()
    {
        if (company is null ||
            !Guid.TryParse(selectedCustomerId, out var customerId) ||
            string.IsNullOrWhiteSpace(newJobName))
        {
            return;
        }

        var result = await JobsApi.CreateJobAsync(new Job
        {
            CompanyId   = company.Id,
            CustomerId  = customerId,
            Code        = string.IsNullOrWhiteSpace(newJobCode) ? "JOB" : newJobCode.Trim(),
            Name        = newJobName.Trim(),
            BillingType = newBillingType
        });

        if (result.IsSuccess)
        {
            newJobCode    = string.Empty;
            newJobName    = string.Empty;
            newBillingType = BillingType.Hourly;
            await LoadAsync();
            return;
        }

        loadError = result.ErrorMessage;
    }

    private void BeginEditJob(Job job)
    {
        editingJob = new Job
        {
            Id          = job.Id,
            CompanyId   = job.CompanyId,
            CustomerId  = job.CustomerId,
            Code        = job.Code,
            Name        = job.Name,
            BillingType = job.BillingType
        };
        editingCustomerId = job.CustomerId.ToString();
    }

    private async Task SaveJobAsync()
    {
        if (editingJob is null || !Guid.TryParse(editingCustomerId, out var customerId))
        {
            return;
        }

        editingJob.CustomerId = customerId;

        var result = await JobsApi.UpdateJobAsync(editingJob);
        if (result.IsSuccess)
        {
            editingJob = null;
            editingCustomerId = null;
            await LoadAsync();
            return;
        }

        loadError = result.ErrorMessage;
    }

    private void CancelJobEdit()
    {
        editingJob = null;
        editingCustomerId = null;
    }
}
