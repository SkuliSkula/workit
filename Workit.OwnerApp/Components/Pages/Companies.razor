@page "/companies"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IAuthApi AuthApi
@inject AuthSessionService AuthSession
@inject NavigationManager Navigation

<PageTitle>My Companies</PageTitle>

<FluentCard Class="admin-card" AreaRestricted="false">
    <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:0.5rem;">
        <FluentLabel Typo="Typography.PaneHeader">My Companies</FluentLabel>
        <FluentButton Appearance="Appearance.Accent" @onclick="@(() => Navigation.NavigateTo("/companies/new"))">
            + Add Company
        </FluentButton>
    </div>

    @if (!string.IsNullOrWhiteSpace(loadError))
    {
        <FluentLabel Color="Color.Error" style="margin-top:0.5rem;">@loadError</FluentLabel>
    }
</FluentCard>

@if (isLoading)
{
    <FluentCard Class="admin-card" AreaRestricted="false">
        <div style="display:flex; align-items:center; gap:0.75rem;">
            <FluentProgressRing />
            <FluentLabel>Loading companies…</FluentLabel>
        </div>
    </FluentCard>
}
else if (companies.Count == 0)
{
    <FluentCard Class="admin-card" AreaRestricted="false">
        <FluentLabel style="color:#60758b;">
            You have no companies yet. Click "+ Add Company" to create your first one.
        </FluentLabel>
    </FluentCard>
}
else
{
    <FluentCard Class="admin-card" AreaRestricted="false">
        <div class="company-list">
            @foreach (var c in companies)
            {
                var isCurrent = c.Id == currentCompanyId;
                <div class="company-row @(isCurrent ? "company-row--active" : "")">
                    <div class="company-info">
                        <div style="display:flex; align-items:center; gap:0.5rem;">
                            <strong>@c.Name</strong>
                            @if (isCurrent)
                            {
                                <span style="background:#dcfce7; color:#166534; padding:2px 8px; border-radius:4px; font-size:0.75rem; font-weight:600;">Active</span>
                            }
                        </div>
                        <div style="font-size:0.85rem; color:#60758b; margin-top:0.15rem;">
                            @c.Ssn · @c.Email
                            @if (!string.IsNullOrWhiteSpace(c.Phone))
                            {
                                <span> · @c.Phone</span>
                            }
                        </div>
                        @if (!string.IsNullOrWhiteSpace(c.Address))
                        {
                            <div style="font-size:0.82rem; color:#9ca3af;">@c.Address</div>
                        }
                    </div>
                    <div style="display:flex; gap:0.5rem; align-items:center; flex-shrink:0;">
                        @if (!isCurrent)
                        {
                            <FluentButton Appearance="Appearance.Accent" Size="ButtonSize.Small"
                                          Disabled="@isSwitching"
                                          @onclick="@(() => SwitchToAsync(c.Id))">
                                @(isSwitching && switchingToId == c.Id ? "Switching…" : "Switch to")
                            </FluentButton>
                        }
                    </div>
                </div>
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(switchError))
        {
            <FluentLabel Color="Color.Error" style="margin-top:0.5rem;">@switchError</FluentLabel>
        }
    </FluentCard>
}

<style>
    .company-list {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .company-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.75rem 1rem;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        background: #fff;
    }

    .company-row--active {
        border-color: #4ade80;
        background: #f0fdf4;
    }

    .company-info {
        flex: 1;
        min-width: 0;
    }
</style>

@code {
    private List<Company> companies = [];
    private Guid? currentCompanyId;
    private bool isLoading = true;
    private string? loadError;
    private bool isSwitching;
    private Guid? switchingToId;
    private string? switchError;

    protected override async Task OnInitializedAsync()
    {
        var session = await AuthSession.GetSessionAsync();
        currentCompanyId = session?.CompanyId;

        var result = await AuthApi.GetUserCompaniesAsync();
        if (result.IsSuccess && result.Value is not null)
            companies = result.Value;
        else
            loadError = result.ErrorMessage ?? "Could not load companies.";

        isLoading = false;
    }

    private async Task SwitchToAsync(Guid companyId)
    {
        isSwitching = true;
        switchingToId = companyId;
        switchError = null;

        var result = await AuthSession.SwitchCompanyAsync(companyId);
        if (result.IsSuccess)
        {
            Navigation.NavigateTo("/", forceLoad: true);
        }
        else
        {
            switchError = result.ErrorMessage ?? "Could not switch company.";
            isSwitching = false;
            switchingToId = null;
        }
    }
}
