@page "/customers"
@rendermode InteractiveServer
@inject HttpClient Http

<PageTitle>Customers</PageTitle>

<FluentCard Class="admin-card">
    <FluentLabel Typo="Typography.PaneHeader">Customers</FluentLabel>

    @if (company is null)
    {
        <FluentLabel>Set up the company first in Admin before adding customers.</FluentLabel>
    }
    else
    {
        <div class="admin-grid">
            <FluentTextField @bind-Value="newCustomerName" Placeholder="Customer name" />
            <FluentTextField @bind-Value="newCustomerSsn" Placeholder="SSN" />
            <FluentTextField @bind-Value="newCustomerEmail" Placeholder="Email" />
            <FluentTextField @bind-Value="newCustomerPhone" Placeholder="Phone" />
            <FluentTextField @bind-Value="newCustomerContactPerson" Placeholder="Contact person" />
            <FluentButton Appearance="Appearance.Accent" @onclick="CreateCustomerAsync">Add Customer</FluentButton>
        </div>
    }

    @if (editingCustomer is not null)
    {
        <FluentCard Class="admin-card">
            <FluentLabel Typo="Typography.PaneHeader">Edit Customer</FluentLabel>
            <div class="admin-grid">
                <FluentTextField @bind-Value="editingCustomer.Name" Placeholder="Customer name" />
                <FluentTextField @bind-Value="editingCustomer.Ssn" Placeholder="SSN" />
                <FluentTextField @bind-Value="editingCustomer.Email" Placeholder="Email" />
                <FluentTextField @bind-Value="editingCustomer.Phone" Placeholder="Phone" />
                <FluentTextField @bind-Value="editingCustomer.ContactPerson" Placeholder="Contact person" />
                <FluentButton Appearance="Appearance.Accent" @onclick="SaveCustomerAsync">Save Changes</FluentButton>
                <FluentButton Appearance="Appearance.Outline" @onclick="CancelCustomerEdit">Cancel</FluentButton>
            </div>
        </FluentCard>
    }

    @if (!string.IsNullOrWhiteSpace(loadError))
    {
        <FluentLabel>@loadError</FluentLabel>
    }

    @if (customers.Count > 0)
    {
        <FluentDataGrid TGridItem="Customer" Items="@customers.AsQueryable()" AutoFit="true" DisplayMode="DataGridDisplayMode.Table">
            <PropertyColumn Property="@(x => x.Name)" Title="Name" />
            <PropertyColumn Property="@(x => x.Ssn)" Title="SSN" />
            <PropertyColumn Property="@(x => x.Email)" Title="Email" />
            <PropertyColumn Property="@(x => x.Phone)" Title="Phone" />
            <PropertyColumn Property="@(x => x.ContactPerson)" Title="Contact Person" />
            <TemplateColumn Title="Actions">
                <FluentButton Appearance="Appearance.Stealth" @onclick="@(() => BeginEditCustomer(context))">Edit</FluentButton>
            </TemplateColumn>
        </FluentDataGrid>
    }
    else
    {
        <FluentLabel>No customers yet.</FluentLabel>
    }
</FluentCard>

@code {
    private readonly List<Customer> customers = [];
    private Company? company;
    private Customer? editingCustomer;
    private string newCustomerName = string.Empty;
    private string newCustomerSsn = string.Empty;
    private string newCustomerEmail = string.Empty;
    private string newCustomerPhone = string.Empty;
    private string newCustomerContactPerson = string.Empty;
    private string? loadError;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        loadError = null;
        customers.Clear();

        try
        {
            company = await Http.GetFromJsonAsync<Company?>("api/company");
            if (company is null)
            {
                return;
            }

            var loadedCustomers = await Http.GetFromJsonAsync<List<Customer>>($"api/customers?companyId={company.Id}") ?? [];
            customers.AddRange(loadedCustomers);
        }
        catch (Exception)
        {
            loadError = "Customers could not be loaded right now.";
        }
    }

    private async Task CreateCustomerAsync()
    {
        if (company is null || string.IsNullOrWhiteSpace(newCustomerName))
        {
            return;
        }

        var response = await Http.PostAsJsonAsync("api/customers", new Customer
        {
            CompanyId = company.Id,
            Name = newCustomerName.Trim(),
            Ssn = newCustomerSsn.Trim(),
            Email = newCustomerEmail.Trim(),
            Phone = newCustomerPhone.Trim(),
            ContactPerson = newCustomerContactPerson.Trim()
        });

        if (response.IsSuccessStatusCode)
        {
            newCustomerName = string.Empty;
            newCustomerSsn = string.Empty;
            newCustomerEmail = string.Empty;
            newCustomerPhone = string.Empty;
            newCustomerContactPerson = string.Empty;
            await LoadAsync();
            return;
        }

        loadError = await response.Content.ReadAsStringAsync();
    }

    private void BeginEditCustomer(Customer customer)
    {
        editingCustomer = new Customer
        {
            Id = customer.Id,
            CompanyId = customer.CompanyId,
            Name = customer.Name,
            Ssn = customer.Ssn,
            Email = customer.Email,
            Phone = customer.Phone,
            ContactPerson = customer.ContactPerson
        };
    }

    private async Task SaveCustomerAsync()
    {
        if (editingCustomer is null)
        {
            return;
        }

        var response = await Http.PutAsJsonAsync($"api/customers/{editingCustomer.Id}", editingCustomer);
        if (response.IsSuccessStatusCode)
        {
            editingCustomer = null;
            await LoadAsync();
            return;
        }

        loadError = await response.Content.ReadAsStringAsync();
    }

    private void CancelCustomerEdit()
    {
        editingCustomer = null;
    }
}
