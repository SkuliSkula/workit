@page "/customers"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject ICompanyApi CompanyApi
@inject ICustomersApi CustomersApi

<PageTitle>Customers</PageTitle>

@* ── Header ── *@
<FluentCard Class="admin-card" AreaRestricted="false">
    <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:0.5rem;">
        <FluentLabel Typo="Typography.PaneHeader">Customers</FluentLabel>
        @if (company is not null)
        {
            <FluentButton Appearance="Appearance.Accent" @onclick="ToggleCreateForm">
                @(showCreateForm ? "✕ Cancel" : "+ New")
            </FluentButton>
        }
    </div>

    @if (company is null && !loading)
    {
        <FluentLabel style="margin-top:0.5rem;">Set up the company first in Admin before adding customers.</FluentLabel>
    }

    @if (!string.IsNullOrWhiteSpace(loadError))
    {
        <FluentLabel Color="Color.Error" style="margin-top:0.5rem;">@loadError</FluentLabel>
    }
</FluentCard>

@* ── Create form ── *@
@if (showCreateForm)
{
    <FluentCard Class="admin-card" AreaRestricted="false">
        <FluentLabel Typo="Typography.Body"><strong>New Customer</strong></FluentLabel>
        <div class="admin-grid" style="margin-top:0.75rem;">
            <div>
                <FluentTextField Label="Name *" @bind-Value="newCustomerName" Placeholder="Customer name" style="width:100%" />
            </div>
            <div>
                <FluentTextField Label="SSN" @bind-Value="newCustomerSsn" Placeholder="SSN" style="width:100%" />
            </div>
            <div>
                <FluentTextField Label="Email" @bind-Value="newCustomerEmail" Placeholder="Email" style="width:100%" />
            </div>
            <div>
                <FluentTextField Label="Phone" @bind-Value="newCustomerPhone" Placeholder="Phone" style="width:100%" />
            </div>
            <div>
                <FluentTextField Label="Contact person" @bind-Value="newCustomerContactPerson" Placeholder="Contact person" style="width:100%" />
            </div>
        </div>
        <div style="display:flex; gap:0.5rem; margin-top:0.75rem;">
            <FluentButton Appearance="Appearance.Accent" @onclick="CreateCustomerAsync">Save</FluentButton>
            <FluentButton Appearance="Appearance.Outline" @onclick="ToggleCreateForm">Cancel</FluentButton>
        </div>
    </FluentCard>
}

@* ── Edit form ── *@
@if (editingCustomer is not null)
{
    <FluentCard Class="admin-card" AreaRestricted="false">
        <FluentLabel Typo="Typography.Body"><strong>Edit Customer</strong></FluentLabel>
        <div class="admin-grid" style="margin-top:0.75rem;">
            <div>
                <FluentTextField Label="Name *" @bind-Value="editingCustomer.Name" Placeholder="Customer name" style="width:100%" />
            </div>
            <div>
                <FluentTextField Label="SSN" @bind-Value="editingCustomer.Ssn" Placeholder="SSN" style="width:100%" />
            </div>
            <div>
                <FluentTextField Label="Email" @bind-Value="editingCustomer.Email" Placeholder="Email" style="width:100%" />
            </div>
            <div>
                <FluentTextField Label="Phone" @bind-Value="editingCustomer.Phone" Placeholder="Phone" style="width:100%" />
            </div>
            <div>
                <FluentTextField Label="Contact person" @bind-Value="editingCustomer.ContactPerson" Placeholder="Contact person" style="width:100%" />
            </div>
        </div>
        <div style="display:flex; gap:0.5rem; margin-top:0.75rem;">
            <FluentButton Appearance="Appearance.Accent" @onclick="SaveCustomerAsync">Save Changes</FluentButton>
            <FluentButton Appearance="Appearance.Outline" @onclick="CancelCustomerEdit">Cancel</FluentButton>
        </div>
    </FluentCard>
}

@* ── List ── *@
<div class="cust-panel">
    <div class="cust-panel-header">
        <span class="cust-panel-title">All Customers</span>
        <span class="cust-count">@customers.Count</span>
    </div>

    @if (loading)
    {
        <PageLoader />
    }
    else if (customers.Count > 0)
    {
        <FluentDataGrid TGridItem="Customer" Items="@customers.AsQueryable()" AutoFit="true" DisplayMode="DataGridDisplayMode.Table">
            <PropertyColumn Property="@(x => x.Name)" Title="Name" />
            <PropertyColumn Property="@(x => x.Ssn)" Title="SSN" />
            <PropertyColumn Property="@(x => x.Email)" Title="Email" />
            <PropertyColumn Property="@(x => x.Phone)" Title="Phone" />
            <PropertyColumn Property="@(x => x.ContactPerson)" Title="Contact Person" />
            <TemplateColumn Title="Actions">
                <FluentButton Appearance="Appearance.Stealth" @onclick="@(() => BeginEditCustomer(context))">Edit</FluentButton>
            </TemplateColumn>
        </FluentDataGrid>
    }
    else
    {
        <FluentLabel>No customers yet.</FluentLabel>
    }
</div>

@code {
    private readonly List<Customer> customers = [];
    private Company? company;
    private Customer? editingCustomer;
    private bool loading = true;
    private bool showCreateForm;
    private string newCustomerName = string.Empty;
    private string newCustomerSsn = string.Empty;
    private string newCustomerEmail = string.Empty;
    private string newCustomerPhone = string.Empty;
    private string newCustomerContactPerson = string.Empty;
    private string? loadError;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        loading    = true;
        loadError  = null;
        customers.Clear();
        var companyResult = await CompanyApi.GetCompanyAsync();
        company = companyResult.Value;

        if (!companyResult.IsSuccess)
        {
            loadError = companyResult.ErrorMessage;
            loading = false;
            return;
        }

        if (company is null)
        {
            loading = false;
            return;
        }

        var customersResult = await CustomersApi.GetCustomersAsync();
        if (!customersResult.IsSuccess)
        {
            loadError = customersResult.ErrorMessage;
            loading = false;
            return;
        }

        customers.AddRange(customersResult.Value ?? []);
        loading = false;
    }

    private void ToggleCreateForm()
    {
        showCreateForm = !showCreateForm;
        if (!showCreateForm) ResetCreateForm();
    }

    private void ResetCreateForm()
    {
        newCustomerName = string.Empty;
        newCustomerSsn = string.Empty;
        newCustomerEmail = string.Empty;
        newCustomerPhone = string.Empty;
        newCustomerContactPerson = string.Empty;
    }

    private async Task CreateCustomerAsync()
    {
        if (company is null || string.IsNullOrWhiteSpace(newCustomerName))
        {
            return;
        }

        var result = await CustomersApi.CreateCustomerAsync(new Customer
        {
            CompanyId = company.Id,
            Name = newCustomerName.Trim(),
            Ssn = newCustomerSsn.Trim(),
            Email = newCustomerEmail.Trim(),
            Phone = newCustomerPhone.Trim(),
            ContactPerson = newCustomerContactPerson.Trim()
        });

        if (result.IsSuccess)
        {
            ResetCreateForm();
            showCreateForm = false;
            await LoadAsync();
            return;
        }

        loadError = result.ErrorMessage;
    }

    private void BeginEditCustomer(Customer customer)
    {
        showCreateForm = false;
        editingCustomer = new Customer
        {
            Id = customer.Id,
            CompanyId = customer.CompanyId,
            Name = customer.Name,
            Ssn = customer.Ssn,
            Email = customer.Email,
            Phone = customer.Phone,
            ContactPerson = customer.ContactPerson
        };
    }

    private async Task SaveCustomerAsync()
    {
        if (editingCustomer is null)
        {
            return;
        }

        var result = await CustomersApi.UpdateCustomerAsync(editingCustomer);
        if (result.IsSuccess)
        {
            editingCustomer = null;
            await LoadAsync();
            return;
        }

        loadError = result.ErrorMessage;
    }

    private void CancelCustomerEdit()
    {
        editingCustomer = null;
    }
}
