@page "/customers"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject ICompanyApi CompanyApi
@inject ICustomersApi CustomersApi

<PageTitle>Customers</PageTitle>

<section class="cust-page">

    @* ── Add / Edit Customer form ── *@
    <div class="cust-shell">
        <div class="cust-header">
            <span class="cust-eyebrow">Customer management</span>
            <h1 class="cust-title">@(editingCustomer is not null ? "Edit Customer" : "Customers")</h1>
        </div>

        @if (!string.IsNullOrWhiteSpace(loadError))
        {
            <div class="cust-alert cust-alert--error">@loadError</div>
        }

        @if (company is null && !loading)
        {
            <p class="cust-note">Set up the company first in Admin before adding customers.</p>
        }
        else if (company is not null)
        {
            <div class="cust-form-grid">
                <label class="cust-field">
                    <span class="cust-label">Customer name</span>
                    <input class="cust-input" type="text" @bind="newCustomerName" placeholder="Customer name" />
                </label>
                <label class="cust-field">
                    <span class="cust-label">SSN</span>
                    <input class="cust-input" type="text" @bind="newCustomerSsn" placeholder="SSN" />
                </label>
                <label class="cust-field">
                    <span class="cust-label">Email</span>
                    <input class="cust-input" type="email" @bind="newCustomerEmail" placeholder="Email" />
                </label>
                <label class="cust-field">
                    <span class="cust-label">Phone</span>
                    <input class="cust-input" type="tel" @bind="newCustomerPhone" placeholder="Phone" />
                </label>
                <label class="cust-field">
                    <span class="cust-label">Contact person</span>
                    <input class="cust-input" type="text" @bind="newCustomerContactPerson" placeholder="Contact person" />
                </label>
            </div>
            <div class="cust-form-actions">
                <button class="cust-btn cust-btn--primary" @onclick="CreateCustomerAsync"
                        disabled="@string.IsNullOrWhiteSpace(newCustomerName)">
                    Add Customer
                </button>
            </div>
        }

        @* ── Edit inline form ── *@
        @if (editingCustomer is not null)
        {
            <div class="cust-edit-card">
                <span class="cust-eyebrow" style="margin-bottom:0.5rem; display:block;">Editing customer</span>
                <div class="cust-form-grid">
                    <label class="cust-field">
                        <span class="cust-label">Customer name</span>
                        <input class="cust-input" type="text" @bind="editingCustomer.Name" placeholder="Customer name" />
                    </label>
                    <label class="cust-field">
                        <span class="cust-label">SSN</span>
                        <input class="cust-input" type="text" @bind="editingCustomer.Ssn" placeholder="SSN" />
                    </label>
                    <label class="cust-field">
                        <span class="cust-label">Email</span>
                        <input class="cust-input" type="email" @bind="editingCustomer.Email" placeholder="Email" />
                    </label>
                    <label class="cust-field">
                        <span class="cust-label">Phone</span>
                        <input class="cust-input" type="tel" @bind="editingCustomer.Phone" placeholder="Phone" />
                    </label>
                    <label class="cust-field">
                        <span class="cust-label">Contact person</span>
                        <input class="cust-input" type="text" @bind="editingCustomer.ContactPerson" placeholder="Contact person" />
                    </label>
                </div>
                <div class="cust-form-actions">
                    <button class="cust-btn cust-btn--primary" @onclick="SaveCustomerAsync">Save Changes</button>
                    <button class="cust-btn cust-btn--outline" @onclick="CancelCustomerEdit">Cancel</button>
                </div>
            </div>
        }
    </div>

    @* ── Customer list ── *@
    <div class="cust-shell">
        <div class="cust-header">
            <span class="cust-eyebrow">Customer list</span>
            <h2 class="cust-title">All Customers</h2>
        </div>

        @if (loading)
        {
            <PageLoader />
        }
        else if (customers.Count > 0)
        {
            <div class="cust-table-wrap">
                <table class="cust-table">
                    <thead>
                        <tr>
                            <th class="cust-th">Name</th>
                            <th class="cust-th">SSN</th>
                            <th class="cust-th">Email</th>
                            <th class="cust-th">Phone</th>
                            <th class="cust-th">Contact Person</th>
                            <th class="cust-th"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in customers)
                        {
                            <tr class="cust-tr">
                                <td class="cust-td cust-td--name">@c.Name</td>
                                <td class="cust-td">@c.Ssn</td>
                                <td class="cust-td">@c.Email</td>
                                <td class="cust-td">@c.Phone</td>
                                <td class="cust-td">@c.ContactPerson</td>
                                <td class="cust-td cust-td--actions">
                                    <button class="cust-btn cust-btn--outline cust-btn--sm"
                                            @onclick="@(() => BeginEditCustomer(c))">Edit</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="cust-empty">No customers yet. Add the first one above.</p>
        }
    </div>

</section>

@code {
    private readonly List<Customer> customers = [];
    private Company? company;
    private Customer? editingCustomer;
    private bool loading = true;
    private string newCustomerName = string.Empty;
    private string newCustomerSsn = string.Empty;
    private string newCustomerEmail = string.Empty;
    private string newCustomerPhone = string.Empty;
    private string newCustomerContactPerson = string.Empty;
    private string? loadError;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        loading    = true;
        loadError  = null;
        customers.Clear();
        var companyResult = await CompanyApi.GetCompanyAsync();
        company = companyResult.Value;

        if (!companyResult.IsSuccess)
        {
            loadError = companyResult.ErrorMessage;
            loading = false;
            return;
        }

        if (company is null)
        {
            loading = false;
            return;
        }

        var customersResult = await CustomersApi.GetCustomersAsync();
        if (!customersResult.IsSuccess)
        {
            loadError = customersResult.ErrorMessage;
            loading = false;
            return;
        }

        customers.AddRange(customersResult.Value ?? []);
        loading = false;
    }

    private async Task CreateCustomerAsync()
    {
        if (company is null || string.IsNullOrWhiteSpace(newCustomerName))
        {
            return;
        }

        var result = await CustomersApi.CreateCustomerAsync(new Customer
        {
            CompanyId = company.Id,
            Name = newCustomerName.Trim(),
            Ssn = newCustomerSsn.Trim(),
            Email = newCustomerEmail.Trim(),
            Phone = newCustomerPhone.Trim(),
            ContactPerson = newCustomerContactPerson.Trim()
        });

        if (result.IsSuccess)
        {
            newCustomerName = string.Empty;
            newCustomerSsn = string.Empty;
            newCustomerEmail = string.Empty;
            newCustomerPhone = string.Empty;
            newCustomerContactPerson = string.Empty;
            await LoadAsync();
            return;
        }

        loadError = result.ErrorMessage;
    }

    private void BeginEditCustomer(Customer customer)
    {
        editingCustomer = new Customer
        {
            Id = customer.Id,
            CompanyId = customer.CompanyId,
            Name = customer.Name,
            Ssn = customer.Ssn,
            Email = customer.Email,
            Phone = customer.Phone,
            ContactPerson = customer.ContactPerson
        };
    }

    private async Task SaveCustomerAsync()
    {
        if (editingCustomer is null)
        {
            return;
        }

        var result = await CustomersApi.UpdateCustomerAsync(editingCustomer);
        if (result.IsSuccess)
        {
            editingCustomer = null;
            await LoadAsync();
            return;
        }

        loadError = result.ErrorMessage;
    }

    private void CancelCustomerEdit()
    {
        editingCustomer = null;
    }
}
