@page "/materials"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IMaterialsApi MaterialsApi

<PageTitle>Materials</PageTitle>

<section class="mat-page">

    @* ── Add / Edit form ── *@
    <div class="mat-shell">
        <div class="mat-header">
            <span class="mat-eyebrow">Material management</span>
            <h1 class="mat-title">@(editingMaterial is not null ? "Edit Material" : "Materials")</h1>
        </div>

        @if (!string.IsNullOrWhiteSpace(loadError))
        {
            <div class="mat-alert mat-alert--error">@loadError</div>
        }

        <div class="mat-form-grid">
            <label class="mat-field">
                <span class="mat-label">Name *</span>
                <input class="mat-input" type="text" @bind="formName" placeholder="e.g. N1XE-U 5G 16 Cu 1kV Aflstrengur" />
            </label>

            <label class="mat-field">
                <span class="mat-label">Product code</span>
                <input class="mat-input" type="text" @bind="formCode" placeholder="e.g. N1XECU015G016" />
            </label>

            <label class="mat-field">
                <span class="mat-label">Category *</span>
                <select class="mat-select" @bind="formCategory">
                    @foreach (var cat in Categories)
                    {
                        <option value="@cat">@cat</option>
                    }
                </select>
            </label>

            <label class="mat-field">
                <span class="mat-label">Unit</span>
                <select class="mat-select" @bind="formUnit">
                    @foreach (var u in Units)
                    {
                        <option value="@u">@u</option>
                    }
                </select>
            </label>

            <label class="mat-field">
                <span class="mat-label">Purchase price (ex. VAT)</span>
                <input class="mat-input" type="number" @bind="formPurchasePrice" @bind:after="RecalcSalePrice"
                       min="0" step="0.01" placeholder="What you pay the vendor" />
            </label>

            <label class="mat-field">
                <span class="mat-label">Markup factor</span>
                <input class="mat-input" type="number" @bind="formMarkupFactor" @bind:after="RecalcSalePrice"
                       min="1" step="0.05" placeholder="e.g. 1.5 = 50% markup" />
            </label>

            <label class="mat-field">
                <span class="mat-label">Sale price (ex. VAT)</span>
                <input class="mat-input" type="number" @bind="formUnitPrice" min="0" step="0.01" />
                @if (formPurchasePrice > 0 && formMarkupFactor > 0)
                {
                    <span class="mat-hint">Auto-calc: @((formPurchasePrice * formMarkupFactor).ToString("N0")) kr.</span>
                }
            </label>

            <label class="mat-field">
                <span class="mat-label">VAT rate (%)</span>
                <input class="mat-input" type="number" @bind="formVatRate" min="0" max="100" step="0.5" />
            </label>

            <label class="mat-field">
                <span class="mat-label">Quantity in stock</span>
                <input class="mat-input" type="number" @bind="formQuantity" min="0" step="1"
                       placeholder="e.g. 500 (metres of cable)" />
            </label>

            <label class="mat-field mat-field--wide">
                <span class="mat-label">Description</span>
                <input class="mat-input" type="text" @bind="formDescription" placeholder="Optional notes" />
            </label>
        </div>

        <div class="mat-form-actions">
            @if (editingMaterial is not null)
            {
                <button class="mat-btn mat-btn--primary" @onclick="UpdateMaterialAsync"
                        disabled="@(string.IsNullOrWhiteSpace(formName) || saving)">
                    @(saving ? "Saving…" : "Save changes")
                </button>
                <button class="mat-btn mat-btn--outline" @onclick="CancelEdit">Cancel</button>
            }
            else
            {
                <button class="mat-btn mat-btn--primary" @onclick="CreateMaterialAsync"
                        disabled="@(string.IsNullOrWhiteSpace(formName) || saving)">
                    @(saving ? "Saving…" : "Add material")
                </button>
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(saveResult))
        {
            <div class="mat-alert mat-alert--ok">@saveResult</div>
        }
    </div>

    @* ── Catalog ── *@
    <div class="mat-shell">
        <div class="mat-catalog-header">
            <div class="mat-header">
                <span class="mat-eyebrow">Material catalog</span>
                <h2 class="mat-title">Catalog</h2>
            </div>
            <div class="mat-filter-row">
                <label class="mat-field">
                    <span class="mat-label">Category filter</span>
                    <select class="mat-select mat-select--filter" @bind="filterCategory" @bind:after="ApplyFilter">
                        <option value="">All</option>
                        @foreach (var cat in Categories)
                        {
                            <option value="@cat">@cat</option>
                        }
                    </select>
                </label>
                <span class="mat-count">@filteredMaterials.Count material@(filteredMaterials.Count == 1 ? "" : "s")</span>
            </div>
        </div>

        @if (loading)
        {
            <PageLoader />
        }
        else if (filteredMaterials.Count > 0)
        {
            <div class="mat-table-wrap">
                <table class="mat-table">
                    <thead>
                        <tr>
                            <th class="mat-th">Category</th>
                            <th class="mat-th">Name</th>
                            <th class="mat-th">Code</th>
                            <th class="mat-th">Unit</th>
                            <th class="mat-th mat-right">Purchase</th>
                            <th class="mat-th mat-right">Markup</th>
                            <th class="mat-th mat-right">Sale (ex. VAT)</th>
                            <th class="mat-th mat-right">Price (incl. VAT)</th>
                            <th class="mat-th mat-right">VAT %</th>
                            <th class="mat-th mat-right">In stock</th>
                            <th class="mat-th">Status</th>
                            <th class="mat-th"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in filteredMaterials)
                        {
                            <tr class="mat-tr">
                                <td class="mat-td mat-td--cat">@m.Category</td>
                                <td class="mat-td mat-td--name">@m.Name</td>
                                <td class="mat-td mat-td--dim">@m.ProductCode</td>
                                <td class="mat-td">@m.Unit</td>
                                <td class="mat-td mat-right">@(m.PurchasePrice > 0 ? $"{m.PurchasePrice:N0} kr." : "—")</td>
                                <td class="mat-td mat-right">@(m.MarkupFactor != 1m ? $"{m.MarkupFactor:0.##}×" : "—")</td>
                                <td class="mat-td mat-right">@m.UnitPrice.ToString("N0") kr.</td>
                                <td class="mat-td mat-right">@((m.UnitPrice * (1 + m.VatRate / 100m)).ToString("N0")) kr.</td>
                                <td class="mat-td mat-right">@m.VatRate.ToString("0.#")</td>
                                <td class="mat-td mat-right">
                                    @{
                                        var stockClass = m.Quantity <= 0
                                            ? "mat-stock mat-stock--empty"
                                            : m.Quantity < 10
                                                ? "mat-stock mat-stock--low"
                                                : "mat-stock mat-stock--ok";
                                    }
                                    <span class="@stockClass">@m.Quantity.ToString("0.##") @m.Unit</span>
                                </td>
                                <td class="mat-td">
                                    @if (m.IsActive)
                                    {
                                        <span class="mat-badge mat-badge--green">Active</span>
                                    }
                                    else
                                    {
                                        <span class="mat-badge mat-badge--red">Inactive</span>
                                    }
                                </td>
                                <td class="mat-td mat-td--actions">
                                    <button class="mat-btn mat-btn--outline mat-btn--sm"
                                            @onclick="@(() => BeginEdit(m))">Edit</button>
                                    <button class="mat-btn mat-btn--danger mat-btn--sm"
                                            @onclick="@(() => DeleteMaterialAsync(m))">Delete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="mat-empty">No materials yet. Add the first one above.</p>
        }
    </div>

</section>

@code {
    // ── Static lists ───────────────────────────────────────────────────────────
    private static readonly string[] Categories =
    [
        "Rafstrengir",
        "Lagnaefni",
        "Lagnaleiðir",
        "Töflubúnaður",
        "Stýribúnaður",
        "Fjarskiptabúnaður",
        "Hitabúnaður",
        "Lýsing",
        "Rofa- og tenglaefni",
        "Verkfæri",
        "Tengibúnaður",
        "Veitubúnaður",
        "Hleðsla rafbíla",
        "Dyrasímar",
        "Snjalllausnir",
        "Brunavarnir",
        "Annað"
    ];

    private static readonly string[] Units = ["stk.", "m.", "pk.", "rúll.", "box", "kg", "ltr."];

    // ── State ──────────────────────────────────────────────────────────────────
    private bool loading = true;
    private List<Material> allMaterials     = [];
    private List<Material> filteredMaterials = [];
    private Material?      editingMaterial;

    private string  filterCategory  = string.Empty;
    private string  loadError       = string.Empty;
    private string  saveResult      = string.Empty;
    private bool    saving;

    // ── Form fields ────────────────────────────────────────────────────────────
    private string  formName          = string.Empty;
    private string  formCode          = string.Empty;
    private string  formCategory      = Categories[0];
    private string  formUnit          = "stk.";
    private decimal formPurchasePrice;
    private decimal formMarkupFactor  = 1.5m;
    private decimal formUnitPrice;
    private decimal formVatRate       = 24.0m;
    private decimal formQuantity;
    private string  formDescription   = string.Empty;
    private bool    formIsActive      = true;

    private void RecalcSalePrice()
    {
        if (formPurchasePrice > 0 && formMarkupFactor >= 1m)
            formUnitPrice = Math.Round(formPurchasePrice * formMarkupFactor, 0);
    }

    // ── Lifecycle ──────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        loading = true;
        loadError = string.Empty;
        var result = await MaterialsApi.GetMaterialsAsync();
        if (result.IsSuccess)
        {
            allMaterials = result.Value!;
            ApplyFilter();
        }
        else
        {
            loadError = result.ErrorMessage ?? "Could not load materials.";
        }
        loading = false;
    }

    private void ApplyFilter()
    {
        filteredMaterials = string.IsNullOrWhiteSpace(filterCategory)
            ? [.. allMaterials]
            : [.. allMaterials.Where(m => m.Category == filterCategory)];
    }

    // ── CRUD ───────────────────────────────────────────────────────────────────
    private async Task CreateMaterialAsync()
    {
        saving     = true;
        saveResult = string.Empty;

        var material = new Material
        {
            Name          = formName,
            ProductCode   = formCode,
            Category      = formCategory,
            Unit          = formUnit,
            PurchasePrice = formPurchasePrice,
            MarkupFactor  = formMarkupFactor,
            UnitPrice     = formUnitPrice,
            VatRate       = formVatRate,
            Quantity      = formQuantity,
            Description   = formDescription,
            IsActive      = true
        };

        var result = await MaterialsApi.CreateMaterialAsync(material);
        if (result.IsSuccess)
        {
            saveResult = $"✓ {result.Value!.Name} added to catalog.";
            ResetForm();
            await LoadAsync();
        }
        else
        {
            saveResult = result.ErrorMessage ?? "Could not save material.";
        }

        saving = false;
    }

    private void BeginEdit(Material m)
    {
        editingMaterial   = m;
        formName          = m.Name;
        formCode          = m.ProductCode;
        formCategory      = m.Category;
        formUnit          = m.Unit;
        formPurchasePrice = m.PurchasePrice;
        formMarkupFactor  = m.MarkupFactor > 0 ? m.MarkupFactor : 1.5m;
        formUnitPrice     = m.UnitPrice;
        formVatRate       = m.VatRate;
        formQuantity      = m.Quantity;
        formDescription   = m.Description;
        formIsActive      = m.IsActive;
        saveResult        = string.Empty;
    }

    private async Task UpdateMaterialAsync()
    {
        if (editingMaterial is null) return;
        saving     = true;
        saveResult = string.Empty;

        var updated = new Material
        {
            Id            = editingMaterial.Id,
            CompanyId     = editingMaterial.CompanyId,
            CreatedAt     = editingMaterial.CreatedAt,
            Name          = formName,
            ProductCode   = formCode,
            Category      = formCategory,
            Unit          = formUnit,
            PurchasePrice = formPurchasePrice,
            MarkupFactor  = formMarkupFactor,
            UnitPrice     = formUnitPrice,
            VatRate       = formVatRate,
            Quantity      = formQuantity,
            Description   = formDescription,
            IsActive      = formIsActive
        };

        var result = await MaterialsApi.UpdateMaterialAsync(updated.Id, updated);
        if (result.IsSuccess)
        {
            saveResult = $"✓ {result.Value!.Name} updated.";
            editingMaterial = null;
            ResetForm();
            await LoadAsync();
        }
        else
        {
            saveResult = result.ErrorMessage ?? "Could not update material.";
        }

        saving = false;
    }

    private async Task DeleteMaterialAsync(Material m)
    {
        saveResult = string.Empty;
        var result = await MaterialsApi.DeleteMaterialAsync(m.Id);
        if (result.IsSuccess)
        {
            saveResult = $"✓ {m.Name} removed.";
            await LoadAsync();
        }
        else
        {
            saveResult = result.ErrorMessage ?? "Could not delete material.";
        }
    }

    private void CancelEdit()
    {
        editingMaterial = null;
        ResetForm();
    }

    private void ResetForm()
    {
        formName          = string.Empty;
        formCode          = string.Empty;
        formCategory      = Categories[0];
        formUnit          = "stk.";
        formPurchasePrice = 0m;
        formMarkupFactor  = 1.5m;
        formUnitPrice     = 0m;
        formVatRate       = 24.0m;
        formQuantity      = 0m;
        formDescription   = string.Empty;
        formIsActive      = true;
    }
}
