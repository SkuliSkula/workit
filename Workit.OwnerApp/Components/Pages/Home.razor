@page "/"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AuthSessionService AuthSession
@inject NavigationManager Navigation
@inject ICompanyApi CompanyApi
@inject ICustomersApi CustomersApi
@inject IEmployeesApi EmployeesApi
@inject IJobsApi JobsApi
@inject ITimeEntriesApi TimeEntriesApi
@inject IAuthApi AuthApi

<PageTitle>Home</PageTitle>

@if (adminNeedsCompany)
{
    <FluentCard Class="dashboard-shell">
        <FluentLabel Typo="Typography.PaneHeader">Welcome, Admin</FluentLabel>
        <p>Select a company to view its dashboard, or go to the Admin page to register a new one.</p>
        <div class="dashboard-actions" style="margin-bottom:1rem;">
            <FluentButton Appearance="Appearance.Accent" @onclick="@(() => Navigation.NavigateTo("/admin"))">Manage Companies</FluentButton>
            <FluentButton Appearance="Appearance.Stealth" @onclick="LogoutAsync">Logout</FluentButton>
        </div>

        @if (userCompanies.Count > 0)
        {
            <FluentLabel Typo="Typography.Body" Style="font-weight:700; margin-bottom:0.5rem;">Enter a company:</FluentLabel>
            <div style="display:grid; gap:0.5rem; max-width:500px;">
                @foreach (var c in userCompanies)
                {
                    <button type="button" class="switch-company-item" @onclick="@(() => SwitchToCompanyAsync(c.Id))">
                        <div class="switch-company-info">
                            <span class="switch-company-name">@c.Name</span>
                            <span class="switch-company-detail">@c.Ssn · @c.Email</span>
                        </div>
                    </button>
                }
            </div>
        }
        else
        {
            <p style="color:#60758b;">No companies registered yet. Go to Admin to create one.</p>
        }
    </FluentCard>
}
else if (!string.IsNullOrWhiteSpace(loadError))
{
    <FluentCard Class="dashboard-shell">
        <FluentLabel Typo="Typography.PaneHeader">Dashboard unavailable</FluentLabel>
        <p>@loadError</p>
        <div class="dashboard-actions">
            <FluentButton Appearance="Appearance.Accent" @onclick="RetryOrLoginAsync">Retry</FluentButton>
            <FluentButton Appearance="Appearance.Stealth" @onclick="@(() => Navigation.NavigateTo("/login"))">Login</FluentButton>
        </div>
    </FluentCard>
}
else if (isLoading)
{
    <FluentCard Class="dashboard-shell">
        <FluentLabel Typo="Typography.PaneHeader">Loading monthly dashboard...</FluentLabel>
    </FluentCard>
}
else if (!isOwnerSession)
{
    <FluentCard Class="dashboard-shell">
        <FluentLabel Typo="Typography.PaneHeader">Access restricted</FluentLabel>
        <p>The monthly dashboard is available for owner accounts.</p>
        <div class="dashboard-actions">
            <FluentButton Appearance="Appearance.Stealth" @onclick="LogoutAsync">Logout</FluentButton>
        </div>
    </FluentCard>
}
else
{
    <section class="dashboard">
        @if (isAdminSession)
        {
            <FluentCard Class="dashboard-shell" Style="background:#eff6ff; border:1px solid #93c5fd;">
                <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:0.5rem;">
                    <FluentLabel Style="font-weight:700; color:#1e40af;">
                        <FluentIcon Value="new Size24.Shield()" Style="vertical-align:middle;" /> Admin viewing: @(company?.Name ?? "Unknown")
                    </FluentLabel>
                    <div style="display:flex; gap:0.5rem;">
                        <FluentButton Appearance="Appearance.Accent" Size="ButtonSize.Small" @onclick="@(() => Navigation.NavigateTo("/admin"))">Manage Companies</FluentButton>
                        <FluentButton Appearance="Appearance.Accent" Size="ButtonSize.Small" @onclick="OpenSwitchCompanyDialog">Switch Company</FluentButton>
                    </div>
                </div>
            </FluentCard>
        }
        <FluentCard Class="dashboard-shell dashboard-hero">
            <div class="hero-copy">
                <span class="eyebrow">Monthly view</span>
                <h1>@(company?.Name ?? "Owner Dashboard")</h1>
                <p>
                    Review labor this month with fast rollups by customer, job, and employee.
                    The most useful default is a ranked operations board: total hours at the top, then who consumed the hours underneath.
                </p>
            </div>

            <div class="hero-controls">
                <div class="month-toolbar">
                    <FluentButton Appearance="Appearance.Stealth" @onclick="PreviousMonthAsync">Previous</FluentButton>
                    <input class="month-picker" type="month" value="@selectedMonthValue" @onchange="OnMonthChangedAsync" />
                    <FluentButton Appearance="Appearance.Stealth" @onclick="NextMonthAsync">Next</FluentButton>
                </div>

                <div class="hero-meta">
                    <div>
                        <span class="meta-label">Period</span>
                        <strong>@monthTitle</strong>
                    </div>
                    <div>
                        <span class="meta-label">Worked days</span>
                        <strong>@dailyLoads.Count(x => x.Hours > 0m)</strong>
                    </div>
                    <div>
                        <span class="meta-label">Entries</span>
                        <strong>@timeEntries.Count</strong>
                    </div>
                </div>

                <div class="dashboard-actions">
                    @if (userCompanies.Count > 1)
                    {
                        <FluentButton Appearance="Appearance.Accent" @onclick="OpenSwitchCompanyDialog">
                            <FluentIcon Value="new Size24.ArrowSwap()" /> Switch Company
                        </FluentButton>
                    }
                    <FluentButton Appearance="Appearance.Accent" @onclick="@(() => Navigation.NavigateTo("/jobs"))">Manage Jobs</FluentButton>
                    <FluentButton Appearance="Appearance.Accent" @onclick="@(() => Navigation.NavigateTo("/employees"))">Manage Employees</FluentButton>
                    <FluentButton Appearance="Appearance.Stealth" @onclick="LogoutAsync">Logout</FluentButton>
                </div>
            </div>
        </FluentCard>

        <section class="dashboard-kpis">
            <FluentCard Class="kpi-card">
                <span class="kpi-label">Total Hours</span>
                <strong>@totalHours.ToString("0.##")</strong>
                <span class="kpi-foot">@averageHoursPerWorkedDay.ToString("0.##") avg per worked day</span>
            </FluentCard>

            <FluentCard Class="kpi-card kpi-card--overtime">
                <span class="kpi-label">Overtime Hours</span>
                <strong>@totalOvertimeHours.ToString("0.##")</strong>
                <span class="kpi-foot">@overtimeRatioLabel of total hours</span>
            </FluentCard>

            <FluentCard Class="kpi-card">
                <span class="kpi-label">Customers Active</span>
                <strong>@customerSummaries.Count</strong>
                <span class="kpi-foot">@TopName(customerSummaries, "No customer activity")</span>
            </FluentCard>

            <FluentCard Class="kpi-card">
                <span class="kpi-label">Jobs Running</span>
                <strong>@jobSummaries.Count</strong>
                <span class="kpi-foot">@TopName(jobSummaries, "No jobs logged")</span>
            </FluentCard>

            <FluentCard Class="kpi-card">
                <span class="kpi-label">Employees Logged</span>
                <strong>@employeeSummaries.Count</strong>
                <span class="kpi-foot">@TopName(employeeSummaries, "No employee activity")</span>
            </FluentCard>
        </section>

        <FluentCard Class="dashboard-shell">
            <div class="section-head">
                <div>
                    <span class="eyebrow">Drill down</span>
                    <h2>Filter the month</h2>
                </div>
                @if (HasActiveFilters)
                {
                    <FluentButton Appearance="Appearance.Stealth" @onclick="ClearFilters">Clear filters</FluentButton>
                }
            </div>

            <div class="filter-grid">
                <label class="filter-field">
                    <span>Customer</span>
                    <select class="filter-select" value="@selectedCustomerId" @onchange="OnCustomerFilterChanged">
                        <option value="">All customers</option>
                        @foreach (var customer in AvailableCustomers)
                        {
                            <option value="@customer.Id">@customer.Name</option>
                        }
                    </select>
                </label>

                <label class="filter-field">
                    <span>Job</span>
                    <select class="filter-select" value="@selectedJobId" @onchange="OnJobFilterChanged">
                        <option value="">All jobs</option>
                        @foreach (var job in AvailableJobs)
                        {
                            <option value="@job.Id">@job.Code - @job.Name</option>
                        }
                    </select>
                </label>

                <label class="filter-field">
                    <span>Employee</span>
                    <select class="filter-select" value="@selectedEmployeeId" @onchange="OnEmployeeFilterChanged">
                        <option value="">All employees</option>
                        @foreach (var employee in AvailableEmployees)
                        {
                            <option value="@employee.Id">@employee.DisplayName</option>
                        }
                    </select>
                </label>
            </div>

            @if (HasActiveFilters)
            {
                <div class="active-filters">
                    @if (SelectedCustomer is not null)
                    {
                        <button type="button" class="filter-chip" @onclick="@(() => ToggleCustomerFilter(null))">
                            Customer: @SelectedCustomer.Name
                        </button>
                    }
                    @if (SelectedJob is not null)
                    {
                        <button type="button" class="filter-chip" @onclick="@(() => ToggleJobFilter(null))">
                            Job: @SelectedJob.Code - @SelectedJob.Name
                        </button>
                    }
                    @if (SelectedEmployee is not null)
                    {
                        <button type="button" class="filter-chip" @onclick="@(() => ToggleEmployeeFilter(null))">
                            Employee: @SelectedEmployee.DisplayName
                        </button>
                    }
                </div>
            }
        </FluentCard>

        <FluentCard Class="dashboard-shell">
            <div class="section-head">
                <div>
                    <span class="eyebrow">Daily load</span>
                    <h2>Hours across @monthTitle</h2>
                </div>
                <p class="section-note">A quick monthly scan to spot thin days, spikes, and uneven staffing.</p>
            </div>

            <div class="day-strip">
                @foreach (var day in dailyLoads)
                {
                    <div class="day-cell @(day.Hours > 0m ? "day-cell--active" : "day-cell--empty")">
                        <span class="day-number">@day.Day</span>
                        <span class="day-hours">@(day.Hours > 0m ? day.Hours.ToString("0.#") : "–")</span>
                    </div>
                }
            </div>
        </FluentCard>

        <section class="dashboard-panels">
            <FluentCard Class="dashboard-shell">
                <div class="section-head">
                    <div>
                        <span class="eyebrow">By customer</span>
                        <h2>Customer load</h2>
                    </div>
                </div>
                @if (customerSummaries.Count == 0)
                {
                    <p>No customer hours were logged this month.</p>
                }
                else
                {
                    @foreach (var item in customerSummaries.Take(6))
                    {
                        <button type="button" class="summary-row summary-button @(IsSelectedCustomer(item.Id) ? "is-selected" : string.Empty)" @onclick="@(() => ToggleCustomerFilter(item.Id))">
                            <div class="summary-copy">
                                <strong>@item.Name</strong>
                                <span>@item.EntryCount entries</span>
                            </div>
                            <div class="summary-bar-wrap">
                                <div class="summary-bar" style="@($"width:{item.WidthPercent:0.##}%")"></div>
                            </div>
                            <div class="summary-value">@item.Hours.ToString("0.##") h</div>
                        </button>
                    }
                }
            </FluentCard>

            <FluentCard Class="dashboard-shell">
                <div class="section-head">
                    <div>
                        <span class="eyebrow">By job</span>
                        <h2>Job load</h2>
                    </div>
                </div>
                @if (jobSummaries.Count == 0)
                {
                    <p>No job hours were logged this month.</p>
                }
                else
                {
                    @foreach (var item in jobSummaries.Take(8))
                    {
                        <button type="button" class="summary-row summary-button @(IsSelectedJob(item.Id) ? "is-selected" : string.Empty)" @onclick="@(() => ToggleJobFilter(item.Id))">
                            <div class="summary-copy">
                                <strong>@item.Name</strong>
                                <span>@item.EntryCount entries</span>
                            </div>
                            <div class="summary-bar-wrap">
                                <div class="summary-bar coral" style="@($"width:{item.WidthPercent:0.##}%")"></div>
                            </div>
                            <div class="summary-value">@item.Hours.ToString("0.##") h</div>
                        </button>
                    }
                }
            </FluentCard>

            <FluentCard Class="dashboard-shell">
                <div class="section-head">
                    <div>
                        <span class="eyebrow">By employee</span>
                        <h2>Team load</h2>
                    </div>
                </div>
                @if (employeeSummaries.Count == 0)
                {
                    <p>No employee hours were logged this month.</p>
                }
                else
                {
                    @foreach (var item in employeeSummaries.Take(8))
                    {
                        <button type="button" class="summary-row summary-button @(IsSelectedEmployee(item.Id) ? "is-selected" : string.Empty)" @onclick="@(() => ToggleEmployeeFilter(item.Id))">
                            <div class="summary-copy">
                                <strong>@item.Name</strong>
                                <span>@item.EntryCount entries</span>
                            </div>
                            <div class="summary-bar-wrap">
                                <div class="summary-bar gold" style="@($"width:{item.WidthPercent:0.##}%")"></div>
                            </div>
                            <div class="summary-value">@item.Hours.ToString("0.##") h</div>
                        </button>
                    }
                }
            </FluentCard>
        </section>

        <FluentCard Class="dashboard-shell">
            <div class="section-head">
                <div>
                    <span class="eyebrow">Latest entries</span>
                    <h2>Recent activity</h2>
                </div>
                <p class="section-note">Most recent submissions inside the selected month.</p>
            </div>

            @if (recentEntries.Count == 0)
            {
                <p>No hours have been logged for this month yet.</p>
            }
            else
            {
                <div class="entry-table">
                    <div class="entry-table-head">Date</div>
                    <div class="entry-table-head">Employee</div>
                    <div class="entry-table-head">Job</div>
                    <div class="entry-table-head">Customer</div>
                    <div class="entry-table-head right">Hours</div>

                    @foreach (var entry in recentEntries)
                    {
                        <div>@entry.WorkDate.ToString("yyyy-MM-dd")</div>
                        <div>@entry.EmployeeName</div>
                        <div>@entry.JobName</div>
                        <div>@entry.CustomerName</div>
                        <div class="right">@entry.Hours.ToString("0.##")</div>
                    }
                </div>
            }
        </FluentCard>
    </section>
}

@* ── Switch Company Dialog ── *@
@if (showSwitchDialog)
{
    <div class="switch-overlay" @onclick="CloseSwitchCompanyDialog">
        <div class="switch-dialog" @onclick:stopPropagation="true">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem;">
                <h3 style="margin:0; color:#14304b;">Switch Company</h3>
                <FluentButton Appearance="Appearance.Stealth" @onclick="CloseSwitchCompanyDialog">✕</FluentButton>
            </div>

            @if (!string.IsNullOrWhiteSpace(switchError))
            {
                <div style="color:#dc2626; font-size:0.85rem; margin-bottom:0.75rem;">@switchError</div>
            }

            <div class="switch-company-list">
                @foreach (var c in userCompanies)
                {
                    var isCurrent = c.Id == session?.CompanyId;
                    <button type="button"
                            class="switch-company-item @(isCurrent ? "switch-company-item--current" : "")"
                            disabled="@(isCurrent || isSwitching)"
                            @onclick="@(() => SwitchToCompanyAsync(c.Id))">
                        <div class="switch-company-info">
                            <span class="switch-company-name">@c.Name</span>
                            <span class="switch-company-detail">@c.Ssn · @c.Email</span>
                        </div>
                        @if (isCurrent)
                        {
                            <span class="switch-company-badge">Current</span>
                        }
                        else if (isSwitching && switchingToCompanyId == c.Id)
                        {
                            <span class="switch-company-badge switch-company-badge--loading">Switching…</span>
                        }
                    </button>
                }
            </div>

            <div style="margin-top:1rem; padding-top:0.75rem; border-top:1px solid #e5e7eb;">
                <FluentButton Appearance="Appearance.Accent" @onclick="NavigateToCreateCompany" Style="width:100%;">
                    <FluentIcon Value="new Size24.Add()" /> Add New Company
                </FluentButton>
            </div>
        </div>
    </div>
}

@code {
    private LoginResponse? session;
    private Company? company;
    private bool isLoading = true;
    private string? loadError;

    // Admin / switch company state
    private bool adminNeedsCompany;
    private List<Company> userCompanies = [];
    private bool showSwitchDialog;
    private bool isSwitching;
    private Guid? switchingToCompanyId;
    private string? switchError;
    private DateOnly selectedMonth = DateOnly.FromDateTime(DateTime.Today);
    private List<Customer> customers = [];
    private List<Employee> employees = [];
    private List<Job> jobs = [];
    private List<TimeEntry> timeEntries = [];
    private List<AggregateRow> customerSummaries = [];
    private List<AggregateRow> jobSummaries = [];
    private List<AggregateRow> employeeSummaries = [];
    private List<DayLoad> dailyLoads = [];
    private List<RecentEntryRow> recentEntries = [];
    private decimal totalHours;
    private decimal totalOvertimeHours;
    private decimal averageHoursPerWorkedDay;

    private string overtimeRatioLabel => totalHours == 0m
        ? "no hours logged"
        : $"{(totalOvertimeHours / totalHours * 100m):0.#}%";
    private Guid? selectedCustomerId;
    private Guid? selectedJobId;
    private Guid? selectedEmployeeId;

    private bool isOwnerSession => string.Equals(session?.Role, WorkitRoles.Owner, StringComparison.Ordinal)
                                  || string.Equals(session?.Role, WorkitRoles.Admin, StringComparison.Ordinal);
    private bool isAdminSession => string.Equals(session?.Role, WorkitRoles.Admin, StringComparison.Ordinal);
    private string selectedMonthValue => $"{selectedMonth.Year:D4}-{selectedMonth.Month:D2}";
    private string monthTitle => selectedMonth.ToDateTime(TimeOnly.MinValue).ToString("MMMM yyyy");
    private bool HasActiveFilters => selectedCustomerId is not null || selectedJobId is not null || selectedEmployeeId is not null;
    private Customer? SelectedCustomer => customers.FirstOrDefault(x => x.Id == selectedCustomerId);
    private Job? SelectedJob => jobs.FirstOrDefault(x => x.Id == selectedJobId);
    private Employee? SelectedEmployee => employees.FirstOrDefault(x => x.Id == selectedEmployeeId);
    private IReadOnlyList<Customer> AvailableCustomers => customers
        .Where(x => timeEntries.Any(entry => JobMatchesCustomer(entry.JobId, x.Id) && EntryMatchesSelectedJobAndEmployee(entry)))
        .OrderBy(x => x.Name)
        .ToList();
    private IReadOnlyList<Job> AvailableJobs => jobs
        .Where(x => EntryMatchesSelectedCustomerForJob(x) && timeEntries.Any(entry => entry.JobId == x.Id && EntryMatchesSelectedEmployee(entry)))
        .OrderBy(x => x.Code)
        .ThenBy(x => x.Name)
        .ToList();
    private IReadOnlyList<Employee> AvailableEmployees => employees
        .Where(x => timeEntries.Any(entry => entry.EmployeeId == x.Id && EntryMatchesSelectedCustomerAndJob(entry)))
        .OrderBy(x => x.DisplayName)
        .ToList();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await LoadDashboardAsync();
        StateHasChanged();
    }

    private async Task LoadDashboardAsync()
    {
        isLoading = true;
        loadError = null;

        try
        {
            session = await AuthSession.GetSessionAsync();
            if (session is null)
            {
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }

            if (!isOwnerSession)
            {
                ResetDashboard();
                return;
            }

            // Admin without a real company — show pick-company landing
            if (isAdminSession)
            {
                var adminCompaniesResult = await AuthApi.GetUserCompaniesAsync();
                userCompanies = adminCompaniesResult.IsSuccess && adminCompaniesResult.Value is not null
                    ? adminCompaniesResult.Value
                    : [];
            }

            var companyResult = await CompanyApi.GetCompanyAsync();
            if (!companyResult.IsSuccess || companyResult.Value is null)
            {
                if (isAdminSession)
                {
                    // Admin hasn't entered a company yet — show landing instead of error
                    adminNeedsCompany = true;
                    ResetDashboard();
                    return;
                }

                if (IsUnauthorized(companyResult.ErrorMessage))
                {
                    await AuthSession.LogoutAsync();
                    Navigation.NavigateTo("/login", forceLoad: true);
                    return;
                }

                loadError = companyResult.ErrorMessage ?? "The company profile could not be loaded right now.";
                ResetDashboard();
                return;
            }

            company = companyResult.Value;

            // Load all companies this user has access to
            var companiesResult = await AuthApi.GetUserCompaniesAsync();
            userCompanies = companiesResult.IsSuccess && companiesResult.Value is not null
                ? companiesResult.Value
                : [company];

            var customersResult = await CustomersApi.GetCustomersAsync();
            var employeesResult = await EmployeesApi.GetEmployeesAsync();
            var jobsResult = await JobsApi.GetJobsAsync();
            var timeEntriesResult = await TimeEntriesApi.GetTimeEntriesAsync(GetMonthStart(), GetMonthEnd());

            if (!customersResult.IsSuccess || !employeesResult.IsSuccess || !jobsResult.IsSuccess || !timeEntriesResult.IsSuccess)
            {
                var firstError = customersResult.ErrorMessage
                    ?? employeesResult.ErrorMessage
                    ?? jobsResult.ErrorMessage
                    ?? timeEntriesResult.ErrorMessage
                    ?? "Dashboard data could not be loaded.";

                if (IsUnauthorized(firstError))
                {
                    await AuthSession.LogoutAsync();
                    Navigation.NavigateTo("/login", forceLoad: true);
                    return;
                }

                loadError = firstError;
                ResetDashboard();
                return;
            }

            customers = customersResult.Value ?? [];
            employees = employeesResult.Value ?? [];
            jobs = jobsResult.Value ?? [];
            timeEntries = timeEntriesResult.Value ?? [];

            BuildDashboard();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task RetryOrLoginAsync()
    {
        await LoadDashboardAsync();
        StateHasChanged();
    }

    private async Task PreviousMonthAsync()
    {
        selectedMonth = selectedMonth.AddMonths(-1);
        await LoadDashboardAsync();
    }

    private async Task NextMonthAsync()
    {
        selectedMonth = selectedMonth.AddMonths(1);
        await LoadDashboardAsync();
    }

    private async Task OnMonthChangedAsync(ChangeEventArgs args)
    {
        var rawValue = args.Value?.ToString();
        if (string.IsNullOrWhiteSpace(rawValue))
        {
            return;
        }

        if (DateOnly.TryParse($"{rawValue}-01", out var month))
        {
            selectedMonth = month;
            await LoadDashboardAsync();
        }
    }

    private void OnCustomerFilterChanged(ChangeEventArgs args)
    {
        ApplyCustomerFilter(ParseGuid(args.Value?.ToString()));
    }

    private void OnJobFilterChanged(ChangeEventArgs args)
    {
        ApplyJobFilter(ParseGuid(args.Value?.ToString()));
    }

    private void OnEmployeeFilterChanged(ChangeEventArgs args)
    {
        ApplyEmployeeFilter(ParseGuid(args.Value?.ToString()));
    }

    private void BuildDashboard()
    {
        var employeeNames = employees.ToDictionary(x => x.Id, x => x.DisplayName);
        var jobNames = jobs.ToDictionary(x => x.Id, x => $"{x.Code} - {x.Name}");
        var customerNames = customers.ToDictionary(x => x.Id, x => x.Name);
        var jobToCustomer = jobs.ToDictionary(x => x.Id, x => x.CustomerId);
        NormalizeFilters(jobToCustomer);
        var filteredEntries = GetFilteredEntries(jobToCustomer);

        totalHours = filteredEntries.Sum(x => x.Hours);
        totalOvertimeHours = filteredEntries.Sum(x => x.OvertimeHours);
        var workedDays = filteredEntries.Select(x => x.WorkDate).Distinct().Count();
        averageHoursPerWorkedDay = workedDays == 0 ? 0m : totalHours / workedDays;

        var customerSeeds = filteredEntries
            .Where(x => jobToCustomer.ContainsKey(x.JobId))
            .GroupBy(x => jobToCustomer[x.JobId])
            .Select(group => new AggregateSeed(
                group.Key,
                customerNames.GetValueOrDefault(group.Key, "Unknown customer"),
                group.Sum(x => x.Hours),
                group.Count()))
            .OrderByDescending(x => x.Hours)
            .ThenBy(x => x.Name)
            .ToList();

        customerSummaries = ToAggregateRows(customerSeeds);

        var jobSeeds = filteredEntries
            .GroupBy(x => x.JobId)
            .Select(group => new AggregateSeed(
                group.Key,
                jobNames.GetValueOrDefault(group.Key, "Unknown job"),
                group.Sum(x => x.Hours),
                group.Count()))
            .OrderByDescending(x => x.Hours)
            .ThenBy(x => x.Name)
            .ToList();

        jobSummaries = ToAggregateRows(jobSeeds);

        var employeeSeeds = filteredEntries
            .GroupBy(x => x.EmployeeId)
            .Select(group => new AggregateSeed(
                group.Key,
                employeeNames.GetValueOrDefault(group.Key, "Unknown employee"),
                group.Sum(x => x.Hours),
                group.Count()))
            .OrderByDescending(x => x.Hours)
            .ThenBy(x => x.Name)
            .ToList();

        employeeSummaries = ToAggregateRows(employeeSeeds);

        recentEntries = filteredEntries
            .OrderByDescending(x => x.WorkDate)
            .ThenByDescending(x => x.Hours)
            .Take(10)
            .Select(entry =>
            {
                var customerId = jobToCustomer.GetValueOrDefault(entry.JobId);
                return new RecentEntryRow(
                    entry.WorkDate,
                    employeeNames.GetValueOrDefault(entry.EmployeeId, "Unknown employee"),
                    jobNames.GetValueOrDefault(entry.JobId, "Unknown job"),
                    customerNames.GetValueOrDefault(customerId, "Unknown customer"),
                    entry.Hours);
            })
            .ToList();

        var monthStart = GetMonthStart();
        var monthEnd = GetMonthEnd();
        var dailyTotals = filteredEntries
            .GroupBy(x => x.WorkDate)
            .ToDictionary(group => group.Key, group => group.Sum(x => x.Hours));
        dailyLoads = Enumerable.Range(0, monthEnd.DayNumber - monthStart.DayNumber + 1)
            .Select(offset =>
            {
                var day = monthStart.AddDays(offset);
                var hours = dailyTotals.GetValueOrDefault(day);
                return new DayLoad(day.Day, hours);
            })
            .ToList();
    }

    private void ResetDashboard()
    {
        company = null;
        customers = [];
        employees = [];
        jobs = [];
        timeEntries = [];
        selectedCustomerId = null;
        selectedJobId = null;
        selectedEmployeeId = null;
        customerSummaries = [];
        jobSummaries = [];
        employeeSummaries = [];
        dailyLoads = [];
        recentEntries = [];
        totalHours = 0m;
        totalOvertimeHours = 0m;
        averageHoursPerWorkedDay = 0m;
    }

    private List<TimeEntry> GetFilteredEntries(IReadOnlyDictionary<Guid, Guid> jobToCustomer) =>
        timeEntries
            .Where(entry =>
                (selectedEmployeeId is null || entry.EmployeeId == selectedEmployeeId) &&
                (selectedJobId is null || entry.JobId == selectedJobId) &&
                (selectedCustomerId is null || (jobToCustomer.TryGetValue(entry.JobId, out var customerId) && customerId == selectedCustomerId)))
            .ToList();

    private void NormalizeFilters(IReadOnlyDictionary<Guid, Guid> jobToCustomer)
    {
        if (selectedJobId is not null && !jobs.Any(x => x.Id == selectedJobId))
        {
            selectedJobId = null;
        }

        if (selectedEmployeeId is not null && !employees.Any(x => x.Id == selectedEmployeeId))
        {
            selectedEmployeeId = null;
        }

        if (selectedCustomerId is not null && !customers.Any(x => x.Id == selectedCustomerId))
        {
            selectedCustomerId = null;
        }

        if (selectedJobId is not null &&
            selectedCustomerId is not null &&
            (!jobToCustomer.TryGetValue(selectedJobId.Value, out var jobCustomerId) || jobCustomerId != selectedCustomerId.Value))
        {
            selectedJobId = null;
        }

        if (selectedEmployeeId is not null)
        {
            var employeeHasMatchingEntries = timeEntries.Any(entry =>
                entry.EmployeeId == selectedEmployeeId &&
                (selectedJobId is null || entry.JobId == selectedJobId) &&
                (selectedCustomerId is null || (jobToCustomer.TryGetValue(entry.JobId, out var customerId) && customerId == selectedCustomerId)));

            if (!employeeHasMatchingEntries)
            {
                selectedEmployeeId = null;
            }
        }
    }

    private DateOnly GetMonthStart() => new(selectedMonth.Year, selectedMonth.Month, 1);

    private DateOnly GetMonthEnd() => GetMonthStart().AddMonths(1).AddDays(-1);

    private static string TopName(IReadOnlyList<AggregateRow> rows, string fallback) =>
        rows.Count == 0 ? fallback : $"{rows[0].Name} leads";

    private static List<AggregateRow> ToAggregateRows(List<AggregateSeed> seeds)
    {
        var peak = seeds.Count == 0 ? 0m : seeds.Max(x => x.Hours);

        return seeds
            .Select(seed => new AggregateRow(
                seed.Id,
                seed.Name,
                seed.Hours,
                seed.EntryCount,
                peak == 0m ? 0m : decimal.Round((seed.Hours / peak) * 100m, 2)))
            .ToList();
    }

    private void ClearFilters()
    {
        selectedCustomerId = null;
        selectedJobId = null;
        selectedEmployeeId = null;
        BuildDashboard();
    }

    private void ToggleCustomerFilter(Guid? customerId)
    {
        ApplyCustomerFilter(selectedCustomerId == customerId ? null : customerId);
    }

    private void ApplyCustomerFilter(Guid? customerId)
    {
        selectedCustomerId = customerId;
        if (selectedJobId is not null && jobs.FirstOrDefault(x => x.Id == selectedJobId)?.CustomerId != selectedCustomerId)
        {
            selectedJobId = null;
        }

        if (selectedEmployeeId is not null && !AvailableEmployees.Any(x => x.Id == selectedEmployeeId))
        {
            selectedEmployeeId = null;
        }

        BuildDashboard();
    }

    private void ToggleJobFilter(Guid? jobId)
    {
        ApplyJobFilter(selectedJobId == jobId ? null : jobId);
    }

    private void ApplyJobFilter(Guid? jobId)
    {
        selectedJobId = jobId;
        if (selectedJobId is not null)
        {
            selectedCustomerId = jobs.FirstOrDefault(x => x.Id == selectedJobId)?.CustomerId;
        }

        if (selectedEmployeeId is not null && !AvailableEmployees.Any(x => x.Id == selectedEmployeeId))
        {
            selectedEmployeeId = null;
        }

        BuildDashboard();
    }

    private void ToggleEmployeeFilter(Guid? employeeId)
    {
        ApplyEmployeeFilter(selectedEmployeeId == employeeId ? null : employeeId);
    }

    private void ApplyEmployeeFilter(Guid? employeeId)
    {
        selectedEmployeeId = employeeId;
        BuildDashboard();
    }

    private static Guid? ParseGuid(string? rawValue) =>
        Guid.TryParse(rawValue, out var parsed) ? parsed : null;

    private static bool IsUnauthorized(string? errorMessage) =>
        !string.IsNullOrWhiteSpace(errorMessage) &&
        (errorMessage.Contains("Unauthorized", StringComparison.OrdinalIgnoreCase) ||
         errorMessage.Contains("401", StringComparison.OrdinalIgnoreCase));

    private bool IsSelectedCustomer(Guid? id) => selectedCustomerId == id;
    private bool IsSelectedJob(Guid? id) => selectedJobId == id;
    private bool IsSelectedEmployee(Guid? id) => selectedEmployeeId == id;
    private bool JobMatchesCustomer(Guid jobId, Guid customerId) => jobs.FirstOrDefault(x => x.Id == jobId)?.CustomerId == customerId;
    private bool EntryMatchesSelectedJobAndEmployee(TimeEntry entry) =>
        (selectedJobId is null || entry.JobId == selectedJobId) &&
        (selectedEmployeeId is null || entry.EmployeeId == selectedEmployeeId);
    private bool EntryMatchesSelectedEmployee(TimeEntry entry) =>
        selectedEmployeeId is null || entry.EmployeeId == selectedEmployeeId;
    private bool EntryMatchesSelectedCustomerAndJob(TimeEntry entry)
    {
        var job = jobs.FirstOrDefault(x => x.Id == entry.JobId);
        if (job is null)
        {
            return false;
        }

        return (selectedCustomerId is null || job.CustomerId == selectedCustomerId) &&
               (selectedJobId is null || entry.JobId == selectedJobId);
    }
    private bool EntryMatchesSelectedCustomerForJob(Job job) =>
        selectedCustomerId is null || job.CustomerId == selectedCustomerId;

    private void OpenSwitchCompanyDialog()
    {
        switchError = null;
        showSwitchDialog = true;
    }

    private void CloseSwitchCompanyDialog()
    {
        showSwitchDialog = false;
    }

    private async Task SwitchToCompanyAsync(Guid companyId)
    {
        isSwitching = true;
        switchingToCompanyId = companyId;
        switchError = null;

        var result = await AuthSession.SwitchCompanyAsync(companyId);
        if (result.IsSuccess)
        {
            showSwitchDialog = false;
            Navigation.NavigateTo("/", forceLoad: true);
        }
        else
        {
            switchError = result.ErrorMessage ?? "Failed to switch company.";
        }

        isSwitching = false;
        switchingToCompanyId = null;
    }

    private void NavigateToCreateCompany()
    {
        showSwitchDialog = false;
        Navigation.NavigateTo("/companies/new");
    }

    private async Task LogoutAsync()
    {
        await AuthSession.LogoutAsync();
        Navigation.NavigateTo("/", forceLoad: true);
    }

    private sealed record AggregateSeed(Guid Id, string Name, decimal Hours, int EntryCount);
    private sealed record AggregateRow(Guid Id, string Name, decimal Hours, int EntryCount, decimal WidthPercent);
    private sealed record DayLoad(int Day, decimal Hours);
    private sealed record RecentEntryRow(DateOnly WorkDate, string EmployeeName, string JobName, string CustomerName, decimal Hours);
}
