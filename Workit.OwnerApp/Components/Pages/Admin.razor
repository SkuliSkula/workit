@page "/admin"
@rendermode InteractiveServer
@inject HttpClient Http

<PageTitle>Admin</PageTitle>

<FluentCard Class="admin-card">
    <FluentLabel Typo="Typography.PaneHeader">Company Setup</FluentLabel>

    @if (company is null)
    {
        <div class="admin-grid">
            <FluentTextField @bind-Value="newCompany.Name" Placeholder="Company name" />
            <FluentTextField @bind-Value="newCompany.Ssn" Placeholder="SSN" />
            <FluentTextField @bind-Value="newCompany.Owner" Placeholder="Owner" />
            <FluentTextField @bind-Value="newCompany.Email" Placeholder="Email" />
            <FluentTextField @bind-Value="newCompany.Phone" Placeholder="Phone" />
            <FluentTextField @bind-Value="newCompany.Address" Placeholder="Address" />
            <FluentButton Appearance="Appearance.Accent" @onclick="CreateCompanyAsync">Create Company</FluentButton>
        </div>

        <p>Set up your company once. After it is created, manage customers, employees, and jobs from their own pages.</p>
    }
    else
    {
        <dl class="admin-grid">
            <div><dt>Company</dt><dd>@company.Name</dd></div>
            <div><dt>SSN</dt><dd>@company.Ssn</dd></div>
            <div><dt>Owner</dt><dd>@company.Owner</dd></div>
            <div><dt>Email</dt><dd>@company.Email</dd></div>
            <div><dt>Phone</dt><dd>@company.Phone</dd></div>
            <div><dt>Address</dt><dd>@company.Address</dd></div>
        </dl>

        <p>This company is fixed after setup.</p>
    }

    @if (!string.IsNullOrWhiteSpace(loadError))
    {
        <p>@loadError</p>
    }
</FluentCard>

@code {
    private Company? company;
    private Company newCompany = new();
    private string? loadError;

    protected override async Task OnInitializedAsync()
    {
        await LoadCompanyAsync();
    }

    private async Task LoadCompanyAsync()
    {
        loadError = null;

        try
        {
            company = await Http.GetFromJsonAsync<Company?>("api/company");
        }
        catch (Exception)
        {
            company = null;
            loadError ??= "The company profile could not be loaded right now.";
        }
    }

    private async Task CreateCompanyAsync()
    {
        if (!IsCompanySetupValid(newCompany))
        {
            loadError = "Company name, SSN, email, address, phone, and owner are required.";
            return;
        }

        var response = await Http.PostAsJsonAsync("api/companies", newCompany);
        if (response.IsSuccessStatusCode)
        {
            newCompany = new Company();
            await LoadCompanyAsync();
            return;
        }

        loadError = await response.Content.ReadAsStringAsync();
    }

    private static bool IsCompanySetupValid(Company input) =>
        !string.IsNullOrWhiteSpace(input.Name) &&
        !string.IsNullOrWhiteSpace(input.Ssn) &&
        !string.IsNullOrWhiteSpace(input.Email) &&
        !string.IsNullOrWhiteSpace(input.Address) &&
        !string.IsNullOrWhiteSpace(input.Phone) &&
        !string.IsNullOrWhiteSpace(input.Owner);
}
