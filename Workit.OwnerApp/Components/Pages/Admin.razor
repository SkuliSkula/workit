@page "/admin"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AuthSessionService AuthSession
@inject IAuthApi AuthApi
@inject NavigationManager Navigation

<PageTitle>Admin</PageTitle>

@if (!isAdmin)
{
    <FluentCard Class="admin-card">
        <FluentLabel Typo="Typography.PaneHeader">Access Denied</FluentLabel>
        <p>This page is only available to administrators.</p>
        <FluentButton Appearance="Appearance.Accent" @onclick="@(() => Navigation.NavigateTo("/"))">Back to Home</FluentButton>
    </FluentCard>
}
else
{
    <FluentCard Class="admin-card" AreaRestricted="false">
        <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:0.75rem;">
            <div>
                <span class="eyebrow">Administration</span>
                <h1 style="margin:0;">Company Management</h1>
            </div>
            <div style="display:flex; gap:0.5rem;">
                <FluentButton Appearance="Appearance.Accent" @onclick="ToggleRegisterForm">
                    @(showRegisterForm ? "Cancel" : "+ Create Owner")
                </FluentButton>
                <FluentButton Appearance="Appearance.Stealth" @onclick="@(() => Navigation.NavigateTo("/"))">← Dashboard</FluentButton>
            </div>
        </div>
    </FluentCard>

    @* ── Create Owner Form ── *@
    @if (showRegisterForm)
    {
        <FluentCard Class="admin-card" AreaRestricted="false">
            <FluentLabel Typo="Typography.Body" Style="font-weight:700; margin-bottom:0.75rem;">Create Owner Account</FluentLabel>
            <FluentLabel Style="color:#60758b; font-size:0.85rem; margin-bottom:0.5rem;">
                The owner will log in and set up their company themselves on first login.
            </FluentLabel>

            <div class="form-fields" style="max-width:480px; margin-top:0.75rem;">
                <div>
                    <FluentLabel>Full Name *</FluentLabel>
                    <FluentTextField @bind-Value="regOwnerName" Style="width:100%;" Placeholder="e.g. Jón Jónsson" />
                </div>
                <div>
                    <FluentLabel>Email *</FluentLabel>
                    <FluentTextField @bind-Value="regOwnerEmail" Style="width:100%;" Placeholder="e.g. jon@company.is" />
                </div>
                <div>
                    <FluentLabel>Password *</FluentLabel>
                    <FluentTextField @bind-Value="regOwnerPassword" Style="width:100%;" Placeholder="Min. 8 characters" TextFieldType="TextFieldType.Password" />
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(registerError))
            {
                <div class="msg msg--error">@registerError</div>
            }

            @if (!string.IsNullOrWhiteSpace(registerSuccess))
            {
                <div class="msg msg--success">@registerSuccess</div>
            }

            <div style="display:flex; gap:0.75rem; margin-top:1.25rem;">
                <FluentButton Appearance="Appearance.Accent"
                              @onclick="CreateOwnerAsync"
                              Disabled="@(isRegistering || !CanCreateOwner)">
                    @(isRegistering ? "Creating…" : "Create Owner")
                </FluentButton>
            </div>
        </FluentCard>
    }

    @* ── Owners List ── *@
    <FluentCard Class="admin-card" AreaRestricted="false">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem;">
            <FluentLabel Typo="Typography.Body" Style="font-weight:700;">
                Owners (@owners.Count)
            </FluentLabel>
            <FluentButton Appearance="Appearance.Stealth" @onclick="LoadOwnersAsync" Disabled="@isLoadingOwners">
                @(isLoadingOwners ? "Loading…" : "Refresh")
            </FluentButton>
        </div>

        @if (!string.IsNullOrWhiteSpace(ownersLoadError))
        {
            <div class="msg msg--error">@ownersLoadError</div>
        }

        @if (isLoadingOwners && owners.Count == 0)
        {
            <div style="display:flex; align-items:center; gap:0.75rem;">
                <FluentProgressRing />
                <FluentLabel>Loading owners…</FluentLabel>
            </div>
        }
        else if (owners.Count == 0)
        {
            <FluentLabel Style="color:#60758b;">No owner accounts yet. Click "+ Create Owner" above to add one.</FluentLabel>
        }
        else
        {
            <div class="company-grid">
                @foreach (var o in owners)
                {
                    <div class="company-card">
                        <div class="company-card-header">
                            <div>
                                <span class="company-card-name">@o.Name</span>
                                <span class="company-card-ssn">@o.Email</span>
                            </div>
                            @if (o.HasCompany)
                            {
                                <span class="badge badge--green">Active · @o.CompanyName</span>
                            }
                            else
                            {
                                <span class="badge badge--amber">Setup Pending</span>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </FluentCard>

    @* ── Companies List ── *@
    <FluentCard Class="admin-card" AreaRestricted="false">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem;">
            <FluentLabel Typo="Typography.Body" Style="font-weight:700;">
                All Companies (@companies.Count)
            </FluentLabel>
            <FluentButton Appearance="Appearance.Stealth" @onclick="LoadCompaniesAsync" Disabled="@isLoadingCompanies">
                @(isLoadingCompanies ? "Loading…" : "Refresh")
            </FluentButton>
        </div>

        @if (isLoadingCompanies && companies.Count == 0)
        {
            <div style="display:flex; align-items:center; gap:0.75rem;">
                <FluentProgressRing />
                <FluentLabel>Loading companies…</FluentLabel>
            </div>
        }
        else if (companies.Count == 0)
        {
            <FluentLabel Style="color:#60758b;">No companies registered yet. Click "+ Register New Company" above to get started.</FluentLabel>
        }
        else
        {
            <div class="company-grid">
                @foreach (var c in companies)
                {
                    <div class="company-card">
                        <div class="company-card-header">
                            <div>
                                <span class="company-card-name">@c.Name</span>
                                <span class="company-card-ssn">@c.Ssn</span>
                            </div>
                            <div style="display:flex; gap:0.35rem; align-items:center;">
                                @if (c.HasPayday)
                                {
                                    <span class="badge badge--green" title="Payday connected">Payday</span>
                                }
                                <FluentButton Appearance="Appearance.Accent" Size="ButtonSize.Small"
                                              @onclick="@(() => SwitchToCompanyAsync(c.Id))"
                                              Disabled="@isSwitching">
                                    @(isSwitching && switchingTo == c.Id ? "Entering…" : "Enter")
                                </FluentButton>
                            </div>
                        </div>
                        <div class="company-card-details">
                            <span><strong>Contact:</strong> @c.Owner</span>
                            <span><strong>Owner login:</strong> @c.OwnerEmail</span>
                            <span><strong>Email:</strong> @c.Email</span>
                            <span><strong>Phone:</strong> @c.Phone</span>
                            <span><strong>Address:</strong> @c.Address</span>
                        </div>
                    </div>
                }
            </div>
        }
    </FluentCard>
}

<style>
    .eyebrow {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #60758b;
    }

    .register-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
        margin-top: 0.5rem;
    }

    .register-section {
        display: grid;
        gap: 0.75rem;
        align-content: start;
    }

    .form-fields {
        display: grid;
        gap: 0.75rem;
    }

    .msg {
        margin-top: 0.75rem;
        padding: 0.75rem 1rem;
        border-radius: 10px;
        font-size: 0.85rem;
    }

    .msg--error {
        background: #fef2f2;
        color: #991b1b;
        border: 1px solid #fecaca;
    }

    .msg--success {
        background: #ecfdf5;
        color: #065f46;
        border: 1px solid #a7f3d0;
    }

    .company-grid {
        display: grid;
        gap: 0.75rem;
    }

    .company-card {
        border: 1px solid rgba(20, 48, 75, 0.08);
        border-radius: 14px;
        padding: 1rem 1.25rem;
        background: #f9fafb;
        transition: border-color 0.15s;
    }

    .company-card:hover {
        border-color: #3b82f6;
    }

    .company-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 0.5rem;
    }

    .company-card-name {
        font-weight: 700;
        color: #14304b;
        font-size: 1rem;
    }

    .company-card-ssn {
        margin-left: 0.5rem;
        font-size: 0.8rem;
        color: #60758b;
    }

    .company-card-details {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem 1.25rem;
        font-size: 0.82rem;
        color: #60758b;
    }

    .badge {
        font-size: 0.65rem;
        font-weight: 700;
        padding: 0.15rem 0.5rem;
        border-radius: 999px;
        white-space: nowrap;
    }

    .badge--green {
        background: #d1fae5;
        color: #065f46;
    }

    .badge--amber {
        background: #fef3c7;
        color: #92400e;
    }

    @@media (max-width: 720px) {
        .register-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    private bool isAdmin;
    private bool isLoadingCompanies;
    private bool isLoadingOwners;
    private bool showRegisterForm;
    private bool isRegistering;
    private bool isSwitching;
    private Guid? switchingTo;
    private List<AdminCompanyInfo> companies = [];
    private List<AdminOwnerInfo> owners = [];
    private string? ownersLoadError;

    // Create-owner form state
    private string regOwnerName = "";
    private string regOwnerEmail = "";
    private string regOwnerPassword = "";
    private string? registerError;
    private string? registerSuccess;

    private bool CanCreateOwner =>
        !string.IsNullOrWhiteSpace(regOwnerName) &&
        !string.IsNullOrWhiteSpace(regOwnerEmail) &&
        regOwnerPassword.Length >= 8;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var session = await AuthSession.GetSessionAsync();
        if (session is null)
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }

        isAdmin = string.Equals(session.Role, WorkitRoles.Admin, StringComparison.Ordinal);
        if (isAdmin)
        {
            await Task.WhenAll(LoadCompaniesAsync(), LoadOwnersAsync());
        }

        StateHasChanged();
    }

    private async Task LoadCompaniesAsync()
    {
        isLoadingCompanies = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            var result = await AuthApi.GetAdminCompaniesAsync();
            if (result.IsSuccess)
                companies = result.Value ?? [];
        }
        finally
        {
            isLoadingCompanies = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadOwnersAsync()
    {
        isLoadingOwners = true;
        ownersLoadError = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            var result = await AuthApi.GetAdminOwnersAsync();
            if (result.IsSuccess)
                owners = result.Value ?? [];
            else
                ownersLoadError = result.ErrorMessage ?? "Could not load owners.";
        }
        finally
        {
            isLoadingOwners = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task CreateOwnerAsync()
    {
        isRegistering = true;
        registerError = null;
        registerSuccess = null;

        var result = await AuthApi.CreateOwnerAsync(new CreateOwnerRequest
        {
            Name     = regOwnerName,
            Email    = regOwnerEmail,
            Password = regOwnerPassword
        });

        if (result.IsSuccess)
        {
            registerSuccess = $"Owner account created for {regOwnerEmail}. They will set up their company on first login.";
            regOwnerName = "";
            regOwnerEmail = "";
            regOwnerPassword = "";
            showRegisterForm = false;
            await LoadOwnersAsync();
        }
        else
        {
            registerError = result.ErrorMessage ?? "Could not create owner account.";
        }

        isRegistering = false;
    }

    private async Task SwitchToCompanyAsync(Guid companyId)
    {
        isSwitching = true;
        switchingTo = companyId;

        var result = await AuthSession.SwitchCompanyAsync(companyId);
        if (result.IsSuccess)
        {
            Navigation.NavigateTo("/", forceLoad: true);
        }

        isSwitching = false;
        switchingTo = null;
    }

    private void ToggleRegisterForm()
    {
        showRegisterForm = !showRegisterForm;
        registerError = null;
        registerSuccess = null;
    }

}
