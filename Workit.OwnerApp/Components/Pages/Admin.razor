@page "/admin"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject ICompanyApi CompanyApi
@inject AuthSessionService AuthSession
@inject NavigationManager Navigation

<PageTitle>Admin</PageTitle>

<FluentCard Class="admin-card">
    <FluentLabel Typo="Typography.PaneHeader">Company Setup</FluentLabel>

    @if (company is null)
    {
        <p>No company was found for this logged-in owner account.</p>
        <FluentButton Appearance="Appearance.Outline" Href="/register">Register Company</FluentButton>
    }
    else
    {
        <dl class="admin-grid">
            <div><dt>Company</dt><dd>@company.Name</dd></div>
            <div><dt>SSN</dt><dd>@company.Ssn</dd></div>
            <div><dt>Owner</dt><dd>@company.Owner</dd></div>
            <div><dt>Email</dt><dd>@company.Email</dd></div>
            <div><dt>Phone</dt><dd>@company.Phone</dd></div>
            <div><dt>Address</dt><dd>@company.Address</dd></div>
        </dl>

        <div class="admin-grid">
            <FluentButton Appearance="Appearance.Stealth" @onclick="LogoutAsync">Logout</FluentButton>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(loadError))
    {
        <p>@loadError</p>
    }
</FluentCard>

@code {
    private Company? company;
    private string? loadError;
    private bool isAdmin;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        var session = await AuthSession.GetSessionAsync();
        isAdmin = session?.Role == WorkitRoles.Admin;
        if (!isAdmin)
        {
            Navigation.NavigateTo("/", forceLoad: true);
            return;
        }

        await LoadCompanyAsync();
        StateHasChanged();
    }

    private async Task LoadCompanyAsync()
    {
        loadError = null;
        var result = await CompanyApi.GetCompanyAsync();
        company = result.Value;
        loadError = result.IsSuccess ? null : result.ErrorMessage;
    }

    private async Task LogoutAsync()
    {
        await AuthSession.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}
