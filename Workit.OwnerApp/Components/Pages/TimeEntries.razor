@page "/timeentries"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IEmployeesApi EmployeesApi
@inject IJobsApi JobsApi
@inject ITimeEntriesApi TimeEntriesApi

<PageTitle>Time Entries</PageTitle>

@* ── Header ── *@
<FluentCard Class="admin-card" AreaRestricted="false">
    <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:0.5rem;">
        <FluentLabel Typo="Typography.PaneHeader">Time Entries</FluentLabel>
        <FluentButton Appearance="Appearance.Accent" @onclick="ToggleCreateForm">
            @(showCreateForm ? "✕ Cancel" : "+ New")
        </FluentButton>
    </div>

    @if (!string.IsNullOrWhiteSpace(loadError))
    {
        <FluentLabel Color="Color.Error" style="margin-top:0.5rem;">@loadError</FluentLabel>
    }
</FluentCard>

@* ── Add Entry form ── *@
@if (showCreateForm)
{
    <FluentCard Class="admin-card" AreaRestricted="false">
        <FluentLabel Typo="Typography.Body"><strong>New Time Entry</strong></FluentLabel>
        <div class="admin-grid" style="margin-top:0.75rem;">
            <div>
                @if (employees.Count > 0)
                {
                    <FluentSelect Label="Employee" TValue="string" TOption="string" @bind-Value="selectedEmployeeId" style="width:100%">
                        @foreach (var emp in employees)
                        {
                            <FluentOption TOption="string" Value="@emp.Id.ToString()">
                                @emp.DisplayName @(string.IsNullOrWhiteSpace(emp.Trade) ? string.Empty : $"({emp.Trade})")
                            </FluentOption>
                        }
                    </FluentSelect>
                }
                else
                {
                    <FluentLabel>No employees yet.</FluentLabel>
                }
            </div>

            <div>
                @if (jobs.Count > 0)
                {
                    <FluentSelect Label="Job" TValue="string" TOption="string" @bind-Value="selectedJobId" style="width:100%">
                        @foreach (var job in jobs)
                        {
                            <FluentOption TOption="string" Value="@job.Id.ToString()">
                                @job.Code – @job.Name
                            </FluentOption>
                        }
                    </FluentSelect>
                }
                else
                {
                    <FluentLabel>No jobs yet.</FluentLabel>
                }
            </div>

            <div>
                <FluentDatePicker Label="Date" @bind-Value="workDate" style="width:100%" />
            </div>

            <div>
                <FluentNumberField Label="Hours" TValue="decimal" @bind-Value="hours" Step="0.5" Min="0" style="width:100%" />
            </div>

            <div>
                <FluentNumberField Label="Overtime hours" TValue="decimal" @bind-Value="overtimeHours" Step="0.5" Min="0" style="width:100%" />
            </div>

            <div>
                <FluentNumberField Label="Driving units" TValue="int" @bind-Value="drivingUnits" Min="0" style="width:100%" />
            </div>

            <div style="grid-column: span 2">
                <FluentTextField Label="Notes" @bind-Value="notes" Placeholder="Optional notes" style="width:100%" />
            </div>
        </div>
        <div style="display:flex; gap:0.5rem; margin-top:0.75rem;">
            <FluentButton Appearance="Appearance.Accent" @onclick="AddEntryAsync"
                          Disabled="@(!CanAdd || saving)">
                @(saving ? "Saving…" : "Save")
            </FluentButton>
            <FluentButton Appearance="Appearance.Neutral" @onclick="ToggleCreateForm">Cancel</FluentButton>
        </div>

        @if (!string.IsNullOrWhiteSpace(saveResult))
        {
            <FluentLabel style="margin-top:0.25rem;">@saveResult</FluentLabel>
        }
    </FluentCard>
}

@* ── Entry Log ── *@
<FluentCard Class="admin-card" AreaRestricted="false">
    <FluentLabel Typo="Typography.Body"><strong>Entry Log</strong></FluentLabel>

    <div class="admin-grid">
        <FluentDatePicker @bind-Value="filterFrom" Label="From" />
        <FluentDatePicker @bind-Value="filterTo"   Label="To" />
        <div style="display:flex; align-items:flex-end;">
            <FluentButton Appearance="Appearance.Accent" @onclick="LoadEntriesAsync" Disabled="@loadingEntries">
                @(loadingEntries ? "Loading…" : "Load")
            </FluentButton>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(editResult))
    {
        <FluentLabel style="margin-top:0.25rem;" Color="@(editResult.StartsWith("✓") ? Color.Success : Color.Error)">@editResult</FluentLabel>
    }

    @if (entries.Count > 0)
    {
        <FluentDataGrid TGridItem="EntryRow" Items="@entries.AsQueryable()" AutoFit="true"
                        DisplayMode="DataGridDisplayMode.Table" style="margin-top:0.5rem;">
            <PropertyColumn Property="@(x => x.Date)"         Title="Date"     Format="dd MMM yyyy" />
            <PropertyColumn Property="@(x => x.EmployeeName)" Title="Employee" />
            <PropertyColumn Property="@(x => x.JobName)"      Title="Job" />
            <TemplateColumn Title="Hours">
                @if (editingRow == context)
                {
                    <FluentNumberField TValue="decimal" @bind-Value="editHours" Step="0.5" Min="0" style="width:5rem;" />
                }
                else
                {
                    @context.Hours.ToString("0.##")
                }
            </TemplateColumn>
            <TemplateColumn Title="Overtime">
                @if (editingRow == context)
                {
                    <FluentNumberField TValue="decimal" @bind-Value="editOvertimeHours" Step="0.5" Min="0" style="width:5rem;" />
                }
                else
                {
                    @context.OvertimeHours.ToString("0.##")
                }
            </TemplateColumn>
            <TemplateColumn Title="Driving">
                @if (editingRow == context)
                {
                    <FluentNumberField TValue="int" @bind-Value="editDrivingUnits" Min="0" style="width:4rem;" />
                }
                else
                {
                    @context.DrivingUnits
                }
            </TemplateColumn>
            <TemplateColumn Title="Notes">
                @if (editingRow == context)
                {
                    <FluentTextField @bind-Value="editNotes" style="width:100%;" />
                }
                else
                {
                    @context.Notes
                }
            </TemplateColumn>
            <TemplateColumn Title="Invoiced">
                @if (context.IsInvoiced && context.PaydayInvoiceNumber.HasValue)
                {
                    <FluentButton Appearance="Appearance.Lightweight"
                                  Style="background:#dcfce7; color:#166534; padding:2px 8px; border-radius:4px; font-size:0.8rem; font-weight:600; min-width:auto; height:auto;"
                                  Title="Click to uninvoice"
                                  @onclick="@(() => ConfirmUninvoice(context.PaydayInvoiceNumber.Value))">
                        #@context.PaydayInvoiceNumber
                    </FluentButton>
                }
                else if (context.IsInvoiced)
                {
                    <span style="background:#dcfce7; color:#166534; padding:2px 8px; border-radius:4px; font-size:0.8rem; font-weight:600;">✓</span>
                }
            </TemplateColumn>
            <TemplateColumn Title="">
                @if (editingRow == context)
                {
                    <div style="display:flex; gap:0.25rem;">
                        <FluentButton Appearance="Appearance.Accent" @onclick="SaveEditAsync" Disabled="@editSaving">Save</FluentButton>
                        <FluentButton Appearance="Appearance.Neutral" @onclick="CancelEdit">Cancel</FluentButton>
                    </div>
                }
                else
                {
                    <FluentButton Appearance="Appearance.Lightweight" @onclick="@(() => StartEdit(context))">Edit</FluentButton>
                }
            </TemplateColumn>
        </FluentDataGrid>

        <FluentLabel style="margin-top:0.4rem; font-size:0.85rem;">
            Total: <strong>@entries.Sum(e => e.Hours).ToString("0.##") hrs</strong>
            · Overtime: <strong>@entries.Sum(e => e.OvertimeHours).ToString("0.##") hrs</strong>
            @if (entries.Sum(e => e.DrivingUnits) > 0)
            {
                <span> · Driving: <strong>@entries.Sum(e => e.DrivingUnits) units</strong></span>
            }
            · across @entries.Count entries
            @{ var invoicedCount = entries.Count(e => e.IsInvoiced); }
            @if (invoicedCount > 0)
            {
                <span> · <strong>@invoicedCount</strong> invoiced</span>
            }
        </FluentLabel>
    }
    else if (!loadingEntries && hasLoadedEntries)
    {
        <FluentLabel>No entries found for the selected period.</FluentLabel>
    }
</FluentCard>

@if (uninvoiceNumber.HasValue)
{
    <FluentCard Class="admin-card" AreaRestricted="false" Style="border: 2px solid #f59e0b;">
        <FluentLabel Typo="Typography.Body">
            <strong>Reset invoice #@uninvoiceNumber?</strong>
        </FluentLabel>
        <FluentLabel style="margin-top:0.25rem;">
            This will mark all time entries and material usages linked to invoice <strong>#@uninvoiceNumber</strong> as <em>not invoiced</em>,
            so they can be included in a new invoice.
        </FluentLabel>
        @if (!string.IsNullOrWhiteSpace(uninvoiceResult))
        {
            <FluentLabel style="margin-top:0.25rem;" Color="@(uninvoiceResult.StartsWith("✓") ? Color.Success : Color.Error)">@uninvoiceResult</FluentLabel>
        }
        <div style="display:flex; gap:0.5rem; margin-top:0.75rem;">
            <FluentButton Appearance="Appearance.Accent" Style="background:#dc2626;" @onclick="ExecuteUninvoiceAsync" Disabled="@uninvoiceSaving">
                @(uninvoiceSaving ? "Resetting…" : "Yes, reset")
            </FluentButton>
            <FluentButton Appearance="Appearance.Neutral" @onclick="CancelUninvoice">Cancel</FluentButton>
        </div>
    </FluentCard>
}

@code {

    // ── Lookup data ───────────────────────────────────────────────────────────
    private readonly List<Employee> employees = [];
    private readonly List<Job> jobs = [];
    private readonly Dictionary<Guid, string> employeeNames = new();
    private readonly Dictionary<Guid, string> jobNames = new();

    // ── Add-entry form state ──────────────────────────────────────────────────
    private bool showCreateForm;
    private string? selectedEmployeeId;
    private string? selectedJobId;
    private DateTime? workDate = DateTime.Today;
    private decimal hours = 8m;
    private decimal overtimeHours = 0m;
    private int     drivingUnits = 0;
    private string notes = string.Empty;
    private bool saving;
    private string? saveResult;
    private string? loadError;

    private bool CanAdd =>
        Guid.TryParse(selectedEmployeeId, out _) &&
        Guid.TryParse(selectedJobId, out _) &&
        workDate is not null &&
        hours > 0;

    // ── Entry log state ───────────────────────────────────────────────────────
    private DateTime? filterFrom = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime? filterTo   = DateTime.Today;
    private bool loadingEntries;
    private bool hasLoadedEntries;
    private readonly List<EntryRow> entries = [];

    private sealed class EntryRow
    {
        public Guid     Id            { get; set; }
        public Guid     EmployeeId    { get; set; }
        public Guid     JobId         { get; set; }
        public DateOnly Date          { get; set; }
        public string   EmployeeName  { get; set; } = string.Empty;
        public string   JobName       { get; set; } = string.Empty;
        public decimal  Hours         { get; set; }
        public decimal  OvertimeHours { get; set; }
        public int      DrivingUnits  { get; set; }
        public string   Notes         { get; set; } = string.Empty;
        public bool     IsInvoiced    { get; set; }
        public int?     PaydayInvoiceNumber { get; set; }
        public string   InvoiceStatus => IsInvoiced
            ? (PaydayInvoiceNumber.HasValue ? $"#{PaydayInvoiceNumber}" : "Yes")
            : "";
    }

    // ── Edit state ──────────────────────────────────────────────────────────
    private EntryRow? editingRow;
    private decimal editHours;
    private decimal editOvertimeHours;
    private int     editDrivingUnits;
    private string  editNotes = string.Empty;
    private bool    editSaving;
    private string? editResult;

    private void StartEdit(EntryRow row)
    {
        editingRow      = row;
        editHours       = row.Hours;
        editOvertimeHours = row.OvertimeHours;
        editDrivingUnits  = row.DrivingUnits;
        editNotes       = row.Notes;
        editResult      = null;
    }

    private void CancelEdit()
    {
        editingRow = null;
        editResult = null;
    }

    private async Task SaveEditAsync()
    {
        if (editingRow is null) return;

        editSaving = true;
        editResult = null;

        try
        {
            var updated = new TimeEntry
            {
                Id            = editingRow.Id,
                EmployeeId    = editingRow.EmployeeId,
                JobId         = editingRow.JobId,
                WorkDate      = editingRow.Date,
                Hours         = editHours,
                OvertimeHours = editOvertimeHours,
                DrivingUnits  = editDrivingUnits,
                Notes         = editNotes.Trim()
            };

            var result = await TimeEntriesApi.UpdateTimeEntryAsync(updated);
            if (result.IsSuccess)
            {
                editingRow.Hours         = editHours;
                editingRow.OvertimeHours = editOvertimeHours;
                editingRow.DrivingUnits  = editDrivingUnits;
                editingRow.Notes         = editNotes.Trim();
                editResult  = "✓ Entry updated";
                editingRow  = null;
            }
            else
            {
                editResult = $"Error: {result.ErrorMessage}";
            }
        }
        finally
        {
            editSaving = false;
        }
    }

    // ── Uninvoice state ─────────────────────────────────────────────────────
    private int?   uninvoiceNumber;
    private bool   uninvoiceSaving;
    private string? uninvoiceResult;

    private void ConfirmUninvoice(int invoiceNumber)
    {
        uninvoiceNumber = invoiceNumber;
        uninvoiceResult = null;
    }

    private void CancelUninvoice()
    {
        uninvoiceNumber = null;
        uninvoiceResult = null;
    }

    private async Task ExecuteUninvoiceAsync()
    {
        if (uninvoiceNumber is null) return;

        uninvoiceSaving = true;
        uninvoiceResult = null;

        try
        {
            var request = new MarkUninvoicedRequest { PaydayInvoiceNumber = uninvoiceNumber.Value };

            var teResult = await TimeEntriesApi.MarkTimeEntriesUninvoicedAsync(request);
            if (!teResult.IsSuccess)
            {
                uninvoiceResult = $"Error resetting time entries: {teResult.ErrorMessage}";
                return;
            }

            uninvoiceResult = $"✓ Invoice #{uninvoiceNumber} entries have been reset.";
            uninvoiceNumber = null;
            await LoadEntriesAsync();
        }
        finally
        {
            uninvoiceSaving = false;
        }
    }

    // ── Lifecycle ─────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        var empTask = EmployeesApi.GetEmployeesAsync();
        var jobTask = JobsApi.GetJobsAsync();
        await Task.WhenAll(empTask, jobTask);

        var empResult = await empTask;
        if (empResult.IsSuccess)
        {
            employees.AddRange(empResult.Value ?? []);
            foreach (var e in employees)
                employeeNames[e.Id] = e.DisplayName;
            selectedEmployeeId = employees.FirstOrDefault()?.Id.ToString();
        }
        else
        {
            loadError = empResult.ErrorMessage;
        }

        var jobResult = await jobTask;
        if (jobResult.IsSuccess)
        {
            jobs.AddRange(jobResult.Value ?? []);
            foreach (var j in jobs)
                jobNames[j.Id] = $"{j.Code} – {j.Name}";
            selectedJobId = jobs.FirstOrDefault()?.Id.ToString();
        }
        else
        {
            loadError ??= jobResult.ErrorMessage;
        }

        await LoadEntriesAsync();
    }

    private void ToggleCreateForm() => showCreateForm = !showCreateForm;

    // ── Add Entry ─────────────────────────────────────────────────────────────
    private async Task AddEntryAsync()
    {
        if (!Guid.TryParse(selectedEmployeeId, out var empId)) return;
        if (!Guid.TryParse(selectedJobId,      out var jobId)) return;
        if (workDate is null) return;

        saving     = true;
        saveResult = null;

        try
        {
            var result = await TimeEntriesApi.CreateTimeEntryAsync(new TimeEntry
            {
                EmployeeId    = empId,
                JobId         = jobId,
                WorkDate      = DateOnly.FromDateTime(workDate.Value),
                Hours         = hours,
                OvertimeHours = overtimeHours,
                DrivingUnits  = drivingUnits,
                Notes         = notes.Trim()
            });

            if (result.IsSuccess)
            {
                saveResult    = $"✓ Entry saved ({hours:0.##} hrs{(overtimeHours > 0 ? $" + {overtimeHours:0.##} OT" : string.Empty)}{(drivingUnits > 0 ? $" + {drivingUnits} driving" : string.Empty)})";
                notes         = string.Empty;
                hours         = 8m;
                overtimeHours = 0m;
                drivingUnits  = 0;
                showCreateForm = false;
                await LoadEntriesAsync();
            }
            else
            {
                saveResult = $"Error: {result.ErrorMessage}";
            }
        }
        finally
        {
            saving = false;
        }
    }

    // ── Load Entries ──────────────────────────────────────────────────────────
    private async Task LoadEntriesAsync()
    {
        if (filterFrom is null || filterTo is null) return;

        loadingEntries  = true;
        hasLoadedEntries = false;
        entries.Clear();

        try
        {
            var from = DateOnly.FromDateTime(filterFrom.Value);
            var to   = DateOnly.FromDateTime(filterTo.Value);

            var result = await TimeEntriesApi.GetTimeEntriesAsync(from, to);
            if (!result.IsSuccess)
            {
                loadError ??= result.ErrorMessage;
                return;
            }

            var rows = (result.Value ?? [])
                .OrderByDescending(e => e.WorkDate)
                .ThenBy(e => employeeNames.GetValueOrDefault(e.EmployeeId, string.Empty))
                .Select(e => new EntryRow
                {
                    Id            = e.Id,
                    EmployeeId    = e.EmployeeId,
                    JobId         = e.JobId,
                    Date          = e.WorkDate,
                    EmployeeName  = employeeNames.GetValueOrDefault(e.EmployeeId, e.EmployeeId.ToString()),
                    JobName       = jobNames.GetValueOrDefault(e.JobId, e.JobId.ToString()),
                    Hours         = e.Hours,
                    OvertimeHours = e.OvertimeHours,
                    DrivingUnits  = e.DrivingUnits,
                    Notes         = e.Notes,
                    IsInvoiced    = e.IsInvoiced,
                    PaydayInvoiceNumber = e.PaydayInvoiceNumber
                });

            entries.AddRange(rows);
        }
        finally
        {
            loadingEntries   = false;
            hasLoadedEntries = true;
        }
    }
}
