@page "/timeentries"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IEmployeesApi EmployeesApi
@inject IJobsApi JobsApi
@inject ITimeEntriesApi TimeEntriesApi

<PageTitle>Time Entries</PageTitle>

@* ── Header ── *@
<FluentCard Class="admin-card" AreaRestricted="false">
    <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:0.5rem;">
        <FluentLabel Typo="Typography.PaneHeader">Time Entries</FluentLabel>
        <FluentButton Appearance="Appearance.Accent" @onclick="ToggleCreateForm">
            @(showCreateForm ? "✕ Cancel" : "+ New")
        </FluentButton>
    </div>

    @if (!string.IsNullOrWhiteSpace(loadError))
    {
        <FluentLabel Color="Color.Error" style="margin-top:0.5rem;">@loadError</FluentLabel>
    }
</FluentCard>

@* ── Add Entry form ── *@
@if (showCreateForm)
{
    <FluentCard Class="admin-card" AreaRestricted="false">
        <FluentLabel Typo="Typography.Body"><strong>New Time Entry</strong></FluentLabel>
        <div class="admin-grid" style="margin-top:0.75rem;">
            <div>
                <FluentLabel>Employee</FluentLabel>
                @if (employees.Count > 0)
                {
                    <FluentSelect TValue="string" TOption="string" @bind-Value="selectedEmployeeId" style="width:100%">
                        @foreach (var emp in employees)
                        {
                            <FluentOption TOption="string" Value="@emp.Id.ToString()">
                                @emp.DisplayName @(string.IsNullOrWhiteSpace(emp.Trade) ? string.Empty : $"({emp.Trade})")
                            </FluentOption>
                        }
                    </FluentSelect>
                }
                else
                {
                    <FluentLabel>No employees yet.</FluentLabel>
                }
            </div>

            <div>
                <FluentLabel>Job</FluentLabel>
                @if (jobs.Count > 0)
                {
                    <FluentSelect TValue="string" TOption="string" @bind-Value="selectedJobId" style="width:100%">
                        @foreach (var job in jobs)
                        {
                            <FluentOption TOption="string" Value="@job.Id.ToString()">
                                @job.Code – @job.Name
                            </FluentOption>
                        }
                    </FluentSelect>
                }
                else
                {
                    <FluentLabel>No jobs yet.</FluentLabel>
                }
            </div>

            <div>
                <FluentLabel>Date</FluentLabel>
                <FluentDatePicker @bind-Value="workDate" style="width:100%" />
            </div>

            <div>
                <FluentLabel>Hours</FluentLabel>
                <FluentNumberField TValue="decimal" @bind-Value="hours" Step="0.5" Min="0" style="width:100%" />
            </div>

            <div>
                <FluentLabel>Overtime hours</FluentLabel>
                <FluentNumberField TValue="decimal" @bind-Value="overtimeHours" Step="0.5" Min="0" style="width:100%" />
            </div>

            <div>
                <FluentLabel>Driving units</FluentLabel>
                <FluentNumberField TValue="int" @bind-Value="drivingUnits" Min="0" style="width:100%" />
            </div>

            <div style="grid-column: span 2">
                <FluentLabel>Notes</FluentLabel>
                <FluentTextField @bind-Value="notes" Placeholder="Optional notes" style="width:100%" />
            </div>
        </div>
        <div style="display:flex; gap:0.5rem; margin-top:0.75rem;">
            <FluentButton Appearance="Appearance.Accent" @onclick="AddEntryAsync"
                          Disabled="@(!CanAdd || saving)">
                @(saving ? "Saving…" : "Save")
            </FluentButton>
            <FluentButton Appearance="Appearance.Outline" @onclick="ToggleCreateForm">Cancel</FluentButton>
        </div>

        @if (!string.IsNullOrWhiteSpace(saveResult))
        {
            <FluentLabel style="margin-top:0.25rem;">@saveResult</FluentLabel>
        }
    </FluentCard>
}

@* ── Entry Log ── *@
<FluentCard Class="admin-card" AreaRestricted="false">
    <FluentLabel Typo="Typography.Body"><strong>Entry Log</strong></FluentLabel>

    <div class="admin-grid">
        <FluentDatePicker @bind-Value="filterFrom" Label="From" />
        <FluentDatePicker @bind-Value="filterTo"   Label="To" />
        <div style="display:flex; align-items:flex-end;">
            <FluentButton Appearance="Appearance.Outline" @onclick="LoadEntriesAsync" Disabled="@loadingEntries">
                @(loadingEntries ? "Loading…" : "Load")
            </FluentButton>
        </div>
    </div>

    @if (entries.Count > 0)
    {
        <FluentDataGrid TGridItem="EntryRow" Items="@entries.AsQueryable()" AutoFit="true"
                        DisplayMode="DataGridDisplayMode.Table" style="margin-top:0.5rem;">
            <PropertyColumn Property="@(x => x.Date)"         Title="Date"     Format="dd MMM yyyy" />
            <PropertyColumn Property="@(x => x.EmployeeName)" Title="Employee" />
            <PropertyColumn Property="@(x => x.JobName)"      Title="Job" />
            <PropertyColumn Property="@(x => x.Hours)"         Title="Hours"    Format="0.##" />
            <PropertyColumn Property="@(x => x.OvertimeHours)" Title="Overtime" Format="0.##" />
            <PropertyColumn Property="@(x => x.DrivingUnits)"  Title="Driving"  />
            <PropertyColumn Property="@(x => x.Notes)"         Title="Notes" />
            <TemplateColumn Title="Invoiced">
                @if (context.IsInvoiced)
                {
                    <span style="background:#dcfce7; color:#166534; padding:2px 8px; border-radius:4px; font-size:0.8rem; font-weight:600; white-space:nowrap;">
                        @(context.PaydayInvoiceNumber.HasValue ? $"#{context.PaydayInvoiceNumber}" : "✓")
                    </span>
                }
            </TemplateColumn>
        </FluentDataGrid>

        <FluentLabel style="margin-top:0.4rem; font-size:0.85rem;">
            Total: <strong>@entries.Sum(e => e.Hours).ToString("0.##") hrs</strong>
            · Overtime: <strong>@entries.Sum(e => e.OvertimeHours).ToString("0.##") hrs</strong>
            @if (entries.Sum(e => e.DrivingUnits) > 0)
            {
                <span> · Driving: <strong>@entries.Sum(e => e.DrivingUnits) units</strong></span>
            }
            · across @entries.Count entries
            @{ var invoicedCount = entries.Count(e => e.IsInvoiced); }
            @if (invoicedCount > 0)
            {
                <span> · <strong>@invoicedCount</strong> invoiced</span>
            }
        </FluentLabel>
    }
    else if (!loadingEntries && hasLoadedEntries)
    {
        <FluentLabel>No entries found for the selected period.</FluentLabel>
    }
</FluentCard>

@code {

    // ── Lookup data ───────────────────────────────────────────────────────────
    private readonly List<Employee> employees = [];
    private readonly List<Job> jobs = [];
    private readonly Dictionary<Guid, string> employeeNames = new();
    private readonly Dictionary<Guid, string> jobNames = new();

    // ── Add-entry form state ──────────────────────────────────────────────────
    private bool showCreateForm;
    private string? selectedEmployeeId;
    private string? selectedJobId;
    private DateTime? workDate = DateTime.Today;
    private decimal hours = 8m;
    private decimal overtimeHours = 0m;
    private int     drivingUnits = 0;
    private string notes = string.Empty;
    private bool saving;
    private string? saveResult;
    private string? loadError;

    private bool CanAdd =>
        Guid.TryParse(selectedEmployeeId, out _) &&
        Guid.TryParse(selectedJobId, out _) &&
        workDate is not null &&
        hours > 0;

    // ── Entry log state ───────────────────────────────────────────────────────
    private DateTime? filterFrom = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime? filterTo   = DateTime.Today;
    private bool loadingEntries;
    private bool hasLoadedEntries;
    private readonly List<EntryRow> entries = [];

    private sealed class EntryRow
    {
        public DateOnly Date          { get; set; }
        public string   EmployeeName  { get; set; } = string.Empty;
        public string   JobName       { get; set; } = string.Empty;
        public decimal  Hours         { get; set; }
        public decimal  OvertimeHours { get; set; }
        public int      DrivingUnits  { get; set; }
        public string   Notes         { get; set; } = string.Empty;
        public bool     IsInvoiced    { get; set; }
        public int?     PaydayInvoiceNumber { get; set; }
        public string   InvoiceStatus => IsInvoiced
            ? (PaydayInvoiceNumber.HasValue ? $"#{PaydayInvoiceNumber}" : "Yes")
            : "";
    }

    // ── Lifecycle ─────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        var empTask = EmployeesApi.GetEmployeesAsync();
        var jobTask = JobsApi.GetJobsAsync();
        await Task.WhenAll(empTask, jobTask);

        var empResult = await empTask;
        if (empResult.IsSuccess)
        {
            employees.AddRange(empResult.Value ?? []);
            foreach (var e in employees)
                employeeNames[e.Id] = e.DisplayName;
            selectedEmployeeId = employees.FirstOrDefault()?.Id.ToString();
        }
        else
        {
            loadError = empResult.ErrorMessage;
        }

        var jobResult = await jobTask;
        if (jobResult.IsSuccess)
        {
            jobs.AddRange(jobResult.Value ?? []);
            foreach (var j in jobs)
                jobNames[j.Id] = $"{j.Code} – {j.Name}";
            selectedJobId = jobs.FirstOrDefault()?.Id.ToString();
        }
        else
        {
            loadError ??= jobResult.ErrorMessage;
        }

        await LoadEntriesAsync();
    }

    private void ToggleCreateForm() => showCreateForm = !showCreateForm;

    // ── Add Entry ─────────────────────────────────────────────────────────────
    private async Task AddEntryAsync()
    {
        if (!Guid.TryParse(selectedEmployeeId, out var empId)) return;
        if (!Guid.TryParse(selectedJobId,      out var jobId)) return;
        if (workDate is null) return;

        saving     = true;
        saveResult = null;

        try
        {
            var result = await TimeEntriesApi.CreateTimeEntryAsync(new TimeEntry
            {
                EmployeeId    = empId,
                JobId         = jobId,
                WorkDate      = DateOnly.FromDateTime(workDate.Value),
                Hours         = hours,
                OvertimeHours = overtimeHours,
                DrivingUnits  = drivingUnits,
                Notes         = notes.Trim()
            });

            if (result.IsSuccess)
            {
                saveResult    = $"✓ Entry saved ({hours:0.##} hrs{(overtimeHours > 0 ? $" + {overtimeHours:0.##} OT" : string.Empty)}{(drivingUnits > 0 ? $" + {drivingUnits} driving" : string.Empty)})";
                notes         = string.Empty;
                hours         = 8m;
                overtimeHours = 0m;
                drivingUnits  = 0;
                showCreateForm = false;
                await LoadEntriesAsync();
            }
            else
            {
                saveResult = $"Error: {result.ErrorMessage}";
            }
        }
        finally
        {
            saving = false;
        }
    }

    // ── Load Entries ──────────────────────────────────────────────────────────
    private async Task LoadEntriesAsync()
    {
        if (filterFrom is null || filterTo is null) return;

        loadingEntries  = true;
        hasLoadedEntries = false;
        entries.Clear();

        try
        {
            var from = DateOnly.FromDateTime(filterFrom.Value);
            var to   = DateOnly.FromDateTime(filterTo.Value);

            var result = await TimeEntriesApi.GetTimeEntriesAsync(from, to);
            if (!result.IsSuccess)
            {
                loadError ??= result.ErrorMessage;
                return;
            }

            var rows = (result.Value ?? [])
                .OrderByDescending(e => e.WorkDate)
                .ThenBy(e => employeeNames.GetValueOrDefault(e.EmployeeId, string.Empty))
                .Select(e => new EntryRow
                {
                    Date          = e.WorkDate,
                    EmployeeName  = employeeNames.GetValueOrDefault(e.EmployeeId, e.EmployeeId.ToString()),
                    JobName       = jobNames.GetValueOrDefault(e.JobId, e.JobId.ToString()),
                    Hours         = e.Hours,
                    OvertimeHours = e.OvertimeHours,
                    DrivingUnits  = e.DrivingUnits,
                    Notes         = e.Notes,
                    IsInvoiced    = e.IsInvoiced,
                    PaydayInvoiceNumber = e.PaydayInvoiceNumber
                });

            entries.AddRange(rows);
        }
        finally
        {
            loadingEntries   = false;
            hasLoadedEntries = true;
        }
    }
}
