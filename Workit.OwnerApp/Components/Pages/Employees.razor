@page "/employees"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject ICompanyApi CompanyApi
@inject IEmployeesApi EmployeesApi

<PageTitle>Employees</PageTitle>

@* ── Header ── *@
<FluentCard Class="admin-card" AreaRestricted="false">
    <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:0.5rem;">
        <FluentLabel Typo="Typography.PaneHeader">Employees</FluentLabel>
        @if (company is not null)
        {
            <FluentButton Appearance="Appearance.Accent" @onclick="ToggleCreateForm">
                @(showCreateForm ? "✕ Cancel" : "+ New")
            </FluentButton>
        }
    </div>

    @if (company is null && !loading)
    {
        <FluentLabel style="margin-top:0.5rem;">Set up the company first in Admin before adding employees.</FluentLabel>
    }

    @if (!string.IsNullOrWhiteSpace(loadError))
    {
        <FluentLabel Color="Color.Error" style="margin-top:0.5rem;">@loadError</FluentLabel>
    }
</FluentCard>

@* ── Create form ── *@
@if (showCreateForm)
{
    <FluentCard Class="admin-card" AreaRestricted="false">
        <FluentLabel Typo="Typography.Body"><strong>New Employee</strong></FluentLabel>
        <div class="admin-grid" style="margin-top:0.75rem;">
            <div>
                <FluentTextField Label="Name *" @bind-Value="newEmployeeName" Placeholder="Full name" style="width:100%" />
            </div>
            <div>
                <FluentSelect Label="Trade" TValue="string" TOption="string" @bind-Value="newEmployeeTrade" style="width:100%">
                    @foreach (var trade in Trades)
                    {
                        <FluentOption TOption="string" Value="@trade">@trade</FluentOption>
                    }
                </FluentSelect>
            </div>
            <div>
                <FluentTextField Label="SSN" @bind-Value="newEmployeeSsn" Placeholder="Social security number" style="width:100%" />
            </div>
            <div>
                <FluentTextField Label="Email" @bind-Value="newEmployeeEmail" Placeholder="employee@example.com" style="width:100%" />
            </div>
            <div>
                <FluentTextField Label="Password" @bind-Value="newEmployeePassword" Placeholder="Min. 8 characters" TextFieldType="TextFieldType.Password" style="width:100%" />
            </div>
            <div>
                <FluentTextField Label="Phone" @bind-Value="newEmployeePhone" Placeholder="Phone number" style="width:100%" />
            </div>
            <div>
                <FluentTextField Label="Contact person" @bind-Value="newEmployeeContactPerson" Placeholder="Emergency contact" style="width:100%" />
            </div>
            <div>
                <FluentSelect Label="Employment type" TValue="string" TOption="string"
                              Value="@newEmploymentType.ToString()"
                              ValueChanged="@(v => newEmploymentType = Enum.TryParse<EmploymentType>(v, out var e) ? e : EmploymentType.Employed)"
                              style="width:100%">
                    <FluentOption TOption="string" Value="@(EmploymentType.Employed.ToString())">Employed</FluentOption>
                    <FluentOption TOption="string" Value="@(EmploymentType.Contractor.ToString())">Contractor</FluentOption>
                </FluentSelect>
            </div>
            <div>
                <FluentNumberField Label="Hourly salary" TValue="decimal" @bind-Value="newHourlySalary" Min="0" Placeholder="0" style="width:100%" />
            </div>
            <div>
                <FluentNumberField Label="Hourly billable rate" TValue="decimal" @bind-Value="newHourlyBillableRate" Min="0" Placeholder="0" style="width:100%" />
            </div>
        </div>
        <div style="display:flex; gap:0.5rem; margin-top:0.75rem;">
            <FluentButton Appearance="Appearance.Accent" @onclick="CreateEmployeeAsync">Save</FluentButton>
            <FluentButton Appearance="Appearance.Outline" @onclick="ToggleCreateForm">Cancel</FluentButton>
        </div>
    </FluentCard>
}

@* ── Edit form ── *@
@if (editingEmployee is not null)
{
    <FluentCard Class="admin-card" AreaRestricted="false">
        <FluentLabel Typo="Typography.Body"><strong>Edit Employee</strong></FluentLabel>
        <div class="admin-grid" style="margin-top:0.75rem;">
            <div>
                <FluentTextField Label="Name *" @bind-Value="editingEmployee.DisplayName" Placeholder="Full name" style="width:100%" />
            </div>
            <div>
                <FluentSelect Label="Trade" TValue="string" TOption="string" @bind-Value="editingEmployee.Trade" style="width:100%">
                    @foreach (var trade in Trades)
                    {
                        <FluentOption TOption="string" Value="@trade">@trade</FluentOption>
                    }
                </FluentSelect>
            </div>
            <div>
                <FluentTextField Label="SSN" @bind-Value="editingEmployee.Ssn" Placeholder="Social security number" style="width:100%" />
            </div>
            <div>
                <FluentTextField Label="Email" @bind-Value="editingEmployee.Email" Placeholder="employee@example.com" style="width:100%" />
            </div>
            <div>
                <FluentTextField Label="Phone" @bind-Value="editingEmployee.Phone" Placeholder="Phone number" style="width:100%" />
            </div>
            <div>
                <FluentTextField Label="Contact person" @bind-Value="editingEmployee.ContactPerson" Placeholder="Emergency contact" style="width:100%" />
            </div>
            <div>
                <FluentSelect Label="Employment type" TValue="string" TOption="string"
                              Value="@editingEmployee.EmploymentType.ToString()"
                              ValueChanged="@(v => editingEmployee.EmploymentType = Enum.TryParse<EmploymentType>(v, out var e) ? e : EmploymentType.Employed)"
                              style="width:100%">
                    <FluentOption TOption="string" Value="@(EmploymentType.Employed.ToString())">Employed</FluentOption>
                    <FluentOption TOption="string" Value="@(EmploymentType.Contractor.ToString())">Contractor</FluentOption>
                </FluentSelect>
            </div>
            <div>
                <FluentNumberField Label="Hourly salary" TValue="decimal" @bind-Value="editingEmployee.HourlySalary" Min="0" style="width:100%" />
            </div>
            <div>
                <FluentNumberField Label="Hourly billable rate" TValue="decimal" @bind-Value="editingEmployee.HourlyBillableRate" Min="0" style="width:100%" />
            </div>
        </div>
        <div style="display:flex; gap:0.5rem; margin-top:0.75rem;">
            <FluentButton Appearance="Appearance.Accent" @onclick="SaveEmployeeAsync">Save Changes</FluentButton>
            <FluentButton Appearance="Appearance.Outline" @onclick="CancelEmployeeEdit">Cancel</FluentButton>
        </div>
    </FluentCard>
}

@* ── List ── *@
<div class="emp-panel">
    <div class="emp-panel-header">
        <span class="emp-panel-title">All Employees</span>
        <span class="emp-count">@employees.Count</span>
    </div>

    @if (loading)
    {
        <PageLoader />
    }
    else if (employees.Count > 0)
    {
        <FluentDataGrid TGridItem="Employee" Items="@employees.AsQueryable()" AutoFit="true" DisplayMode="DataGridDisplayMode.Table">
            <PropertyColumn Property="@(x => x.DisplayName)" Title="Name" />
            <PropertyColumn Property="@(x => x.Trade)" Title="Trade" />
            <PropertyColumn Property="@(x => x.EmploymentType)" Title="Type" />
            <PropertyColumn Property="@(x => x.Ssn)" Title="SSN" />
            <PropertyColumn Property="@(x => x.Email)" Title="Email" />
            <PropertyColumn Property="@(x => x.Phone)" Title="Phone" />
            <TemplateColumn Title="Salary/hr">
                <span>@context.HourlySalary.ToString("N0")</span>
            </TemplateColumn>
            <TemplateColumn Title="Billable/hr">
                <span>@context.HourlyBillableRate.ToString("N0")</span>
            </TemplateColumn>
            <PropertyColumn Property="@(x => x.ContactPerson)" Title="Contact Person" />
            <TemplateColumn Title="Actions">
                <div style="display:flex; align-items:center; gap:0.5rem; flex-wrap:wrap;">
                    <FluentButton Appearance="Appearance.Stealth" @onclick="@(() => BeginEditEmployee(context))">Edit</FluentButton>
                    <FluentButton Appearance="Appearance.Stealth" @onclick="@(() => ResetEmployeePasswordAsync(context))"
                                  Disabled="@resettingIds.Contains(context.Id)">
                        @(resettingIds.Contains(context.Id) ? "Resetting…" : "Reset Password")
                    </FluentButton>
                    @if (resetPasswords.TryGetValue(context.Id, out var pw))
                    {
                        <FluentLabel style="font-weight:600; color:var(--accent-fill-rest);">New password: @pw</FluentLabel>
                    }
                </div>
            </TemplateColumn>
        </FluentDataGrid>
    }
    else
    {
        <FluentLabel>No employees yet.</FluentLabel>
    }
</div>

@code {
    private static readonly string[] Trades = ["Electrician", "Carpenter", "Plumber", "Painter", "Other"];

    private bool loading = true;
    private bool showCreateForm;
    private readonly List<Employee> employees = [];
    private Company? company;
    private Employee? editingEmployee;
    private string newEmployeeName = string.Empty;
    private string newEmployeeTrade = Trades[0];
    private string newEmployeeSsn = string.Empty;
    private string newEmployeeEmail = string.Empty;
    private string newEmployeePassword = string.Empty;
    private string newEmployeePhone = string.Empty;
    private string newEmployeeContactPerson = string.Empty;
    private EmploymentType newEmploymentType = EmploymentType.Employed;
    private decimal newHourlySalary;
    private decimal newHourlyBillableRate;
    private string? loadError;

    // ── Reset Password state ─────────────────────────────────────────────────
    private readonly HashSet<Guid> resettingIds = [];
    private readonly Dictionary<Guid, string> resetPasswords = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        loading = true;
        loadError = null;
        employees.Clear();
        var companyResult = await CompanyApi.GetCompanyAsync();
        company = companyResult.Value;

        if (!companyResult.IsSuccess)
        {
            loadError = companyResult.ErrorMessage;
            loading = false;
            return;
        }

        if (company is null)
        {
            loading = false;
            return;
        }

        var employeesResult = await EmployeesApi.GetEmployeesAsync();
        if (!employeesResult.IsSuccess)
        {
            loadError = employeesResult.ErrorMessage;
            loading = false;
            return;
        }

        employees.AddRange(employeesResult.Value ?? []);
        loading = false;
    }

    private void ToggleCreateForm()
    {
        showCreateForm = !showCreateForm;
        if (!showCreateForm) ResetCreateForm();
    }

    private void ResetCreateForm()
    {
        newEmployeeName = string.Empty;
        newEmployeeTrade = Trades[0];
        newEmployeeSsn = string.Empty;
        newEmployeeEmail = string.Empty;
        newEmployeePassword = string.Empty;
        newEmployeePhone = string.Empty;
        newEmployeeContactPerson = string.Empty;
        newEmploymentType = EmploymentType.Employed;
        newHourlySalary = 0;
        newHourlyBillableRate = 0;
    }

    private async Task CreateEmployeeAsync()
    {
        if (company is null || string.IsNullOrWhiteSpace(newEmployeeName))
        {
            return;
        }

        var result = await EmployeesApi.CreateEmployeeAsync(new CreateEmployeeUserRequest
        {
            Employee = new Employee
            {
                CompanyId = company.Id,
                DisplayName = newEmployeeName.Trim(),
                Trade = newEmployeeTrade.Trim(),
                Ssn = newEmployeeSsn.Trim(),
                Email = newEmployeeEmail.Trim(),
                Phone = newEmployeePhone.Trim(),
                ContactPerson = newEmployeeContactPerson.Trim(),
                EmploymentType = newEmploymentType,
                HourlySalary = newHourlySalary,
                HourlyBillableRate = newHourlyBillableRate
            },
            Password = newEmployeePassword
        });

        if (result.IsSuccess)
        {
            ResetCreateForm();
            showCreateForm = false;
            await LoadAsync();
            return;
        }

        loadError = result.ErrorMessage;
    }

    private void BeginEditEmployee(Employee employee)
    {
        showCreateForm = false;
        editingEmployee = new Employee
        {
            Id = employee.Id,
            CompanyId = employee.CompanyId,
            DisplayName = employee.DisplayName,
            Trade = employee.Trade,
            Ssn = employee.Ssn,
            Email = employee.Email,
            Phone = employee.Phone,
            ContactPerson = employee.ContactPerson,
            EmploymentType = employee.EmploymentType,
            HourlySalary = employee.HourlySalary,
            HourlyBillableRate = employee.HourlyBillableRate
        };
    }

    private async Task SaveEmployeeAsync()
    {
        if (editingEmployee is null)
        {
            return;
        }

        var result = await EmployeesApi.UpdateEmployeeAsync(editingEmployee);
        if (result.IsSuccess)
        {
            editingEmployee = null;
            await LoadAsync();
            return;
        }

        loadError = result.ErrorMessage;
    }

    private void CancelEmployeeEdit()
    {
        editingEmployee = null;
    }

    private async Task ResetEmployeePasswordAsync(Employee employee)
    {
        resettingIds.Add(employee.Id);
        resetPasswords.Remove(employee.Id);

        try
        {
            var password = GeneratePassword();
            var result = await EmployeesApi.ResetPasswordAsync(employee.Id, password);
            if (result.IsSuccess)
                resetPasswords[employee.Id] = password;
            else
                loadError = result.ErrorMessage;
        }
        finally
        {
            resettingIds.Remove(employee.Id);
        }
    }

    private static string GeneratePassword()
    {
        var raw = Guid.NewGuid().ToString("N");
        return char.ToUpper(raw[0]) + raw[1..9] + "!1";
    }
}
