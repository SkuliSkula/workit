@page "/employees"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject ICompanyApi CompanyApi
@inject IEmployeesApi EmployeesApi

<PageTitle>Employees</PageTitle>

<section class="emp-page">

    <div class="emp-layout">

        @* ── Sidebar: Add / Edit Employee forms ── *@
        <aside class="emp-sidebar">

            @* Add Employee Card *@
            <div class="emp-shell">
                <div class="emp-header">
                    <span class="emp-eyebrow">Employee management</span>
                    <h1 class="emp-title">Add Employee</h1>
                </div>

                @if (!string.IsNullOrWhiteSpace(loadError))
                {
                    <div class="emp-alert emp-alert--error">@loadError</div>
                }

                @if (company is null && !loading)
                {
                    <p class="emp-note">Set up the company first in Admin before adding employees.</p>
                }
                else if (company is not null)
                {
                    <div class="emp-form">
                        <label class="emp-field">
                            <span class="emp-label">Name</span>
                            <input class="emp-input" type="text" @bind="newEmployeeName" placeholder="Full name" />
                        </label>
                        <label class="emp-field">
                            <span class="emp-label">Trade</span>
                            <select class="emp-select" @bind="newEmployeeTrade">
                                @foreach (var trade in Trades)
                                {
                                    <option value="@trade">@trade</option>
                                }
                            </select>
                        </label>
                        <label class="emp-field">
                            <span class="emp-label">SSN</span>
                            <input class="emp-input" type="text" @bind="newEmployeeSsn" placeholder="Social security number" />
                        </label>
                        <label class="emp-field">
                            <span class="emp-label">Email</span>
                            <input class="emp-input" type="email" @bind="newEmployeeEmail" placeholder="employee@example.com" />
                        </label>
                        <label class="emp-field">
                            <span class="emp-label">Password</span>
                            <input class="emp-input" type="password" @bind="newEmployeePassword" placeholder="Min. 8 characters" />
                        </label>
                        <label class="emp-field">
                            <span class="emp-label">Phone</span>
                            <input class="emp-input" type="tel" @bind="newEmployeePhone" placeholder="Phone number" />
                        </label>
                        <label class="emp-field">
                            <span class="emp-label">Contact person</span>
                            <input class="emp-input" type="text" @bind="newEmployeeContactPerson" placeholder="Emergency contact" />
                        </label>
                        <div class="emp-actions">
                            <button class="emp-btn emp-btn--primary" @onclick="CreateEmployeeAsync"
                                    disabled="@string.IsNullOrWhiteSpace(newEmployeeName)">
                                Add Employee
                            </button>
                        </div>
                    </div>
                }
            </div>

            @* Edit Employee Card *@
            @if (editingEmployee is not null)
            {
                <div class="emp-shell">
                    <div class="emp-header">
                        <span class="emp-eyebrow">Editing employee</span>
                        <h2 class="emp-title">Edit Employee</h2>
                    </div>
                    <div class="emp-form">
                        <label class="emp-field">
                            <span class="emp-label">Name</span>
                            <input class="emp-input" type="text" @bind="editingEmployee.DisplayName" placeholder="Full name" />
                        </label>
                        <label class="emp-field">
                            <span class="emp-label">Trade</span>
                            <select class="emp-select" @bind="editingEmployee.Trade">
                                @foreach (var trade in Trades)
                                {
                                    <option value="@trade">@trade</option>
                                }
                            </select>
                        </label>
                        <label class="emp-field">
                            <span class="emp-label">SSN</span>
                            <input class="emp-input" type="text" @bind="editingEmployee.Ssn" placeholder="Social security number" />
                        </label>
                        <label class="emp-field">
                            <span class="emp-label">Email</span>
                            <input class="emp-input" type="email" @bind="editingEmployee.Email" placeholder="employee@example.com" />
                        </label>
                        <label class="emp-field">
                            <span class="emp-label">Phone</span>
                            <input class="emp-input" type="tel" @bind="editingEmployee.Phone" placeholder="Phone number" />
                        </label>
                        <label class="emp-field">
                            <span class="emp-label">Contact person</span>
                            <input class="emp-input" type="text" @bind="editingEmployee.ContactPerson" placeholder="Emergency contact" />
                        </label>
                        <div class="emp-actions">
                            <button class="emp-btn emp-btn--primary" @onclick="SaveEmployeeAsync">Save Changes</button>
                            <button class="emp-btn emp-btn--outline" @onclick="CancelEmployeeEdit">Cancel</button>
                        </div>
                    </div>
                </div>
            }
        </aside>

        @* ── Main: Employee list ── *@
        <div class="emp-shell emp-list-shell">
            <div class="emp-header">
                <span class="emp-eyebrow">Employee roster</span>
                <h2 class="emp-title">All Employees</h2>
            </div>

            @if (loading)
            {
                <PageLoader />
            }
            else if (employees.Count > 0)
            {
                <div class="emp-table-wrap">
                    <table class="emp-table">
                        <thead>
                            <tr>
                                <th class="emp-th">Name</th>
                                <th class="emp-th">Trade</th>
                                <th class="emp-th">SSN</th>
                                <th class="emp-th">Email</th>
                                <th class="emp-th">Phone</th>
                                <th class="emp-th">Contact Person</th>
                                <th class="emp-th"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var emp in employees)
                            {
                                <tr class="emp-tr">
                                    <td class="emp-td emp-td--name">@emp.DisplayName</td>
                                    <td class="emp-td">@emp.Trade</td>
                                    <td class="emp-td">@emp.Ssn</td>
                                    <td class="emp-td">@emp.Email</td>
                                    <td class="emp-td">@emp.Phone</td>
                                    <td class="emp-td">@emp.ContactPerson</td>
                                    <td class="emp-td emp-td--actions">
                                        <button class="emp-btn emp-btn--outline emp-btn--sm"
                                                @onclick="@(() => BeginEditEmployee(emp))">Edit</button>
                                        <button class="emp-btn emp-btn--outline emp-btn--sm"
                                                @onclick="@(() => ResetEmployeePasswordAsync(emp))"
                                                disabled="@resettingIds.Contains(emp.Id)">
                                            @(resettingIds.Contains(emp.Id) ? "Resetting…" : "Reset Password")
                                        </button>
                                        @if (resetPasswords.TryGetValue(emp.Id, out var pw))
                                        {
                                            <span class="emp-new-password">New: @pw</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="emp-empty">No employees yet. Add the first one using the form.</p>
            }
        </div>

    </div>

</section>

@code {
    private static readonly string[] Trades = ["Electrician", "Carpenter", "Plumber", "Painter", "Other"];

    private bool loading = true;
    private readonly List<Employee> employees = [];
    private Company? company;
    private Employee? editingEmployee;
    private string newEmployeeName = string.Empty;
    private string newEmployeeTrade = Trades[0];
    private string newEmployeeSsn = string.Empty;
    private string newEmployeeEmail = string.Empty;
    private string newEmployeePassword = string.Empty;
    private string newEmployeePhone = string.Empty;
    private string newEmployeeContactPerson = string.Empty;
    private string? loadError;

    // ── Reset Password state ─────────────────────────────────────────────────
    private readonly HashSet<Guid> resettingIds = [];
    private readonly Dictionary<Guid, string> resetPasswords = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        loading = true;
        loadError = null;
        employees.Clear();
        var companyResult = await CompanyApi.GetCompanyAsync();
        company = companyResult.Value;

        if (!companyResult.IsSuccess)
        {
            loadError = companyResult.ErrorMessage;
            loading = false;
            return;
        }

        if (company is null)
        {
            loading = false;
            return;
        }

        var employeesResult = await EmployeesApi.GetEmployeesAsync();
        if (!employeesResult.IsSuccess)
        {
            loadError = employeesResult.ErrorMessage;
            loading = false;
            return;
        }

        employees.AddRange(employeesResult.Value ?? []);
        loading = false;
    }

    private async Task CreateEmployeeAsync()
    {
        if (company is null || string.IsNullOrWhiteSpace(newEmployeeName))
        {
            return;
        }

        var result = await EmployeesApi.CreateEmployeeAsync(new CreateEmployeeUserRequest
        {
            Employee = new Employee
            {
                CompanyId = company.Id,
                DisplayName = newEmployeeName.Trim(),
                Trade = newEmployeeTrade.Trim(),
                Ssn = newEmployeeSsn.Trim(),
                Email = newEmployeeEmail.Trim(),
                Phone = newEmployeePhone.Trim(),
                ContactPerson = newEmployeeContactPerson.Trim()
            },
            Password = newEmployeePassword
        });

        if (result.IsSuccess)
        {
            newEmployeeName = string.Empty;
            newEmployeeTrade = Trades[0];
            newEmployeeSsn = string.Empty;
            newEmployeeEmail = string.Empty;
            newEmployeePassword = string.Empty;
            newEmployeePhone = string.Empty;
            newEmployeeContactPerson = string.Empty;
            await LoadAsync();
            return;
        }

        loadError = result.ErrorMessage;
    }

    private void BeginEditEmployee(Employee employee)
    {
        editingEmployee = new Employee
        {
            Id = employee.Id,
            CompanyId = employee.CompanyId,
            DisplayName = employee.DisplayName,
            Trade = employee.Trade,
            Ssn = employee.Ssn,
            Email = employee.Email,
            Phone = employee.Phone,
            ContactPerson = employee.ContactPerson
        };
    }

    private async Task SaveEmployeeAsync()
    {
        if (editingEmployee is null)
        {
            return;
        }

        var result = await EmployeesApi.UpdateEmployeeAsync(editingEmployee);
        if (result.IsSuccess)
        {
            editingEmployee = null;
            await LoadAsync();
            return;
        }

        loadError = result.ErrorMessage;
    }

    private void CancelEmployeeEdit()
    {
        editingEmployee = null;
    }

    private async Task ResetEmployeePasswordAsync(Employee employee)
    {
        resettingIds.Add(employee.Id);
        resetPasswords.Remove(employee.Id);

        try
        {
            var password = GeneratePassword();
            var result = await EmployeesApi.ResetPasswordAsync(employee.Id, password);
            if (result.IsSuccess)
                resetPasswords[employee.Id] = password;
            else
                loadError = result.ErrorMessage;
        }
        finally
        {
            resettingIds.Remove(employee.Id);
        }
    }

    private static string GeneratePassword()
    {
        var raw = Guid.NewGuid().ToString("N");
        return char.ToUpper(raw[0]) + raw[1..9] + "!1";
    }
}
