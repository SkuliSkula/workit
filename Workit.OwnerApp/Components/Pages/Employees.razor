@page "/employees"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject ICompanyApi CompanyApi
@inject IEmployeesApi EmployeesApi

<PageTitle>Employees</PageTitle>

<FluentCard Class="admin-card" AreaRestricted="false">
    <FluentLabel Typo="Typography.PaneHeader">Employees</FluentLabel>

    <div class="emp-layout">
        <div class="emp-sidebar">
            @if (company is null)
            {
                <FluentLabel>Set up the company first in Admin before adding employees.</FluentLabel>
            }
            else
            {
                <div class="emp-form">
                    <label class="emp-field">
                        <span>Name</span>
                        <FluentTextField @bind-Value="newEmployeeName" Placeholder="Full name" style="width:100%" />
                    </label>
                    <label class="emp-field">
                        <span>Trade</span>
                        <FluentSelect TValue="string" TOption="string" @bind-Value="newEmployeeTrade" style="width:100%">
                            @foreach (var trade in Trades)
                            {
                                <FluentOption TOption="string" Value="@trade">@trade</FluentOption>
                            }
                        </FluentSelect>
                    </label>
                    <label class="emp-field">
                        <span>SSN</span>
                        <FluentTextField @bind-Value="newEmployeeSsn" Placeholder="Social security number" style="width:100%" />
                    </label>
                    <label class="emp-field">
                        <span>Email</span>
                        <FluentTextField @bind-Value="newEmployeeEmail" Placeholder="employee@example.com" style="width:100%" />
                    </label>
                    <label class="emp-field">
                        <span>Password</span>
                        <FluentTextField @bind-Value="newEmployeePassword" Placeholder="Min. 8 characters" TextFieldType="TextFieldType.Password" style="width:100%" />
                    </label>
                    <label class="emp-field">
                        <span>Phone</span>
                        <FluentTextField @bind-Value="newEmployeePhone" Placeholder="Phone number" style="width:100%" />
                    </label>
                    <label class="emp-field">
                        <span>Contact person</span>
                        <FluentTextField @bind-Value="newEmployeeContactPerson" Placeholder="Emergency contact" style="width:100%" />
                    </label>
                    <div class="emp-actions">
                        <FluentButton Appearance="Appearance.Accent" @onclick="CreateEmployeeAsync">Add Employee</FluentButton>
                    </div>
                </div>
            }

            @if (editingEmployee is not null)
            {
                <FluentCard Class="admin-card" AreaRestricted="false">
                    <FluentLabel Typo="Typography.PaneHeader">Edit Employee</FluentLabel>
                    <div class="emp-form">
                        <label class="emp-field">
                            <span>Name</span>
                            <FluentTextField @bind-Value="editingEmployee.DisplayName" Placeholder="Full name" style="width:100%" />
                        </label>
                        <label class="emp-field">
                            <span>Trade</span>
                            <FluentSelect TValue="string" TOption="string" @bind-Value="editingEmployee.Trade" style="width:100%">
                                @foreach (var trade in Trades)
                                {
                                    <FluentOption TOption="string" Value="@trade">@trade</FluentOption>
                                }
                            </FluentSelect>
                        </label>
                        <label class="emp-field">
                            <span>SSN</span>
                            <FluentTextField @bind-Value="editingEmployee.Ssn" Placeholder="Social security number" style="width:100%" />
                        </label>
                        <label class="emp-field">
                            <span>Email</span>
                            <FluentTextField @bind-Value="editingEmployee.Email" Placeholder="employee@example.com" style="width:100%" />
                        </label>
                        <label class="emp-field">
                            <span>Phone</span>
                            <FluentTextField @bind-Value="editingEmployee.Phone" Placeholder="Phone number" style="width:100%" />
                        </label>
                        <label class="emp-field">
                            <span>Contact person</span>
                            <FluentTextField @bind-Value="editingEmployee.ContactPerson" Placeholder="Emergency contact" style="width:100%" />
                        </label>
                        <div class="emp-actions">
                            <FluentButton Appearance="Appearance.Accent" @onclick="SaveEmployeeAsync">Save Changes</FluentButton>
                            <FluentButton Appearance="Appearance.Outline" @onclick="CancelEmployeeEdit">Cancel</FluentButton>
                        </div>
                    </div>
                </FluentCard>
            }

            @if (!string.IsNullOrWhiteSpace(loadError))
            {
                <FluentLabel>@loadError</FluentLabel>
            }
        </div>

        <div class="emp-list">
            @if (employees.Count > 0)
            {
                <FluentDataGrid TGridItem="Employee" Items="@employees.AsQueryable()" AutoFit="true" DisplayMode="DataGridDisplayMode.Table">
                    <PropertyColumn Property="@(x => x.DisplayName)" Title="Name" />
                    <PropertyColumn Property="@(x => x.Trade)" Title="Trade" />
                    <PropertyColumn Property="@(x => x.Ssn)" Title="SSN" />
                    <PropertyColumn Property="@(x => x.Email)" Title="Email" />
                    <PropertyColumn Property="@(x => x.Phone)" Title="Phone" />
                    <PropertyColumn Property="@(x => x.ContactPerson)" Title="Contact Person" />
                    <TemplateColumn Title="Actions">
                        <div style="display:flex; align-items:center; gap:0.5rem; flex-wrap:wrap;">
                            <FluentButton Appearance="Appearance.Stealth" @onclick="@(() => BeginEditEmployee(context))">Edit</FluentButton>
                            <FluentButton Appearance="Appearance.Stealth" @onclick="@(() => ResetEmployeePasswordAsync(context))"
                                          Disabled="@resettingIds.Contains(context.Id)">
                                @(resettingIds.Contains(context.Id) ? "Resetting…" : "Reset Password")
                            </FluentButton>
                            @if (resetPasswords.TryGetValue(context.Id, out var pw))
                            {
                                <FluentLabel style="font-weight:600; color:var(--accent-fill-rest);">New password: @pw</FluentLabel>
                            }
                        </div>
                    </TemplateColumn>
                </FluentDataGrid>
            }
            else
            {
                <FluentLabel>No employees yet.</FluentLabel>
            }
        </div>
    </div>
</FluentCard>

@code {
    private static readonly string[] Trades = ["Electrician", "Carpenter", "Plumber", "Painter", "Other"];

    private readonly List<Employee> employees = [];
    private Company? company;
    private Employee? editingEmployee;
    private string newEmployeeName = string.Empty;
    private string newEmployeeTrade = Trades[0];
    private string newEmployeeSsn = string.Empty;
    private string newEmployeeEmail = string.Empty;
    private string newEmployeePassword = string.Empty;
    private string newEmployeePhone = string.Empty;
    private string newEmployeeContactPerson = string.Empty;
    private string? loadError;

    // ── Reset Password state ─────────────────────────────────────────────────
    private readonly HashSet<Guid> resettingIds = [];
    private readonly Dictionary<Guid, string> resetPasswords = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        loadError = null;
        employees.Clear();
        var companyResult = await CompanyApi.GetCompanyAsync();
        company = companyResult.Value;

        if (!companyResult.IsSuccess)
        {
            loadError = companyResult.ErrorMessage;
            return;
        }

        if (company is null)
        {
            return;
        }

        var employeesResult = await EmployeesApi.GetEmployeesAsync();
        if (!employeesResult.IsSuccess)
        {
            loadError = employeesResult.ErrorMessage;
            return;
        }

        employees.AddRange(employeesResult.Value ?? []);
    }

    private async Task CreateEmployeeAsync()
    {
        if (company is null || string.IsNullOrWhiteSpace(newEmployeeName))
        {
            return;
        }

        var result = await EmployeesApi.CreateEmployeeAsync(new CreateEmployeeUserRequest
        {
            Employee = new Employee
            {
                CompanyId = company.Id,
                DisplayName = newEmployeeName.Trim(),
                Trade = newEmployeeTrade.Trim(),
                Ssn = newEmployeeSsn.Trim(),
                Email = newEmployeeEmail.Trim(),
                Phone = newEmployeePhone.Trim(),
                ContactPerson = newEmployeeContactPerson.Trim()
            },
            Password = newEmployeePassword
        });

        if (result.IsSuccess)
        {
            newEmployeeName = string.Empty;
            newEmployeeTrade = Trades[0];
            newEmployeeSsn = string.Empty;
            newEmployeeEmail = string.Empty;
            newEmployeePassword = string.Empty;
            newEmployeePhone = string.Empty;
            newEmployeeContactPerson = string.Empty;
            await LoadAsync();
            return;
        }

        loadError = result.ErrorMessage;
    }

    private void BeginEditEmployee(Employee employee)
    {
        editingEmployee = new Employee
        {
            Id = employee.Id,
            CompanyId = employee.CompanyId,
            DisplayName = employee.DisplayName,
            Trade = employee.Trade,
            Ssn = employee.Ssn,
            Email = employee.Email,
            Phone = employee.Phone,
            ContactPerson = employee.ContactPerson
        };
    }

    private async Task SaveEmployeeAsync()
    {
        if (editingEmployee is null)
        {
            return;
        }

        var result = await EmployeesApi.UpdateEmployeeAsync(editingEmployee);
        if (result.IsSuccess)
        {
            editingEmployee = null;
            await LoadAsync();
            return;
        }

        loadError = result.ErrorMessage;
    }

    private void CancelEmployeeEdit()
    {
        editingEmployee = null;
    }

    private async Task ResetEmployeePasswordAsync(Employee employee)
    {
        resettingIds.Add(employee.Id);
        resetPasswords.Remove(employee.Id);

        try
        {
            var password = GeneratePassword();
            var result = await EmployeesApi.ResetPasswordAsync(employee.Id, password);
            if (result.IsSuccess)
                resetPasswords[employee.Id] = password;
            else
                loadError = result.ErrorMessage;
        }
        finally
        {
            resettingIds.Remove(employee.Id);
        }
    }

    private static string GeneratePassword()
    {
        var raw = Guid.NewGuid().ToString("N");
        return char.ToUpper(raw[0]) + raw[1..9] + "!1";
    }
}
