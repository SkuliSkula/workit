@page "/onboarding"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject AuthSessionService AuthSession
@inject ICompanyApi CompanyApi
@inject NavigationManager Navigation

<PageTitle>Set Up Your Company — Workit</PageTitle>

<div class="onboarding-page">
    <div class="onboarding-header">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="48" height="48" fill="none">
            <rect width="64" height="64" rx="16" fill="#14304b"/>
            <g transform="translate(12, 8)" fill="#ffffff">
                <rect x="6" y="8" width="28" height="10" rx="3"/>
                <rect x="17" y="18" width="6" height="28" rx="3"/>
                <path d="M6 8 C6 8, 2 4, 4 2 C6 0, 10 4, 10 8" fill="#ffffff"/>
            </g>
        </svg>
        <div>
            <h1>Welcome to Workit</h1>
            <p>Set up your company to get started</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(globalError))
    {
        <div class="msg msg--error">@globalError</div>
    }

    @* ── Tab selector ── *@
    <div class="tab-row">
        <button class="tab-btn @(activeTab == Tab.Manual ? "active" : "")" @onclick="() => activeTab = Tab.Manual">
            🏢 Set up manually
        </button>
        <button class="tab-btn @(activeTab == Tab.Payday ? "active" : "")" @onclick="() => activeTab = Tab.Payday">
            🔗 Import from Payday
        </button>
    </div>

    @* ── Manual setup ── *@
    @if (activeTab == Tab.Manual)
    {
        <div class="onboarding-card">
            <h2>Company details</h2>
            <p class="hint">Fill in your company information. You can always update this later.</p>

            <div class="form-grid">
                <div>
                    <FluentLabel>Company name *</FluentLabel>
                    <FluentTextField @bind-Value="company.Name" Placeholder="e.g. Verkþjónustan ehf." style="width:100%" />
                </div>
                <div>
                    <FluentLabel>SSN (Kennitala) *</FluentLabel>
                    <FluentTextField @bind-Value="company.Ssn" Placeholder="e.g. 5012345678" style="width:100%" />
                </div>
                <div>
                    <FluentLabel>Email *</FluentLabel>
                    <FluentTextField @bind-Value="company.Email" Placeholder="info@company.is" style="width:100%" />
                </div>
                <div>
                    <FluentLabel>Phone *</FluentLabel>
                    <FluentTextField @bind-Value="company.Phone" Placeholder="e.g. 555-1234" style="width:100%" />
                </div>
                <div style="grid-column:span 2">
                    <FluentLabel>Address *</FluentLabel>
                    <FluentTextField @bind-Value="company.Address" Placeholder="e.g. Laugavegur 1, 101 Reykjavík" style="width:100%" />
                </div>
                <div style="grid-column:span 2">
                    <FluentLabel>Contact person *</FluentLabel>
                    <FluentTextField @bind-Value="company.Owner" Placeholder="Your full name" style="width:100%" />
                </div>
            </div>

            <div style="margin-top:1.5rem;">
                <FluentButton Appearance="Appearance.Accent" @onclick="SetupManualAsync"
                              Disabled="@(saving || !CanSaveManual)">
                    @(saving ? "Setting up…" : "Create Company")
                </FluentButton>
            </div>
        </div>
    }

    @* ── Payday import ── *@
    @if (activeTab == Tab.Payday)
    {
        <div class="onboarding-card">
            <h2>Connect to Payday</h2>
            <p class="hint">Enter your Payday API credentials. Your company info will be imported automatically.</p>

            <div class="form-grid" style="max-width:480px;">
                <div style="grid-column:span 2">
                    <FluentLabel>Client ID</FluentLabel>
                    <FluentTextField @bind-Value="paydayClientId" Placeholder="Payday client ID" style="width:100%" />
                </div>
                <div style="grid-column:span 2">
                    <FluentLabel>Client Secret</FluentLabel>
                    <FluentTextField @bind-Value="paydayClientSecret" Placeholder="Payday client secret"
                                     TextFieldType="TextFieldType.Password" style="width:100%" />
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(paydayError))
            {
                <div class="msg msg--error" style="margin-top:0.75rem;">@paydayError</div>
            }

            <div style="display:flex; gap:0.75rem; margin-top:1.25rem; flex-wrap:wrap; align-items:center;">
                <FluentButton Appearance="Appearance.Outline" @onclick="TestPaydayAsync"
                              Disabled="@(testingPayday || string.IsNullOrWhiteSpace(paydayClientId) || string.IsNullOrWhiteSpace(paydayClientSecret))">
                    @(testingPayday ? "Testing…" : "Test Connection")
                </FluentButton>
            </div>

            @if (paydayCompany is not null)
            {
                <div class="msg msg--success" style="margin-top:1rem;">
                    ✓ Connected — <strong>@paydayCompany.Name</strong> (@paydayCompany.Ssn)
                </div>

                <div style="margin-top:1rem;">
                    <FluentLabel>Contact person *</FluentLabel>
                    <FluentTextField @bind-Value="paydayCompany.Owner"
                                     Placeholder="Your full name"
                                     style="width:100%; max-width:480px;" />
                    <p class="hint" style="margin-top:0.4rem;">Enter the contact person name to complete setup.</p>
                </div>

                <div style="margin-top:1rem;">
                    <FluentButton Appearance="Appearance.Accent" @onclick="SetupFromPaydayAsync"
                                  Disabled="@(saving || string.IsNullOrWhiteSpace(paydayCompany.Owner))">
                        @(saving ? "Setting up…" : "Create Company from Payday")
                    </FluentButton>
                </div>
            }
        </div>
    }
</div>

<style>
    .onboarding-page {
        max-width: 720px;
        margin: 2rem auto;
        padding: 0 1rem;
        display: grid;
        gap: 1.25rem;
    }

    .onboarding-header {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .onboarding-header h1 {
        margin: 0;
        font-size: 1.6rem;
        color: #14304b;
    }

    .onboarding-header p {
        margin: 0.1rem 0 0;
        color: #60758b;
        font-size: 0.9rem;
    }

    .tab-row {
        display: flex;
        gap: 0.5rem;
        border-bottom: 2px solid #e5e7eb;
        padding-bottom: 0;
    }

    .tab-btn {
        background: none;
        border: none;
        border-bottom: 3px solid transparent;
        padding: 0.6rem 1.25rem;
        cursor: pointer;
        font-size: 0.95rem;
        font-weight: 500;
        color: #60758b;
        margin-bottom: -2px;
        transition: color 0.15s, border-color 0.15s;
    }

    .tab-btn.active {
        color: #14304b;
        border-bottom-color: #14304b;
    }

    .tab-btn:hover:not(.active) {
        color: #14304b;
    }

    .onboarding-card {
        background: #fff;
        border: 1px solid rgba(20, 48, 75, 0.1);
        border-radius: 16px;
        padding: 1.5rem 1.75rem;
    }

    .onboarding-card h2 {
        margin: 0 0 0.25rem;
        color: #14304b;
        font-size: 1.15rem;
    }

    .hint {
        margin: 0 0 1.25rem;
        color: #60758b;
        font-size: 0.875rem;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem 1rem;
    }

    .msg {
        padding: 0.75rem 1rem;
        border-radius: 10px;
        font-size: 0.85rem;
    }

    .msg--error {
        background: #fef2f2;
        color: #991b1b;
        border: 1px solid #fecaca;
    }

    .msg--success {
        background: #ecfdf5;
        color: #065f46;
        border: 1px solid #a7f3d0;
    }
</style>

@code {
    private enum Tab { Manual, Payday }
    private Tab activeTab = Tab.Manual;

    // Manual form
    private Company company = new();
    private bool saving;
    private string? globalError;

    private bool CanSaveManual =>
        !string.IsNullOrWhiteSpace(company.Name) &&
        !string.IsNullOrWhiteSpace(company.Ssn)  &&
        !string.IsNullOrWhiteSpace(company.Email) &&
        !string.IsNullOrWhiteSpace(company.Phone) &&
        !string.IsNullOrWhiteSpace(company.Address) &&
        !string.IsNullOrWhiteSpace(company.Owner);

    // Payday form
    private string paydayClientId = string.Empty;
    private string paydayClientSecret = string.Empty;
    private bool testingPayday;
    private string? paydayError;
    private Company? paydayCompany;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var session = await AuthSession.GetSessionAsync();

        // Redirect if not logged in
        if (session is null)
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }

        // Redirect if already has a company
        if (session.Role == WorkitRoles.Owner && session.CompanyId != Guid.Empty)
        {
            Navigation.NavigateTo("/", forceLoad: true);
            return;
        }

        // Redirect non-owners
        if (session.Role != WorkitRoles.Owner)
        {
            Navigation.NavigateTo("/", forceLoad: true);
            return;
        }

        StateHasChanged();
    }

    private async Task SetupManualAsync()
    {
        saving = true;
        globalError = null;

        try
        {
            var result = await AuthSession.SetupOwnerCompanyAsync(new OwnerSetupCompanyRequest
            {
                Company = company
            });

            if (result.IsSuccess)
            {
                Navigation.NavigateTo("/", forceLoad: true);
            }
            else
            {
                globalError = result.ErrorMessage ?? "Could not set up company.";
            }
        }
        finally
        {
            saving = false;
        }
    }

    private async Task TestPaydayAsync()
    {
        testingPayday = true;
        paydayError   = null;
        paydayCompany = null;

        try
        {
            var result = await CompanyApi.TestPaydayCredentialsAsync(
                paydayClientId.Trim(),
                paydayClientSecret.Trim());

            if (!result.IsSuccess)
            {
                paydayError = result.ErrorMessage ?? "Could not reach the Payday test endpoint.";
                return;
            }

            var data = result.Value;
            if (data is null || !data.Success)
            {
                paydayError = data?.Message ?? "Authentication failed. Check your credentials and try again.";
                return;
            }

            // Populate a Company object from the Payday response
            paydayCompany = new Company
            {
                Name    = data.CompanyName    ?? string.Empty,
                Ssn     = data.CompanySsn     ?? string.Empty,
                Email   = data.CompanyEmail   ?? string.Empty,
                Phone   = data.CompanyPhone   ?? string.Empty,
                Address = data.CompanyAddress ?? string.Empty,
                Owner   = string.Empty   // owner fills this in or edits after setup
            };
        }
        finally
        {
            testingPayday = false;
        }
    }

    private async Task SetupFromPaydayAsync()
    {
        if (paydayCompany is null) return;

        saving = true;
        globalError = null;

        try
        {
            var result = await AuthSession.SetupOwnerCompanyAsync(new OwnerSetupCompanyRequest
            {
                Company            = paydayCompany,
                PaydayClientId     = paydayClientId.Trim(),
                PaydayClientSecret = paydayClientSecret.Trim()
            });

            if (result.IsSuccess)
            {
                Navigation.NavigateTo("/payday", forceLoad: true);
            }
            else
            {
                globalError = result.ErrorMessage ?? "Could not set up company from Payday.";
            }
        }
        finally
        {
            saving = false;
        }
    }
}
