@page "/tools"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IToolsApi ToolsApi
@inject IEmployeesApi EmployeesApi

<PageTitle>Tools</PageTitle>

<section class="tool-page">

    @* ── Add Tool ── *@
    <div class="tool-shell">
        <div class="tool-header">
            <span class="tool-eyebrow">Tool management</span>
            <h1 class="tool-title">Add Tool</h1>
        </div>

        @if (!string.IsNullOrWhiteSpace(loadError))
        {
            <div class="tool-alert tool-alert--error">@loadError</div>
        }

        <div class="tool-form-grid">
            <label class="tool-field">
                <span class="tool-label">Name</span>
                <input class="tool-input" type="text" @bind="newName" placeholder="e.g. Angle grinder" />
            </label>
            <label class="tool-field">
                <span class="tool-label">Serial number</span>
                <input class="tool-input" type="text" @bind="newSerial" placeholder="Optional" />
            </label>
            <label class="tool-field tool-field--wide">
                <span class="tool-label">Description</span>
                <input class="tool-input" type="text" @bind="newDescription" placeholder="Optional notes" />
            </label>
        </div>

        <div class="tool-form-actions">
            <button class="tool-btn tool-btn--primary" @onclick="CreateToolAsync"
                    disabled="@(string.IsNullOrWhiteSpace(newName) || saving)">
                @(saving ? "Saving…" : "Add Tool")
            </button>
        </div>

        @if (!string.IsNullOrWhiteSpace(saveResult))
        {
            <div class="tool-alert tool-alert--ok">@saveResult</div>
        }
    </div>

    @* ── Edit panel ── *@
    @if (editingTool is not null)
    {
        <div class="tool-shell">
            <div class="tool-header">
                <span class="tool-eyebrow">Editing tool</span>
                <h2 class="tool-title">Edit Tool</h2>
            </div>

            <div class="tool-form-grid">
                <label class="tool-field">
                    <span class="tool-label">Name</span>
                    <input class="tool-input" type="text" @bind="editingTool.Name" />
                </label>
                <label class="tool-field">
                    <span class="tool-label">Serial number</span>
                    <input class="tool-input" type="text" @bind="editingTool.SerialNumber" />
                </label>
                <label class="tool-field tool-field--wide">
                    <span class="tool-label">Description</span>
                    <input class="tool-input" type="text" @bind="editingTool.Description" />
                </label>
            </div>

            <div class="tool-form-actions">
                <button class="tool-btn tool-btn--primary" @onclick="SaveToolAsync"
                        disabled="@(string.IsNullOrWhiteSpace(editingTool.Name) || saving)">
                    @(saving ? "Saving…" : "Save Changes")
                </button>
                <button class="tool-btn tool-btn--outline" @onclick="CancelEdit">Cancel</button>
            </div>
        </div>
    }

    @* ── Tool Inventory ── *@
    <div class="tool-shell">
        <div class="tool-header">
            <span class="tool-eyebrow">Inventory</span>
            <h2 class="tool-title">Tool Inventory</h2>
        </div>

        @if (loading)
        {
            <PageLoader />
        }
        else if (tools.Count > 0)
        {
            <div class="tool-table-wrap">
                <table class="tool-table">
                    <thead>
                        <tr>
                            <th class="tool-th">Name</th>
                            <th class="tool-th">Serial #</th>
                            <th class="tool-th">Description</th>
                            <th class="tool-th">Added</th>
                            <th class="tool-th">Status</th>
                            <th class="tool-th"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in tools)
                        {
                            <tr class="tool-tr">
                                <td class="tool-td tool-td--name">@row.Name</td>
                                <td class="tool-td">@row.SerialNumber</td>
                                <td class="tool-td">@row.Description</td>
                                <td class="tool-td tool-td--dim">@row.CreatedAt.LocalDateTime.ToString("dd MMM yyyy")</td>
                                <td class="tool-td">
                                    @if (row.IsAssigned)
                                    {
                                        <span class="tool-badge tool-badge--amber">In use</span>
                                    }
                                    else
                                    {
                                        <span class="tool-badge tool-badge--green">Available</span>
                                    }
                                </td>
                                <td class="tool-td tool-td--actions">
                                    <button class="tool-btn tool-btn--outline tool-btn--sm"
                                            @onclick="@(() => BeginEdit(row.Tool))">Edit</button>
                                    <button class="tool-btn tool-btn--danger tool-btn--sm"
                                            disabled="@row.IsAssigned"
                                            @onclick="@(() => DeleteToolAsync(row.Tool))">Delete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="tool-empty">No tools yet. Add the first one above.</p>
        }
    </div>

    @* ── Assignment Overview ── *@
    <div class="tool-shell">
        <div class="tool-header">
            <span class="tool-eyebrow">Assignments</span>
            <h2 class="tool-title">Current Tool Assignments</h2>
        </div>

        @if (currentAssignments.Count > 0)
        {
            <div class="tool-table-wrap">
                <table class="tool-table">
                    <thead>
                        <tr>
                            <th class="tool-th">Tool</th>
                            <th class="tool-th">Employee</th>
                            <th class="tool-th">Assigned since</th>
                            <th class="tool-th">Duration</th>
                            <th class="tool-th"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in currentAssignments)
                        {
                            <tr class="tool-tr">
                                <td class="tool-td tool-td--name">@row.ToolName</td>
                                <td class="tool-td">@row.EmployeeName</td>
                                <td class="tool-td tool-td--dim">@row.AssignedSince</td>
                                <td class="tool-td">@row.Duration</td>
                                <td class="tool-td tool-td--actions">
                                    <button class="tool-btn tool-btn--outline tool-btn--sm"
                                            @onclick="@(() => ReturnToolAsync(row.Assignment))">Return</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="tool-empty">No tools are currently assigned.</p>
        }
    </div>

</section>

@code {

    // ── State ─────────────────────────────────────────────────────────────────
    private bool loading = true;
    private readonly List<ToolRow> tools = [];
    private readonly List<AssignmentRow> currentAssignments = [];
    private readonly Dictionary<Guid, string> employeeNames = new();
    private readonly Dictionary<Guid, string> toolNames = new();

    private string newName        = string.Empty;
    private string newSerial      = string.Empty;
    private string newDescription = string.Empty;
    private bool   saving;
    private string? saveResult;
    private string? loadError;

    private Tool? editingTool;

    // ── View models ───────────────────────────────────────────────────────────
    private sealed class ToolRow
    {
        public Tool   Tool         { get; set; } = null!;
        public string Name         => Tool.Name;
        public string SerialNumber => Tool.SerialNumber;
        public string Description  => Tool.Description;
        public DateTimeOffset CreatedAt => Tool.CreatedAt;
        public bool   IsAssigned   { get; set; }
    }

    private sealed class AssignmentRow
    {
        public ToolAssignment Assignment    { get; set; } = null!;
        public string         ToolName     { get; set; } = string.Empty;
        public string         EmployeeName { get; set; } = string.Empty;
        public string         AssignedSince => Assignment.AssignedAt.LocalDateTime.ToString("dd MMM yyyy HH:mm");
        public string         Duration      => FormatDuration(DateTimeOffset.UtcNow - Assignment.AssignedAt);

        private static string FormatDuration(TimeSpan span)
        {
            if (span.TotalDays >= 1)
                return $"{(int)span.TotalDays}d {span.Hours}h";
            if (span.TotalHours >= 1)
                return $"{(int)span.TotalHours}h {span.Minutes}m";
            return $"{span.Minutes}m";
        }
    }

    // ── Lifecycle ─────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        loading = true;
        loadError = null;
        tools.Clear();
        currentAssignments.Clear();
        employeeNames.Clear();
        toolNames.Clear();

        var empTask  = EmployeesApi.GetEmployeesAsync();
        var toolTask = ToolsApi.GetToolsAsync();
        await Task.WhenAll(empTask, toolTask);

        var empResult = await empTask;
        if (empResult.IsSuccess)
        {
            foreach (var e in empResult.Value ?? [])
                employeeNames[e.Id] = e.DisplayName;
        }

        var toolResult = await toolTask;
        if (!toolResult.IsSuccess)
        {
            loadError = toolResult.ErrorMessage;
            loading = false;
            return;
        }

        foreach (var t in toolResult.Value ?? [])
            toolNames[t.Id] = t.Name;

        var assignResult = await ToolsApi.GetToolAssignmentsAsync();
        if (!assignResult.IsSuccess)
        {
            loadError = assignResult.ErrorMessage;
            loading = false;
            return;
        }

        var allAssignments = assignResult.Value ?? [];
        var assignedToolIds = allAssignments
            .Where(a => a.ReturnedAt == null)
            .Select(a => a.ToolId)
            .ToHashSet();

        foreach (var t in toolResult.Value ?? [])
        {
            tools.Add(new ToolRow { Tool = t, IsAssigned = assignedToolIds.Contains(t.Id) });
        }

        foreach (var a in allAssignments.Where(x => x.ReturnedAt == null).OrderBy(x => x.AssignedAt))
        {
            currentAssignments.Add(new AssignmentRow
            {
                Assignment   = a,
                ToolName     = toolNames.GetValueOrDefault(a.ToolId, a.ToolId.ToString()),
                EmployeeName = employeeNames.GetValueOrDefault(a.EmployeeId, a.EmployeeId.ToString())
            });
        }
        loading = false;
    }

    // ── Create ────────────────────────────────────────────────────────────────
    private async Task CreateToolAsync()
    {
        if (string.IsNullOrWhiteSpace(newName)) return;

        saving     = true;
        saveResult = null;

        try
        {
            var result = await ToolsApi.CreateToolAsync(new Tool
            {
                Name         = newName.Trim(),
                SerialNumber = newSerial.Trim(),
                Description  = newDescription.Trim()
            });

            if (result.IsSuccess)
            {
                saveResult    = $"✓ Tool '{result.Value!.Name}' added.";
                newName        = string.Empty;
                newSerial      = string.Empty;
                newDescription = string.Empty;
                await LoadAsync();
            }
            else
            {
                saveResult = $"Error: {result.ErrorMessage}";
            }
        }
        finally
        {
            saving = false;
        }
    }

    // ── Edit ──────────────────────────────────────────────────────────────────
    private void BeginEdit(Tool tool)
    {
        editingTool = new Tool
        {
            Id           = tool.Id,
            CompanyId    = tool.CompanyId,
            Name         = tool.Name,
            SerialNumber = tool.SerialNumber,
            Description  = tool.Description
        };
        saveResult = null;
    }

    private async Task SaveToolAsync()
    {
        if (editingTool is null || string.IsNullOrWhiteSpace(editingTool.Name)) return;

        saving = true;
        try
        {
            var result = await ToolsApi.UpdateToolAsync(editingTool.Id, editingTool);
            if (result.IsSuccess)
            {
                saveResult  = $"✓ Tool '{result.Value!.Name}' updated.";
                editingTool = null;
                await LoadAsync();
            }
            else
            {
                saveResult = $"Error: {result.ErrorMessage}";
            }
        }
        finally
        {
            saving = false;
        }
    }

    private void CancelEdit()
    {
        editingTool = null;
        saveResult  = null;
    }

    // ── Delete ────────────────────────────────────────────────────────────────
    private async Task DeleteToolAsync(Tool tool)
    {
        saving = true;
        try
        {
            var result = await ToolsApi.DeleteToolAsync(tool.Id);
            if (result.IsSuccess)
            {
                saveResult = $"✓ Tool '{tool.Name}' deleted.";
                await LoadAsync();
            }
            else
            {
                saveResult = $"Error: {result.ErrorMessage}";
            }
        }
        finally
        {
            saving = false;
        }
    }

    // ── Return ────────────────────────────────────────────────────────────────
    private async Task ReturnToolAsync(ToolAssignment assignment)
    {
        saving = true;
        try
        {
            var result = await ToolsApi.ReturnToolAsync(assignment.ToolId);
            if (result.IsSuccess)
            {
                var name = toolNames.GetValueOrDefault(assignment.ToolId, "Tool");
                saveResult = $"✓ '{name}' marked as returned.";
                await LoadAsync();
            }
            else
            {
                saveResult = $"Error: {result.ErrorMessage}";
            }
        }
        finally
        {
            saving = false;
        }
    }
}
